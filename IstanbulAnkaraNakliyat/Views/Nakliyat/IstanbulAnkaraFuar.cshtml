@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "BreadcrumbList",
    "itemListElement": [
        { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
        { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
        { "@@type": "ListItem", "position": 3, "name": "İstanbul Ankara Fuar Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-fuar-nakliyat" }
    ]
}
</script>
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "Service",
    "name": "İstanbul Ankara Fuar Nakliyat",
    "provider": { "@@type": "LocalBusiness", "name": "İstanbul Ankara Nakliyat", "telephone": "+905325436837", "url": "https://www.istanbulankaranakliyat.tr" },
    "areaServed": [{ "@@type": "City", "name": "İstanbul" }, { "@@type": "City", "name": "Ankara" }],
    "description": "İstanbul'daki fuar merkezlerinden Ankara fuar alanlarına stand, display, sergi malzemesi ve promosyon ürünü taşımacılığı.",
    "offers": { "@@type": "AggregateOffer", "priceCurrency": "TRY", "lowPrice": "3500", "highPrice": "14000" }
}
</script>
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "FAQPage",
    "mainEntity": [
        {
            "@@type": "Question",
            "name": "İstanbul'dan Ankara'ya fuar nakliyat fiyatı ne kadar?",
            "acceptedAnswer": { "@@type": "Answer", "text": "2026 itibarıyla İstanbul'dan Ankara'ya fuar malzemesi taşıma; minivan/transit ile küçük stand için 3.500–5.000 ₺, kamyonet ile orta stand ve ekipman için 4.500–7.500 ₺, 12 tonluk kamyon ile büyük stand kompleksi için 8.000–14.000 ₺ arasında başlamaktadır. Kesin fiyat, eşya listesi ve hacim bilgisine göre belirlenir." }
        },
        {
            "@@type": "Question",
            "name": "Fuar stand montajı da yapıyor musunuz?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Nakliyat kapsamında stand parçalarının Ankara fuar alanına güvenli taşınmasını sağlıyoruz. Stand kurulumu (montaj) ise stand sistemine göre ek organizasyon gerektirdiğinden, talebinizi önceden bildirirseniz bu konuda yönlendirme yapabiliriz." }
        },
        {
            "@@type": "Question",
            "name": "İstanbul CNR Expo'dan Ankara'ya taşıma kaç saatte yapılır?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Yeşilköy'deki CNR Expo'dan TEM-E5 güzergahıyla Ankara'ya yaklaşık 4,5–6 saat yol süresi söz konusudur. Yükleme ve boşaltma dahil toplam 8–12 saat içinde Ankara fuar alanına teslim yapılmaktadır. Fuar açılışından 1 gün önce hareket önerilir." }
        },
        {
            "@@type": "Question",
            "name": "Fuar malzemeleri için özel ambalaj yapıyor musunuz?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Stand profilleri için köpük tabanlı sarma malzeme, vitrin ve display ekipmanları için balonlu naylon ve streç film, elektronik ekipmanlar için sert köpük dolgu kullanıyoruz. Kırılgan sergi ürünleri, porselen veya cam numuneler için özel sandık ambalaj da temin edebiliyoruz." }
        },
        {
            "@@type": "Question",
            "name": "Fuar sonrası İstanbul'a geri dönüş nakliyatı da yapıyor musunuz?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Evet, gidişli-dönüşlü fuar nakliyat paketimiz mevcuttur. Fuar kapanışı günü veya ertesinde malzemelerinizi Ankara'dan alarak İstanbul'a iade ediyoruz. Paket fiyatlaması için fuar tarihlerinizi önceden bildirin." }
        }
    ]
}
</script>
}

