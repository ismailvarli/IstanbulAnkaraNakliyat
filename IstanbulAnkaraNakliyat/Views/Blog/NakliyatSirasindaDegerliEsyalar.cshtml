<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "BreadcrumbList",
    "itemListElement": [
        { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
        { "@@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.istanbulankaranakliyat.tr/blog" },
        { "@@type": "ListItem", "position": 3, "name": "Nakliyatta Değerli Eşyaları Koruma", "item": "https://www.istanbulankaranakliyat.tr/blog/nakliyat-sirasinda-degerli-esyalar" }
    ]
}
</script>
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "FAQPage",
    "mainEntity": [
        {
            "@@type": "Question",
            "name": "Mücevherleri ve altınları nakliyatta nasıl taşımalıyım?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Mücevher ve altın gibi küçük değerli eşyalar kesinlikle nakliyat aracına bırakılmamalıdır. Bu eşyaları bizzat yanınızda, güvenli bir çantada taşımanız önerilir. Değeri yüksekse banka kasasına kaldırıp yeni adresinizde teslim almanız en güvenli yöntemdir." }
        },
        {
            "@@type": "Question",
            "name": "Antika ve sanat eserleri nakliyatta nasıl korunur?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Antika ve sanat eserlerinin nakliyatında asit içermeyen özel kağıt, köpük ve ahşap sandık kullanılmalıdır. Bu kategorideki eşyalar için nakliyat öncesi bağımsız ekspertiz yapılması ve özel değerli eşya sigortası düzenlenmesi şiddetle tavsiye edilir." }
        },
        {
            "@@type": "Question",
            "name": "Elektronik cihazlar nakliyatta nasıl taşınmalı?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Elektronik cihazları mümkünse orijinal kutuları ve ambalajlarıyla taşıyın. Orijinal ambalaj yoksa anti-statik köpük ve darbe emici malzeme kullanın. Dizüstü bilgisayar, tablet ve kameralar sert taşıma çantasında ve sizinle birlikte taşınmalıdır." }
        },
        {
            "@@type": "Question",
            "name": "Değerli eşyalar için nakliyat sigortası yeterli mi?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Standart nakliyat sigortası genel eşyalar için uygundur ancak antika, sanat eseri veya mücevher gibi yüksek değerli kalemler için ek veya özel değer sigortası düzenlenmelidir. Taşıma öncesi bu eşyaların ekspertiz değerinin belgelenmesi gerekir." }
        }
    ]
}
</script>
