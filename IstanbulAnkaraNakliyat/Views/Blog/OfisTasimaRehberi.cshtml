@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "BreadcrumbList",
    "itemListElement": [
        { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
        { "@@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.istanbulankaranakliyat.tr/blog" },
        { "@@type": "ListItem", "position": 3, "name": "Ofis Taşıma Rehberi", "item": "https://www.istanbulankaranakliyat.tr/blog/ofis-tasima-rehberi" }
    ]
}
</script>
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "FAQPage",
    "mainEntity": [
        {
            "@@type": "Question",
            "name": "Ofis taşıması ne kadar sürer?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Küçük ofisler (10-15 kişilik) için 1-2 gün, orta ölçekli ofisler için 3-5 gün, büyük kurumsal taşımalar için 1-2 hafta planlanmalıdır. Şehirlerarası ofis taşımalarında mesafe de bu süreye eklenir." }
        },
        {
            "@@type": "Question",
            "name": "Ofis taşıması için en uygun zaman hangisi?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Hafta sonu ve resmi tatil günleri iş sürekliliği açısından en ideal zamanlardır. Bu şekilde çalışanlar için iş günü kaybı en aza iner. İstanbul–Ankara gibi uzun mesafeli taşımalarda cuma akşamı yükleme, pazartesi sabahı açılış planlaması yaygın tercih edilir." }
        },
        {
            "@@type": "Question",
            "name": "IT altyapısı ofis taşımasında nasıl korunur?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Sunucular özel anti-statik ambalajla sarılmalı, kablo düzenleri etiketlenerek fotoğraflanmalı ve mümkünse IT ekibi tarafından sökülüp kurulmalıdır. Kritik veriler taşıma öncesi yedeklenmeli, bulut çözümlere geçiş değerlendirilmelidir." }
        },
        {
            "@@type": "Question",
            "name": "Ofis taşıması için ne kadar önceden planlama yapılmalı?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Küçük ofisler için 4-6 hafta, orta ölçekli ofisler için 2-3 ay, büyük kurumsal taşımalar için 3-6 ay önceden planlama başlatılmalıdır. Şehirlerarası taşımalarda yeni ofis kira/satın alma süreci de hesaba katılmalıdır." }
        }
    ]
}
</script>
}

