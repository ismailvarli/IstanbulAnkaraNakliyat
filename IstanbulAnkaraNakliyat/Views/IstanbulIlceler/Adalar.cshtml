@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Adalar Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/adalar-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Adalar Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Adalar, İstanbul",
            "description": "İstanbul Adaları'ndan (Büyükada, Heybeliada, Burgazada, Kınalıada) Ankara'ya feribot ve kara taşımacılığını kapsayan özel nakliyat hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/adalar-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Büyükada'dan Ankara'ya nakliyat nasıl yapılıyor?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Büyükada'dan Ankara'ya nakliyat iki aşamadan oluşur. İlk aşamada eşyalar adadan iskeleyeye taşınır (büyük parçalar için fayton veya el arabası kullanılır), ardından feribot veya özel tekneyle Kabataş ya da Bostancı iskelesine çıkarılır. İkinci aşamada karada nakliyat aracına yüklenerek Ankara'ya gidilir. Bu süreç önceden detaylı planlanmayı gerektirmektedir." }
                },
                {
                    "@@type": "Question",
                    "name": "Adalarda motorlu araç yasağı nakliyatı nasıl etkiliyor?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "İstanbul Adaları'nda motorlu kara araçları yasak olduğundan nakliyat araçları adaya girememektedir. Eşyalar fayton, el arabası ya da insan taşımasıyla iskeleyeye getirilir, feribot ile karaya çıkarılır ve ancak ondan sonra nakliyat kamyonuna yüklenir. Bu ekstra adımlar hem süreye hem de maliyete yansımaktadır; keşif aşamasında tüm bu aşamalar hesaba katılır." }
                },
                {
                    "@@type": "Question",
                    "name": "Adalar'dan Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Adalar'dan Ankara'ya nakliyat; standart taşımaya ek olarak feribot koordinasyonu, iskele taşıma ve aktarma maliyetleri de dahil edildiğinden fiyat keşif sonrası netleşmektedir. Genel fiyat aralığı olarak 1+1 için 10.000–16.000 ₺, 2+1 için 15.000–24.000 ₺ başlangıç olarak düşünülebilir. Kesin fiyat için ücretsiz keşif randevusu alınması gerekmektedir." }
                },
                {
                    "@@type": "Question",
                    "name": "Büyükada – Ankara taşıması kaç gün sürer?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Büyükada – Ankara taşıması, feribot geçişi ve kara taşımacılığının birleşimi nedeniyle genellikle 1,5–2 günlük bir planlama gerektirir. Eşyaların adadan çıkarılması, feribot geçişi, İstanbul'da araca yükleme ve Ankara'ya ulaşım en verimli şekilde düzenlendiğinde toplam süre 16–24 saat olabilmektedir. Eşyanın hacmi ve iskele yoğunluğu bu süreyi etkileyebilir." }
                },
                {
                    "@@type": "Question",
                    "name": "Adalardaki eski ahşap villaların eşyaları için özel ambalaj yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Adalardaki tarihi ahşap villaların antika mobilyaları, değerli tabloları ve kırılgan eşyaları için özel ambalaj hizmeti sunuyoruz. Balonlu naylon, koruyucu köpük, ahşap kasa ve özel streç film kullanılarak feribot yolculuğu ve kara taşımacılığı süresince eşyaların zarar görmesi önlenir." }
                }
            ]
        }
    ]
}
</script>
}

