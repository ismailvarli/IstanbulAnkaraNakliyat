                    @{
                        var nedenler = new[] {
                            new { I="⛵", T="Ada Deneyimi", A="İstanbul Adaları'ndan taşıma konusunda deneyimliyiz. Feribot koordinasyonu, fayton kiralama ve iskele yükleme süreçlerini biliyoruz." },
                            new { I="🛡️", T="Nakliyat Sigortası", A="Eşyalarınız feribot geçişi dahil tüm süreç boyunca sigortalıdır. Antika ve değerli eşyalar için ek sigorta sunulmaktadır." },
                            new { I="🔍", T="Ücretsiz Ada Keşfi", A="Eksperimiz adanıza bizzat gelir. Feribot saatleri, iskele koşulları ve bina durumu yerinde değerlendirilerek sabit fiyat teklifi hazırlanır." },
                            new { I="📦", T="Özel Ambalaj", A="Ahşap villa eşyaları ve antika mobilyalar için güçlendirilmiş, feribot yolculuğuna dayanıklı ambalaj çözümleri. Nem ve titreşime karşı özel koruma." },
                            new { I="💬", T="7/24 İletişim", A="Ada taşımalarının karmaşık koordinasyonu boyunca her an ulaşabilirsiniz. WhatsApp üzerinden anlık bilgi paylaşımı yapılır." },
                            new { I="💰", T="Şeffaf Fiyatlandırma", A="Feribot, fayton ve aktarma maliyetleri dahil tüm kalemler keşif sonrası yazılı olarak bildirilir. Sürpriz fatura çıkmaz." }
                        };
                    }
                    @foreach (var n in nedenler)
