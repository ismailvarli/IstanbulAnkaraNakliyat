@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Tuzla Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/tuzla-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Tuzla Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Tuzla, İstanbul",
            "description": "Tuzla ilçesinden Ankara'ya kapıdan kapıya, sigortalı evden eve, kurumsal ve ofis taşıma hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/tuzla-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Tuzla OSB bölgesinden kurumsal taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Tuzla Organize Sanayi Bölgesi'ndeki fabrika, depo ve ofislerden Ankara'ya kurumsal taşıma hizmeti sunuyoruz. Geniş araç parkı imkânı olan OSB adreslerinde büyük tonajlı araçlarla hızlı yükleme yapılabilmektedir. Hafta sonu ve gece taşıma seçenekleri de mevcuttur." }
                },
                {
                    "@@type": "Question",
                    "name": "Tuzla'dan Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Tuzla'dan Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında başlamaktadır. Kesin fiyat ücretsiz keşif sonrası netleşir. Kurumsal taşımalar için özel teklif hazırlanmaktadır." }
                },
                {
                    "@@type": "Question",
                    "name": "Tuzla – Ankara kaç saatte ulaşılır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Tuzla, İstanbul'un güneydoğusunda konumlandığından TEM otoyoluna bağlantı Sabiha Gökçen çevreyolu üzerinden hızlı şekilde sağlanır. Yükleme ve boşaltmayla birlikte Tuzla – Ankara arası toplam 10–14 saat arasında tamamlanır. Kargo yoğunluğu göz önünde bulundurularak sabah erken saatlerde hareket tercih edilir." }
                },
                {
                    "@@type": "Question",
                    "name": "İçmeler'deki sahil sitelerinden taşıma konusunda deneyiminiz var mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. İçmeler sahil bandındaki site ve apartmanlardan Ankara'ya taşıma konusunda deneyimliyiz. Sahil sitelerinde güvenlik prosedürleri ve araç girişi önceden koordine edilmektedir. Denize bakan dairelerin uzun koridorlu yapılarında özel taşıyıcı ekipman kullanılır." }
                }
            ]
        }
    ]
}
</script>
}

