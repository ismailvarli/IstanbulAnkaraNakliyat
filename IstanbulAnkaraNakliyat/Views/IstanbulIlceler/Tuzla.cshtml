<!-- ANA İÇERİK -->
<section style="padding:64px 0;">
    <div class="container">
        <div class="row">

            <!-- Sol: Ana İçerik -->
            <div class="col-lg-8">

                <h2 style="margin-bottom:1rem;">Tuzla'dan Ankara'ya Nakliyat</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    <strong>Tuzla</strong>, İstanbul'un güneydoğusunda, Sabiha Gökçen Havalimanı'na yakın konumuyla hem ulaşım hem de lojistik açısından stratejik bir ilçedir. Tersaneler, Organize Sanayi Bölgesi ve geniş lojistik depo alanlarıyla tanınan Tuzla, aynı zamanda İçmeler sahil bandı, Mimar Sinan mahalleleri, Postane ve Aydınlı gibi köklü yerleşim bölgelerine ev sahipliği yapar. Deniz, kara ve lojistik sektörü çalışanlarının yoğun olduğu bu ilçede konut çeşitliliği oldukça geniştir; eski tersane işçisi mahallelerinden modern sahil sitelerine uzanan bu yapı, <strong>Tuzla'dan Ankara'ya nakliyat</strong> hizmetini özel bir planlama gerektiren bir iş haline getirir. İstanbul Ankara Nakliyat olarak Tuzla'nın tüm mahallelerinde edindiğimiz saha deneyimiyle her adrese kapıdan kapıya hizmet sunuyoruz.
                </p>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Tuzla OSB'deki kurumsal taşımalarda en büyük avantajlardan biri geniş araç park alanlarının mevcudiyetidir. Büyük tonajlı TIR ve kamyonların rahatça manevra yapabildiği bu geniş alanlarda yükleme süreci çok daha hızlı ve düzenli gerçekleşmektedir. Tersane bölgesindeki eski konutlarda ise dar ve eski bina problemi oldukça sınırlıdır; çünkü bölgenin büyük bölümü modern lojistik tesisler ve yeni konut projelerine dönüşmüştür. Sabiha Gökçen bağlantı yolları TEM otoyoluna girişi önemli ölçüde hızlandırmakta, bu durum İstanbul içi güzergah süresini kısaltmaktadır. İçmeler sahil sitelerinden taşıma yaparken ise güvenlikli site prosedürleri ve araç giriş izinleri önceden koordine edilmektedir; bu aşamayı ekibimiz sizin adınıza yönetir.
                </p>
                <p style="margin-bottom:2rem;line-height:1.9;color:var(--gray-700);">
                    Tuzla'daki taşınmaların önemli bir bölümü kurumsal nitelik taşımaktadır. Tersane ve fabrika çalışanlarının iş değişikliği nedeniyle Ankara'ya nakli, şirket ofis ve depo taşımaları ile imalat sektörü işverenlerinin sıkça talep ettiği toplu personel nakli bu kategorinin başlıca örneklerini oluşturmaktadır. Bireysel taşımalarda ise emeklilik sonrası yerleşim değişikliği, yükseköğrenim amacıyla çocukların Ankara'ya gönderilmesi ya da sanayi bölgesinin ağır iş temposundan uzaklaşarak daha sakin bir yaşam arayanların Ankara tercihinde bulunması öne çıkmaktadır. İstanbul Ankara Nakliyat olarak hem kurumsal hem bireysel müşterilere ücretsiz keşif, sabit fiyat teklifi ve nakliyat sigortasını kapsayan eksiksiz bir hizmet paketi sunmaktayız.
                </p>


                <figure style="margin:1.75rem 0 2rem;">
                    <img src="~/img/galeri/galeri36.jpeg" loading="lazy"
                         style="width:100%;border-radius:var(--radius-lg);object-fit:cover;max-height:380px;"
                         onerror="this.style.display='none'">
                </figure>
                <!-- HİZMET KAPSAMI -->
                <h2 style="margin-bottom:1.25rem;">Tuzla'da Sunduğumuz Nakliyat Hizmetleri</h2>
                <div class="row" style="row-gap:1.25rem;margin-bottom:2.5rem;">
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏠</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Evden Eve Nakliyat</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Tuzla'daki evinizden Ankara'nın istediğiniz semtine tam kapıdan kapıya taşıma. İçmeler, Mimar Sinan, Aydınlı veya Postane fark etmez — her adrese geliyoruz.
                            </p>
                            <a href="/evden-eve-nakliyat" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏭</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Kurumsal ve Ofis Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Tuzla OSB ve tersane bölgesindeki fabrika, depo ve ofisleri minimum iş kaybıyla Ankara'ya taşıyoruz. Büyük tonajlı araç ve uzman ekip desteği.
                            </p>
                            <a href="/ofis-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">📦</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Parça Eşya Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Tuzla'dan Ankara'ya tek koltuk, kargo kutusu veya birkaç parça eşya gönderimi. Parsiyel yükle ekonomik ve hızlı çözüm.
                            </p>
                            <a href="/parca-esya-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🎁</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Ambalaj &amp; Paketleme</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Balonlu naylon, streç film, karton kutu ve köpük koruyucularla profesyonel ambalaj. Kurumsal taşımalar için özel endüstriyel paketleme çözümleri.
                            </p>
                            <a href="/ambalaj-hizmeti" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                </div>

                <!-- İLÇEYE ÖZGÜ -->
                <h2 style="margin-bottom:1rem;">Tuzla Nakliyatında Bilmeniz Gerekenler</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Tuzla'dan Ankara'ya gerçekleştirilen taşımalarda güzergah seçimi kritik bir avantaj sağlar. Sabiha Gökçen Havalimanı bağlantı yolu üzerinden TEM otoyoluna katılmak, ilçenin İstanbul içi konumunu göz önünde bulundurduğumuzda oldukça verimli bir başlangıç noktası oluşturur. Tuzla'dan yola çıkan araçlarımız İstanbul'un yoğun iç trafiğine girmeden ana güzergaha ulaşabilmektedir. Sabahın erken saatlerinde başlayan taşımalar, Ankara'ya gündüz saatlerinde vararak boşaltma işleminin gün ışığında tamamlanmasını mümkün kılmaktadır.
                </p>
                <p style="margin-bottom:2.5rem;line-height:1.9;color:var(--gray-700);">
                    OSB bölgesindeki kurumsal taşımalarda üretim akışını kesintiye uğratmamak için taşıma planı müşterimizle birlikte hazırlanmaktadır. Hangi eşyaların önce yükleneceği, hangi departmanın öncelikli taşınacağı ve Ankara'daki yeni adresin fiziksel koşulları önceden değerlendirilerek en verimli yükleme düzeni oluşturulmaktadır. Bireysel ev taşımalarında ise Tuzla'daki eski konut stoğunun asansör kapasiteleri ve bina girişleri keşif aşamasında incelenmekte; herhangi bir dar merdiven ya da düşük tavan yüksekliği durumunda eşyaların güvenli taşınması için gerekli ekip ve ekipman planlaması önceden yapılmaktadır.
                </p>

                <!-- SÜREÇ -->
                <h2 style="margin-bottom:1.5rem;">Tuzla Nakliyat Sürecimiz</h2>
                <div style="margin-bottom:2.5rem;">
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">1</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Ücretsiz Keşif</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Uzman eksperimiz Tuzla adresinize gelir. Bina tipi, kat durumu, asansör kapasitesi ve eşya miktarını yerinde değerlendirir. Kurumsal taşımalarda depo ve ofis alanları da incelenir.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">2</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sabit Fiyat Teklifi</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Tüm kalemleri kapsayan yazılı teklif verilir. Verilen fiyat değişmez; kurumsal taşımalarda özel fiyat anlaşması yapılır.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">3</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Profesyonel Ambalajlama</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Taşıma günü ekibimiz Tuzla adresinize erken gelir. Mobilyalar battaniye ve streç filmle, kırılganlar balonlu naylonla paketlenir. Kurumsal malzeme ve ekipman için endüstriyel ambalaj malzemeleri kullanılır.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">4</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sigortalı Nakliye</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Eşyalarınız kapalı kasalı, sigortalı araçlara yüklenerek Ankara'ya hareket edilir. ~450 km mesafe ortalama 8–12 saatte tamamlanır.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">5</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Yerleştirme ve Montaj</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Ankara'daki yeni adresinizde eşyalar boşaltılır, sökülmüş mobilyalar monte edilir. Kurumsal taşımalarda ofis düzenlemesi müşteri planına göre gerçekleştirilir.</p></div>
                    </div>
                </div>

                <!-- FİYAT -->
                <h2 style="margin-bottom:1rem;">Tuzla – Ankara Nakliyat Fiyatları 2026</h2>
                <p style="color:var(--gray-600);margin-bottom:1.25rem;font-size:.95rem;">
                    Aşağıdaki fiyatlar referans niteliğindedir. Kesin fiyat keşif sonrası belirlenir.
                </p>
                <div class="price-table" style="margin-bottom:2.5rem;">
                    <div class="price-row price-row--header"><span>Daire / Hacim</span><span>Yaklaşık m³</span><span>Fiyat Aralığı</span></div>
                    <div class="price-row"><span>1+1 Daire</span><span>15–25 m³</span><span>8.000 – 14.000 ₺</span></div>
                    <div class="price-row"><span>2+1 Daire</span><span>25–40 m³</span><span>12.000 – 20.000 ₺</span></div>
                    <div class="price-row"><span>3+1 Daire</span><span>40–60 m³</span><span>16.000 – 26.000 ₺</span></div>
                    <div class="price-row"><span>4+1 / Villa</span><span>60–100+ m³</span><span>Keşif Sonrası</span></div>
                    <div class="price-row"><span>Ofis / İşyeri</span><span>Değişken</span><span>Keşif Sonrası</span></div>
                </div>

                <!-- MAHALLELER -->
                <div style="background:var(--gray-100);border-radius:var(--radius-lg);padding:1.75rem;margin-bottom:2.5rem;">
                    <h3 style="margin-bottom:.75rem;">Tuzla Mahalleleri — Hizmet Bölgelerimiz</h3>
                    <p style="margin-bottom:1rem;font-size:.95rem;color:var(--gray-700);">
                        Tuzla'nın tüm mahallelerinde ücretsiz keşif yapıyor ve Ankara'ya nakliyat hizmeti sunuyoruz:
                    </p>
                    <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1rem;">
                        @foreach (var m in new[]{"İçmeler","Mimar Sinan","Aydınlı","Postane","Tepeören","Orhanlı","Evliya Çelebi","Balıklı","Cüriye","Şifa"})
                        {
                            <span style="background:var(--white);border:1px solid var(--gray-200);border-radius:50px;padding:.3rem .9rem;font-size:.82rem;font-weight:500;">@m</span>
                        }
                    </div>
                    <p style="font-size:.85rem;color:var(--gray-500);margin:0;">Mahalleniz listede olmasa da Tuzla sınırları içindeki tüm adreslere hizmet veriyoruz.</p>
                </div>

                <!-- NEDEN BİZ -->
                <h2 style="margin-bottom:1.25rem;">Neden İstanbul Ankara Nakliyat?</h2>
                <div class="row" style="row-gap:1rem;margin-bottom:2.5rem;">
                    @{
                        var nedenler = new[] {
                            new { I="🛡️", T="Nakliyat Sigortası", A="Tüm eşyalarınız taşıma süresince sigorta kapsamındadır. Kurumsal taşımalarda ticari ekipman ve makineler için ek sigorta seçeneği sunulmaktadır." },
