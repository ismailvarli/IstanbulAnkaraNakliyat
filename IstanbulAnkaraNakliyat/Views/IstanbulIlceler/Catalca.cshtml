@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Çatalca Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/catalca-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Çatalca Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Çatalca, İstanbul",
            "description": "Çatalca ilçesinden Ankara'ya kapıdan kapıya, sigortalı evden eve ve ofis taşıma hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/catalca-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Çatalca'dan Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Çatalca'dan Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında başlamaktadır. Villa ve çiftlik evi taşımalarında kesin fiyat ücretsiz keşif sonrası belirlenir." }
                },
                {
                    "@@type": "Question",
                    "name": "Çatalca köy ve belde merkezlerinden de taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Çatalca'nın Kapaklı, Yalıköy, Ferhatpaşa, Dağyenice, Ormanlı gibi köy ve belde merkezlerinden de taşıma yapıyoruz. Dar kırsal yollar için uygun boyutlarda araç tahsis ediyoruz." }
                },
                {
                    "@@type": "Question",
                    "name": "Çatalca'daki çiftlik evi ve villalar için özel taşıma hizmetiniz var mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Çatalca'nın tarımsal ve kırsal yapısına uygun büyük hacimli taşıma hizmeti sunuyoruz. Villa, çiftlik evi ve tarımsal ekipman taşımalarında önceden yerinde keşif yaparak en uygun araç ve ekip planlamasını hazırlıyoruz." }
                },
                {
                    "@@type": "Question",
                    "name": "Çatalca'dan Ankara'ya taşıma kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Çatalca – Ankara mesafesi yaklaşık 450 km'dir. Yükleme ve boşaltmayla birlikte toplam süre genellikle 8–12 saat arasında tamamlanır. Çatalca'nın E-5'e paralel güzergahı sayesinde İstanbul çıkışı görece hızlıdır." }
                }
            ]
        }
    ]
}
</script>
}

