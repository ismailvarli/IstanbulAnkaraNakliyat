<!-- ANA İÇERİK -->
<section style="padding:64px 0;">
    <div class="container">
        <div class="row">

            <!-- Sol: Ana İçerik -->
            <div class="col-lg-8">

                <h2 style="margin-bottom:1rem;">Avcılar'dan Ankara'ya Nakliyat</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    <strong>Avcılar</strong>, İstanbul'un Avrupa yakasında Marmara kıyısına uzanan, İstanbul Üniversitesi kampüsünün varlığıyla öğrenci nüfusunun yoğun olduğu ve Ambarlı sanayi ile liman bölgesinin sınırında konumlanan özgün bir ilçedir. Firuzköy, Cihangir ve Üniversite mahalleleri yüksek öğrenci yoğunluğuyla tanınırken Ambarlı ve Denizköşkler bölgesi lojistik ve sanayi karakterini korumaktadır. Uygun kira fiyatları, üniversite yakınlığı ve E-5 üzerindeki konumu Avcılar'ı geniş bir kitle için tercih sebebi kılmaktadır. <strong>Avcılar'dan Ankara'ya nakliyat</strong> talebi bu çeşitli demografi sayesinde hem öğrenci taşımalarını hem de tam ev ve kurumsal taşımaları kapsamaktadır.
                </p>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Avcılar'daki öğrenci taşımalarında en çok tercih edilen seçenek parsiyel (parça eşya) yüktür. Bir öğrencinin Ankara'daki üniversiteye ya da mezuniyet sonrası döndüğü kentine taşıyacağı eşya genellikle tam bir araca sığmayacak kadar azdır; bu durumlarda paylaşımlı yük hizmetimiz devreye girer ve hem maliyet hem de çevre açısından en verimli çözümü sunar. Öte yandan Ambarlı liman ve sanayi bölgesinde büyük nakliye araçlarının girişi oldukça kolaydır; kurumsal taşımalarda bu avantajdan yararlanıyoruz. E-5 üzerindeki konumu sayesinde Avcılar, İstanbul içi trafiğe çok az maruz kalarak Ankara güzergahına hızla bağlanır.
                </p>
                <p style="margin-bottom:2rem;line-height:1.9;color:var(--gray-700);">
                    <strong>Avcılar Ankara nakliyat</strong> sürecinde en sık karşılaştığımız müşteri profilleri şunlardır: İstanbul Üniversitesi'nden mezun olup Ankara'daki iş veya lisansüstü programına başlayacak gençler; Ankara'daki üniversiteyi kazanan öğrencilerin Avcılar'daki aile evinden eşya taşımaları; ve kira farkı hesabı yaparak İstanbul'dan Ankara'ya taşınan aileler. Her profil için ayrı çözüm sunuyoruz: öğrencilere parsiyel yük, ailelere tam evden eve, kurumsal müşterilere özel kurumsal paket. Ücretsiz keşif ve sabit fiyat garantisiyle taşınma sürecinizi stressiz hale getiriyoruz.
                </p>


                <figure style="margin:1.75rem 0 2rem;">
                    <img src="~/img/galeri/galeri4.webp" loading="lazy"
                         style="width:100%;border-radius:var(--radius-lg);object-fit:cover;max-height:380px;"
                         onerror="this.style.display='none'">
                </figure>
                <!-- HİZMET KAPSAMI -->
                <h2 style="margin-bottom:1.25rem;">Avcılar'da Sunduğumuz Nakliyat Hizmetleri</h2>
                <div class="row" style="row-gap:1.25rem;margin-bottom:2.5rem;">
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏠</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Evden Eve Nakliyat</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Avcılar'daki evinizden Ankara'nın istediğiniz semtine kapıdan kapıya taşıma. Firuzköy, Cihangir, Üniversite, Ambarlı fark etmez.
                            </p>
                            <a href="/evden-eve-nakliyat" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🎓</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Öğrenci Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                İstanbul Üniversitesi öğrencileri için Ankara'ya ekonomik parsiyel taşıma. Az eşyayla dolu araç tutmak zorunda değilsiniz.
                            </p>
                            <a href="/parca-esya-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">📦</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Parça Eşya Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Avcılar'dan Ankara'ya tek koltuk, kargo kutusu veya birkaç parça eşya gönderimi. Paylaşımlı yükle ekonomik çözüm.
                            </p>
                            <a href="/parca-esya-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏢</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Kurumsal &amp; Sanayi Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Ambarlı sanayi ve liman bölgesindeki iş yerleri için büyük araç, hafta sonu ve gece çalışma seçeneğiyle Ankara'ya kurumsal taşıma.
                            </p>
                            <a href="/ofis-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                </div>

                <!-- İLÇEYE ÖZGÜ -->
                <h2 style="margin-bottom:1rem;">Avcılar Nakliyatında Bilmeniz Gerekenler</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Avcılar'da taşıma sürecinin en çok dikkat gerektiren konusu mahalle bazındaki erişim farklılıklarıdır. Üniversite ve Cihangir mahallelerinde öğrenci yoğunluğu yüksek olduğundan dar sokaklar ve çift taraflı park nedeniyle sabahın erken saatlerinde harekete geçmek avantajlıdır. Firuzköy'de büyük araç girişi nispeten daha kolaydır. Ambarlı sanayi bölgesinde ise zaten geniş yollar ve sanayi altyapısı araç konuşlanmasını kolaylaştırır. Denizköşkler ve Gümüşpala mahallelerindeki konut alanlarında park durumunu önceden bildirmenizi öneririz.
                </p>
                <p style="margin-bottom:2.5rem;line-height:1.9;color:var(--gray-700);">
                    Avcılar'dan Ankara'ya taşınma gerekçeleri çok çeşitlidir. Öğrenci hareketliliği eylül-ekim ve haziran-temmuz aylarında zirveye çıkarken aile taşımaları yıl boyunca sürer. İstanbul'un koşuşturmacalı temposundan çıkıp Ankara'nın daha sakin ve uygun fiyatlı konut stokuna yönelen aileler her yıl Avcılar'dan Ankara'ya taşınmaktadır. İstanbul Ankara Nakliyat olarak tüm bu profillere uygun esnek çözümler sunuyor; ücretsiz keşif ve şeffaf fiyatlandırmayla güvence sağlıyoruz.
                </p>

                <!-- SÜREÇ -->
                <h2 style="margin-bottom:1.5rem;">Avcılar Nakliyat Sürecimiz</h2>
                <div style="margin-bottom:2.5rem;">
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">1</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Ücretsiz Keşif</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Uzman eksperimiz Avcılar adresinize gelir. Eşya miktarı, bina durumu ve taşıma koşullarını yerinde değerlendirir. Öğrenci taşımalarında telefonla fiyat da alabilirsiniz.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">2</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sabit Fiyat Teklifi</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Tüm kalemleri kapsayan yazılı teklif verilir. Parsiyel taşımalarda da fiyat nettir; sürpriz fatura çıkmaz.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">3</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Profesyonel Ambalajlama</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Mobilyalar battaniye ve streç filmle, kırılganlar balonlu naylonla paketlenir. Öğrenci eşyaları için standart karton kutu seti de temin edilir.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">4</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sigortalı Nakliye</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Eşyalarınız kapalı kasalı, sigortalı araçlara yüklenerek E-5 üzerinden Ankara'ya hareket edilir. ~450 km mesafe ortalama 8–12 saatte tamamlanır.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">5</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Yerleştirme ve Montaj</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Ankara'daki yeni adresinizde eşyalar boşaltılır, mobilyalar monte edilir. Öğrenci taşımalarında da yerleştirme yardımı sunulur.</p></div>
                    </div>
                </div>

                <!-- FİYAT -->
                <h2 style="margin-bottom:1rem;">Avcılar – Ankara Nakliyat Fiyatları 2026</h2>
                <p style="color:var(--gray-600);margin-bottom:1.25rem;font-size:.95rem;">
                    Aşağıdaki fiyatlar referans niteliğindedir. Kesin fiyat keşif sonrası belirlenir.
                </p>
                <div class="price-table" style="margin-bottom:2.5rem;">
                    <div class="price-row price-row--header"><span>Daire / Hacim</span><span>Yaklaşık m³</span><span>Fiyat Aralığı</span></div>
                    <div class="price-row"><span>1+1 Daire</span><span>15–25 m³</span><span>8.000 – 14.000 ₺</span></div>
                    <div class="price-row"><span>2+1 Daire</span><span>25–40 m³</span><span>12.000 – 20.000 ₺</span></div>
                    <div class="price-row"><span>3+1 Daire</span><span>40–60 m³</span><span>16.000 – 26.000 ₺</span></div>
                    <div class="price-row"><span>4+1 / Villa</span><span>60–100+ m³</span><span>Keşif Sonrası</span></div>
                    <div class="price-row"><span>Öğrenci / Parsiyel</span><span>1–10 m³</span><span>Telefonda Bilgi Alın</span></div>
                </div>

                <!-- MAHALLELER -->
                <div style="background:var(--gray-100);border-radius:var(--radius-lg);padding:1.75rem;margin-bottom:2.5rem;">
                    <h3 style="margin-bottom:.75rem;">Avcılar Mahalleleri — Hizmet Bölgelerimiz</h3>
                    <p style="margin-bottom:1rem;font-size:.95rem;color:var(--gray-700);">
                        Avcılar'ın tüm mahallelerinde ücretsiz keşif yapıyor ve Ankara'ya nakliyat hizmeti sunuyoruz:
                    </p>
                    <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1rem;">
                        @foreach (var m in new[]{"Ambarlı","Cihangir","Firuzköy","Tahtakale","Üniversite","Denizköşkler","Gümüşpala","Mustafa Kemal","Yeşilkent","Bahçeşehir"})
                        {
                            <span style="background:var(--white);border:1px solid var(--gray-200);border-radius:50px;padding:.3rem .9rem;font-size:.82rem;font-weight:500;">@m</span>
                        }
                    </div>
                    <p style="font-size:.85rem;color:var(--gray-500);margin:0;">Mahalleniz listede olmasa da Avcılar sınırları içindeki tüm adreslere hizmet veriyoruz.</p>
                </div>

                <!-- NEDEN BİZ -->
                <h2 style="margin-bottom:1.25rem;">Neden İstanbul Ankara Nakliyat?</h2>
                <div class="row" style="row-gap:1rem;margin-bottom:2.5rem;">
                    @{
                        var nedenler = new[] {
                            new { I="🛡️", T="Nakliyat Sigortası", A="Tüm eşyalarınız taşıma süresince sigorta kapsamındadır. Öğrenci eşyaları dahil tüm taşımalar güvence altındadır." },
                            new { I="🔍", T="Ücretsiz Keşif", A="Eksperimiz Avcılar adresinize gelir, koşulları yerinde değerlendirir. Öğrenci taşımalarında telefonla hızlı fiyat da alabilirsiniz." },
                            new { I="🔧", T="Söküm-Montaj Dahil", A="Karyola, gardırop ve mobilyalar sökülür; Ankara'da monte edilir. Montaj ücretsizdir." },
                            new { I="🚛", T="Parsiyel Yük Seçeneği", A="Tam araca ihtiyaç duymayan öğrenciler ve küçük hacimli taşımalar için paylaşımlı yük çözümü sunuyoruz." },
                            new { I="💬", T="7/24 İletişim", A="Taşıma öncesi, sırası ve sonrasında her an ulaşabilirsiniz. WhatsApp üzerinden anlık bilgi alabilirsiniz." },
                            new { I="💰", T="Şeffaf Fiyatlandırma", A="Keşif sonrası verilen fiyat değişmez. Parsiyel taşımalarda da net fiyat verilir; sürpriz fatura çıkmaz." }
                        };
                    }
