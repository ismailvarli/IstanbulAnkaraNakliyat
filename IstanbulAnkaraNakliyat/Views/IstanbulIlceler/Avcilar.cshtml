@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Avcılar Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/avcilar-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Avcılar Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Avcılar, İstanbul",
            "description": "Avcılar ilçesinden Ankara'ya kapıdan kapıya, sigortalı evden eve, öğrenci ve parsiyel taşıma hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/avcilar-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Avcılar'dan Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Avcılar'dan Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında başlamaktadır. Öğrenci taşımalarında parça eşya seçeneğiyle daha ekonomik çözüm sunulmaktadır." }
                },
                {
                    "@@type": "Question",
                    "name": "Öğrenci eşyası taşıma için parsiyel seçenek var mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Avcılar'dan Ankara'ya öğrenci eşyası, kişisel eşya veya birkaç kutu gönderimi için parsiyel (parça eşya) hizmetimiz mevcuttur. Tam araç tutmaya gerek kalmadan paylaşımlı yükle çok daha ekonomik taşıma yapılır." }
                },
                {
                    "@@type": "Question",
                    "name": "Ambarlı sanayi bölgesinden kurumsal taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Ambarlı liman ve sanayi bölgesindeki fabrika, depo ve ofis taşımalarında deneyimliyiz. Büyük hacimli kurumsal taşımalarda hafta sonu ve gece çalışma seçeneği de sunuyoruz." }
                },
                {
                    "@@type": "Question",
                    "name": "Avcılar – Ankara güzergahı kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Avcılar, E-5 üzerinde konumuyla Ankara güzergahına hızla bağlanır. Yükleme ve boşaltmayla birlikte toplam süre genellikle 8–12 saat arasında tamamlanır. Sabah erken saatlerde hareket edilerek E-5 trafiği minimize edilir." }
                }
            ]
        }
    ]
}
</script>
}

