@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Bakırköy Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/bakirkoy-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Bakırköy Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Bakırköy, İstanbul",
            "description": "Bakırköy ilçesinden Ankara'ya kapıdan kapıya, sigortalı evden eve ve ofis taşıma hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/bakirkoy-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Ataköy sitelerinden taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Ataköy'ün büyük konut sitelerinden taşıma konusunda deneyimliyiz. Site yönetimiyle önceden iletişim kurarak araç giriş izni, servis asansörü rezervasyonu ve güvenlik protokollerini eksiksiz yönetiyoruz. Ataköy'ün yüksek katlı rezidanslarında servis asansörü kapasitesine göre yükleme planı oluşturulur." }
                },
                {
                    "@@type": "Question",
                    "name": "Bakırköy'den Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Bakırköy'den Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında başlamaktadır. Kesin fiyat bina tipi, kat durumu, eşya miktarı ve ek hizmetlere göre ücretsiz keşif sonrası belirlenir." }
                },
                {
                    "@@type": "Question",
                    "name": "Florya'daki sahil yazlıklarından eşya taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Florya'daki yazlık ve müstakil konutlardan Ankara'ya taşıma yapıyoruz. Florya sahil yolu genel olarak araç erişimine uygun olup büyük kamyon manevrası için erken saatte başlama tercih edilir. Bahçeli ev ve villalardaki büyük mobilyalar için özel ekipman kullanılır." }
                },
                {
                    "@@type": "Question",
                    "name": "Bakırköy – Ankara güzergahı E-5 mi TEM mi?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Bakırköy, E-5 (D-100) otoyolunun üzerinde yer alır; bu nedenle İstanbul'dan çıkış E-5 üzerinden yapılır. Güzergah tercihine ve günlük trafik koşullarına bağlı olarak Avcılar'dan TEM'e geçiş de değerlendirilebilir. Her iki güzergah da yaklaşık 450 km olup 8–12 saat içinde tamamlanır." }
                }
            ]
        }
    ]
}
</script>
}

