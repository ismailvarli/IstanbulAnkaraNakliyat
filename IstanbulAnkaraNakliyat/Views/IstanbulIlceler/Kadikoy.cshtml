<!-- ANA İÇERİK -->
<section style="padding:64px 0;">
    <div class="container">
        <div class="row">

            <!-- Sol: Ana İçerik -->
            <div class="col-lg-8">

                <h2 style="margin-bottom:1rem;">Kadıköy'den Ankara'ya Nakliyat</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    <strong>Kadıköy</strong>, İstanbul Anadolu yakasının tartışmasız kültür, gastronomi ve ticaret merkezidir. Moda'nın tarihi çarşısından Bağdat Caddesi'nin gözde butiklerine, Fenerbahçe'nin lüks sitelerinden Fikirtepe'nin hızla yükselen yeni yapılarına uzanan bu ilçe, İstanbul'un en çeşitli konut dokusuna ev sahipliği yapar. Tam da bu çeşitlilik, <strong>Kadıköy'den Ankara'ya nakliyat</strong> sürecini özel bir uzmanlık gerektiren bir iş haline getirir. İstanbul Ankara Nakliyat olarak Kadıköy'ün her mahallesinde yıllarca edindğimiz saha deneyimiyle, bölgeye özgü lojistik zorlukların üstesinden güvenle geliyoruz.
                </p>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Kadıköy'de taşınma sürecinin en büyük zorluğu bina yapısının çok katmanlı olmasıdır. Moda'nın dar sokaklarında 1950–70'lerden kalma, asansörsüz ve merdiven boşluğu dar olan apartmanlar ile Fikirtepe ve Koşuyolu'ndaki 20–30 katlı rezidanslar aynı ilçede yer alır. Eski binalarda, özellikle Moda ve Caferağa mahallelerinde, büyük mobilyaları taşımak için yeterli personel ve uygun ekipman kullanmak zorunludur. Asansörsüz binalarda karyola, kanepe veya gardırop gibi büyük parçaları pencere veya balkon yoluyla indirmek gerekebilir; ekibimiz bu tür özel operasyonlarda deneyimlidir. Fikirtepe'deki yüksek katlı yeni yapılarda ise servis asansörü koordinasyonu ve site güvenlik prosedürleri önceden planlanarak yönetilir.
                </p>
                <p style="margin-bottom:2rem;line-height:1.9;color:var(--gray-700);">
                    Kadıköy'den Ankara'ya uzanan yaklaşık 450 km'lik güzergah, İstanbul'un yoğun iç trafik ağına takılmadan tamamlanabilmesi için güzergah planlaması kritiktir. Köprü trafiğini aşmak amacıyla taşıma günü erken saatlerde hareket ediliyor; bu sayede hem köprü gişelerinde zaman kaybı önleniyor hem de Ankara'ya gündüz saatlerinde varılarak boşaltma işlemi gün ışığında tamamlanıyor. <strong>Kadıköy Ankara nakliyat</strong> sürecinde tüm eşyalarınız nakliyat sigortası güvencesi altında taşınır; kırılgan eşyalar için balonlu naylon, porselen ve camlar için özel köpük paketleme, mobilyalar için battaniye ve streç film kullanılır. Ücretsiz keşif randevusu için hemen arayabilirsiniz.
                </p>


                <figure style="margin:1.75rem 0 2rem;">
                    <img src="~/img/galeri/galeri23.webp" loading="lazy"
                         style="width:100%;border-radius:var(--radius-lg);object-fit:cover;max-height:380px;"
                         onerror="this.style.display='none'">
                </figure>
                <!-- HİZMET KAPSAMI -->
                <h2 style="margin-bottom:1.25rem;">Kadıköy'de Sunduğumuz Nakliyat Hizmetleri</h2>
                <div class="row" style="row-gap:1.25rem;margin-bottom:2.5rem;">
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏠</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Evden Eve Nakliyat</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Kadıköy'deki evinizden Ankara'nın istediğiniz semtine tam kapıdan kapıya taşıma. Moda, Caferağa, Fenerbahçe, Fikirtepe fark etmez — her adrese geliyoruz.
                            </p>
                            <a href="/evden-eve-nakliyat" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏢</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Ofis Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Kadıköy'deki iş yerinizi minimum iş kaybıyla Ankara'ya taşıyoruz. Hafta sonu veya gece taşıma seçeneğiyle operasyonel kesinti sıfıra iner.
                            </p>
                            <a href="/ofis-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">📦</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Parça Eşya Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Kadıköy'den Ankara'ya tek koltuk, kargo kutusu veya birkaç parça eşya gönderimi. Parsiyel yükle ekonomik ve hızlı çözüm.
                            </p>
                            <a href="/parca-esya-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🎁</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Ambalaj &amp; Paketleme</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Balonlu naylon, streç film, karton kutu ve köpük koruyucularla profesyonel ambalaj. Kadıköy'ün eski binalarından indirilecek kırılgan eşyalar için özel paketleme.
                            </p>
                            <a href="/ambalaj-hizmeti" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                </div>

                <!-- İLÇEYE ÖZGÜ -->
                <h2 style="margin-bottom:1rem;">Kadıköy Nakliyatında Bilmeniz Gerekenler</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Kadıköy'de araç park etme ve yükleme noktası belirlemek, başarılı bir taşıma için kritik önem taşır. Moda ve Caferağa gibi yoğun merkezî mahallelerde araç park izni belediyeden önceden alınması gerekebilir; ekibimiz bu süreci sizin adınıza yönetir. Bağdat Caddesi boyunca uzanan çift taraflı park yasağı bölgelerinde taşıma araçlarının sabahın erken saatlerinde konuşlanması koordineli bir planlama gerektirir. Fenerbahçe ve Göztepe mahallelerindeki güvenlikli sitelerde ise güvenlik birimiyle önceden iletişim kurarak araç ve personel girişi ayarlanır — bu adımı biz üstleniriz.
                </p>
                <p style="margin-bottom:2.5rem;line-height:1.9;color:var(--gray-700);">
                    Kadıköy'den Ankara'ya taşınma kararının arkasında çoğunlukla iş değişikliği, emeklilik planlaması veya yaşam maliyetini düşürme isteği yatar. Ankara, İstanbul'a kıyasla daha uygun kira fiyatları ve geniş konut seçenekleri sunar; bu nedenle özellikle aileler ve çalışma hayatını merkezi bir şehirde sürdürmek isteyenler Kadıköy'den Ankara'ya taşınmayı tercih eder. İstanbul Ankara Nakliyat olarak bu taşınmanın stressiz ve sorunsuz geçmesi için ücretsiz keşif, sabit fiyat teklifi ve taşıma sonrası yerleştirme hizmetlerini bir arada sunuyoruz.
                </p>

                <!-- SÜREÇ -->
                <h2 style="margin-bottom:1.5rem;">Kadıköy Nakliyat Sürecimiz</h2>
                <div style="margin-bottom:2.5rem;">
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">1</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Ücretsiz Keşif</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Uzman eksperimiz Kadıköy adresinize gelir. Bina tipi, kat durumu, asansör kapasitesi ve eşya miktarını yerinde değerlendirir. Keşif tamamen ücretsizdir.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">2</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sabit Fiyat Teklifi</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Tüm kalemleri (ambalaj, söküm, montaj, sigorta) kapsayan yazılı teklif verilir. Verilen fiyat değişmez; sürpriz fatura çıkmaz.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">3</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Profesyonel Ambalajlama</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Taşıma günü ekibimiz Kadıköy'e erken saatte gelir. Mobilyalar battaniye ve streç filmle, kırılganlar balonlu naylonla özenle paketlenir.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">4</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sigortalı Nakliye</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Eşyalarınız kapalı kasalı, sigortalı araçlara yüklenerek Ankara'ya hareket edilir. ~450 km mesafe ortalama 8–12 saatte tamamlanır.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">5</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Yerleştirme ve Montaj</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Ankara'daki yeni adresinizde eşyalar boşaltılır, sökülmüş mobilyalar monte edilir. İşlem tamamlanana kadar yanınızdayız.</p></div>
                    </div>
                </div>

                <!-- FİYAT -->
                <h2 style="margin-bottom:1rem;">Kadıköy – Ankara Nakliyat Fiyatları 2026</h2>
                <p style="color:var(--gray-600);margin-bottom:1.25rem;font-size:.95rem;">
                    Aşağıdaki fiyatlar referans niteliğindedir. Kesin fiyat keşif sonrası belirlenir.
                </p>
                <div class="price-table" style="margin-bottom:2.5rem;">
                    <div class="price-row price-row--header"><span>Daire / Hacim</span><span>Yaklaşık m³</span><span>Fiyat Aralığı</span></div>
                    <div class="price-row"><span>1+1 Daire</span><span>15–25 m³</span><span>8.000 – 14.000 ₺</span></div>
                    <div class="price-row"><span>2+1 Daire</span><span>25–40 m³</span><span>12.000 – 20.000 ₺</span></div>
                    <div class="price-row"><span>3+1 Daire</span><span>40–60 m³</span><span>16.000 – 26.000 ₺</span></div>
                    <div class="price-row"><span>4+1 / Villa</span><span>60–100+ m³</span><span>Keşif Sonrası</span></div>
                    <div class="price-row"><span>Ofis / İşyeri</span><span>Değişken</span><span>Keşif Sonrası</span></div>
                </div>

                <!-- MAHALLELER -->
                <div style="background:var(--gray-100);border-radius:var(--radius-lg);padding:1.75rem;margin-bottom:2.5rem;">
                    <h3 style="margin-bottom:.75rem;">Kadıköy Mahalleleri — Hizmet Bölgelerimiz</h3>
                    <p style="margin-bottom:1rem;font-size:.95rem;color:var(--gray-700);">
                        Kadıköy'ün tüm mahallelerinde ücretsiz keşif yapıyor ve Ankara'ya nakliyat hizmeti sunuyoruz:
                    </p>
                    <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1rem;">
                        @foreach (var m in new[]{"Moda","Bostancı","Fenerbahçe","Fikirtepe","Caferağa","Koşuyolu","Göztepe","Erenköy","Caddebostan","Suadiye","Acıbadem","Sahrayıcedit"})
                        {
                            <span style="background:var(--white);border:1px solid var(--gray-200);border-radius:50px;padding:.3rem .9rem;font-size:.82rem;font-weight:500;">@m</span>
                        }
                    </div>
                    <p style="font-size:.85rem;color:var(--gray-500);margin:0;">Mahalleniz listede olmasa da Kadıköy sınırları içindeki tüm adreslere hizmet veriyoruz.</p>
                </div>

                <!-- NEDEN BİZ -->
                <h2 style="margin-bottom:1.25rem;">Neden İstanbul Ankara Nakliyat?</h2>
                <div class="row" style="row-gap:1rem;margin-bottom:2.5rem;">
                    @{
                        var nedenler = new[] {
                            new { I="🛡️", T="Nakliyat Sigortası", A="Tüm eşyalarınız taşıma süresince sigorta kapsamındadır. Kadıköy'ün eski binalarından taşınan antika ve değerli eşyalar için ek sigorta da sunulmaktadır." },
                            new { I="🔍", T="Ücretsiz Keşif", A="Eksperimiz Kadıköy adresinize gelir, eşyaları yerinde değerlendirir ve sabit fiyat teklifi sunar. Asansörsüz binalarda özel planlama yapılır." },
