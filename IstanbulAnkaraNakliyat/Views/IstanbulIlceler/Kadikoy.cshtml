@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Kadıköy Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/kadikoy-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Kadıköy Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Kadıköy, İstanbul",
            "description": "Kadıköy ilçesinden Ankara'ya kapıdan kapıya, sigortalı evden eve ve ofis taşıma hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/kadikoy-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Kadıköy'den Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Kadıköy'den Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 18.000–28.000 ₺ arasında başlamaktadır. Kesin fiyat kat sayısı, asansör durumu ve eşya miktarına göre ücretsiz keşif sonrası netleşir." }
                },
                {
                    "@@type": "Question",
                    "name": "Kadıköy Bağdat Caddesi'ndeki asansörsüz binalara geliyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Bağdat Caddesi boyunca bulunan eski ve asansörsüz binalarda taşıma konusunda deneyimliyiz. Dar merdivenlerde özel ekipman ve yeterli personel kullanarak eşyaları güvenle indiriyoruz." }
                },
                {
                    "@@type": "Question",
                    "name": "Kadıköy'den Ankara'ya taşıma kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Kadıköy – Ankara mesafesi yaklaşık 450 km'dir. Yükleme ve boşaltmayla birlikte toplam süre genellikle 10–14 saat arasında tamamlanır. Köprü trafiğinden kaçmak için erken saatte yola çıkılır." }
                },
                {
                    "@@type": "Question",
                    "name": "Fikirtepe kentsel dönüşüm bölgesindeki yüksek katlı binalardan taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Fikirtepe'nin yeni rezidans ve site projelerinden asansörlü profesyonel taşıma yapıyoruz. Yüksek kat avantajını kullanarak eşyaları hızlı ve güvenli indiriyoruz." }
                }
            ]
        }
    ]
}
</script>
}

