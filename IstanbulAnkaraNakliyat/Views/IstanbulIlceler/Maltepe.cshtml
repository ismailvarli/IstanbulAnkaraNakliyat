                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Maltepe Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/maltepe-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Maltepe Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Maltepe, İstanbul",
            "description": "Maltepe ilçesinden Ankara'ya kapıdan kapıya, sigortalı evden eve ve ofis taşıma hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/maltepe-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Maltepe'den Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Maltepe'den Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında değişmektedir. Kesin fiyat kat sayısı, asansör durumu ve eşya miktarına göre ücretsiz keşif sonrası belirlenir." }
                },
                {
                    "@@type": "Question",
                    "name": "Maltepe sahil bandındaki binalara araç erişimi kolay mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "E-5 sahil yolu boyunca uzanan Maltepe sahil bandında araç park etmek sabah saatlerinde yoğunluk nedeniyle zorlaşabilir. Bu nedenle taşıma operasyonlarını erken saatte başlatıyoruz. Küçükyalı ve Altayçeşme'deki yeni lüks projelerde ise araç girişi daha düzenli olup site yönetimiyle önceden koordinasyon sağlanır." }
                },
                {
                    "@@type": "Question",
                    "name": "Küçükyalı'daki site ve rezidanslardan taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Küçükyalı'daki lüks konut projelerinden ve güvenlikli sitelerden taşıma yapıyoruz. Site yönetimiyle önceden iletişim kurarak araç girişi ve servis asansörü rezervasyonunu ayarlıyoruz. Yüksek değerli mobilya ve eşyalar için özel paketleme ve ek sigorta da sunulmaktadır." }
                },
                {
                    "@@type": "Question",
                    "name": "Maltepe – Ankara güzergahında E-5 mi TEM mi kullanılıyor?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Maltepe'den Ankara'ya gidişte araçlarımız E-5 sahil yolundan Kartal yönünde ilerleyerek TEM otoyoluna bağlanır. TEM üzerinden Ankara'ya kesintisiz ulaşım sağlanır. Trafik yoğunluğuna göre en hızlı güzergah tercih edilir." }
                }
            ]
        }
    ]
}
</script>
}

