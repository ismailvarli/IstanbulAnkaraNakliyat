@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Güngören Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/gungoren-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Güngören Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Güngören, İstanbul",
            "description": "Güngören ilçesinden Ankara'ya kapıdan kapıya, sigortalı evden eve ve ofis taşıma hizmeti. Dar sokak deneyimi ve tekstil kurumsal taşıma uzmanlığı.",
            "url": "https://www.istanbulankaranakliyat.tr/gungoren-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Güngören'deki dar sokaklarda büyük nakliyat aracı girebiliyor mu?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Güngören'in Tozkoparan, Güven ve Mehmet Nesih Özmen mahallelerindeki bazı sokaklar tır geçişine uygun değildir. Bu durumlarda daha küçük araçlarla önce bir toplama noktasına taşıma yapıyor, ardından büyük araçla Ankara'ya hareket ediyoruz. Ekibimiz bölgeyi yakından tanıdığından güzergah planlaması önceden yapılır." }
                },
                {
                    "@@type": "Question",
                    "name": "Merter'deki tekstil atölyesi veya iş yeri taşıması için ne yapmalıyım?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Merter tekstil bölgesindeki atölye, depo veya ofis taşımalarında iş akışını sekteye uğratmamak için hafta sonu veya mesai dışı saatlerde taşıma yapıyoruz. Makine ve ekipmanlar özel sabitleme malzemeleriyle güvence altına alınır. Kurumsal taşıma için keşif randevusu alarak ayrıntılı planlama yapıyoruz." }
                },
                {
                    "@@type": "Question",
                    "name": "Güngören'den Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Güngören'den Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında başlamaktadır. Dar sokak veya asansörsüz bina durumunda ekstra personel ücreti önceden bildirilir. Kesin fiyat ücretsiz keşif sonrası sabit olarak belirlenir." }
                },
                {
                    "@@type": "Question",
                    "name": "Güngören'den Ankara'ya taşıma süresi ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Güngören – Ankara arası yaklaşık 450 km'dir. Yükleme ve boşaltmayla birlikte toplam süre genellikle 8–12 saat arasında tamamlanır. E-5 karayoluna yakın konumu sayesinde İstanbul'dan çıkış hızlı gerçekleşir; sabah erken saatte hareket edildiğinde Ankara'ya öğleden sonra varılır." }
                }
            ]
        }
    ]
}
</script>
}

