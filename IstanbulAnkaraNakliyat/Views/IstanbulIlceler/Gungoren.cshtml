<!-- ANA İÇERİK -->
<section style="padding:64px 0;">
    <div class="container">
        <div class="row">

            <!-- Sol: Ana İçerik -->
            <div class="col-lg-8">

                <h2 style="margin-bottom:1rem;">Güngören'den Ankara'ya Nakliyat</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    <strong>Güngören</strong>, İstanbul'un Avrupa yakasında Bağcılar, Bahçelievler ve Zeytinburnu arasında konumlanan, küçük yüzölçümüne karşın yoğun nüfusuyla dikkat çeken bir ilçedir. Merter Sanayi Bölgesi'nin hemen bitişiğinde yer alan Güngören, tarihsel olarak tekstil ve konfeksiyon sektörüyle özdeşleşmiştir. Güngören Merkez, Tozkoparan, Güven ve Mehmet Nesih Özmen mahalleleri ilçenin konut ağırlıklı dokusunu oluştururken, Merter ve Haznedar mahalleleri yoğun ticari ve sınai faaliyetin sürdüğü bölgelerdir. <strong>Güngören'den Ankara'ya nakliyat</strong> hizmetimizde hem bu dar dokulu konut alanlarının gerektirdiği özel lojistik planlamayı hem de ticari taşımalardaki kurumsal gereksinimleri eksiksiz karşılıyoruz.
                </p>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Güngören'de nakliyat sürecini zorlaştıran en önemli etken, özellikle Tozkoparan ve Güven mahallelerindeki dar sokak dokusudur. 1970–80'lerde inşa edilmiş, bodrum katlı ve asansörsüz çok sayıda eski apartman, büyük mobilyaların taşınmasında deneyim ve ekstra ekipman gerektirmektedir. Geniş nakliyat araçlarının sokağa giremediği durumlarda eşyalar önce küçük bir araçla ana caddeye taşınır, ardından büyük araca yüklenir. Bu iki aşamalı operasyon, ekibimizin standart çalışma pratiğinin bir parçasıdır. Abdurrahman Nafiz Gürman Mahallesi gibi bölgelerde ise yeni konut yapılarının yanı sıra eski yapı stoku da sürmekte olup her bina için özelleştirilmiş bir yükleme planı hazırlanmaktadır.
                </p>
                <p style="margin-bottom:2rem;line-height:1.9;color:var(--gray-700);">
                    Güngören'ün E-5 karayoluna olan yakınlığı, İstanbul'dan Ankara yönüne çıkışı önemli ölçüde kolaylaştırmaktadır. Yükleme tamamlandıktan sonra E-5 üzerinden hızla hareket eden nakliyat aracımız, Ankara'ya yaklaşık 8–12 saatlik bir süre içinde ulaşmaktadır. Güngören ve Merter'deki tekstil atölyeleri ile küçük ölçekli üretim tesislerinden zaman zaman kurumsal taşıma talepleri de almaktayız; bu tür işlerde makine ve ekipmanların özel sabitleme aparatlarıyla güvence altına alınması ve mesai saatleri dışında taşıma yapılması tercih edilmektedir. <strong>Güngören Ankara nakliyat</strong> sürecinizi ücretsiz keşif, sabit fiyat teklifi ve sigortalı taşıma güvencesiyle başlatmak için hemen arayabilirsiniz.
                </p>


                <figure style="margin:1.75rem 0 2rem;">
                    <img src="~/img/galeri/galeri22.jpeg" loading="lazy"
                         style="width:100%;border-radius:var(--radius-lg);object-fit:cover;max-height:380px;"
                         onerror="this.style.display='none'">
                </figure>
                <!-- HİZMET KAPSAMI -->
                <h2 style="margin-bottom:1.25rem;">Güngören'de Sunduğumuz Nakliyat Hizmetleri</h2>
                <div class="row" style="row-gap:1.25rem;margin-bottom:2.5rem;">
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏠</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Evden Eve Nakliyat</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Güngören'deki evinizden Ankara'nın istediğiniz semtine tam kapıdan kapıya taşıma. Tozkoparan, Güven, Merter fark etmez — her adrese ekibimizle geliyoruz.
                            </p>
                            <a href="/evden-eve-nakliyat" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏢</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Ofis &amp; Atölye Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Merter tekstil bölgesindeki iş yerinizi minimum iş kaybıyla Ankara'ya taşıyoruz. Hafta sonu veya gece taşıma seçeneğiyle operasyonel kesinti sıfıra iner.
                            </p>
                            <a href="/ofis-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">📦</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Parça Eşya Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Güngören'den Ankara'ya tek koltuk, kargo kutusu veya birkaç parça eşya gönderimi. Parsiyel yükle ekonomik ve hızlı çözüm.
                            </p>
                            <a href="/parca-esya-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🎁</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Ambalaj &amp; Paketleme</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Balonlu naylon, streç film, karton kutu ve köpük koruyucularla profesyonel ambalaj. Dar merdivenden indirilecek kırılgan eşyalar için özel paketleme.
                            </p>
                            <a href="/ambalaj-hizmeti" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                </div>

                <!-- İLÇEYE ÖZGÜ -->
                <h2 style="margin-bottom:1rem;">Güngören Nakliyatında Bilmeniz Gerekenler</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Güngören'de araç park izni ve yükleme noktası seçimi, taşıma sürecinin en kritik adımlarından biridir. Tozkoparan ve Güven mahallelerindeki çıkmaz sokaklar ile bölge sakinlerinin yoğun araç parkı nedeniyle nakliyat aracının binaya yakın konuşlandırılması her zaman mümkün olmayabilir. Bu gibi durumlarda ekibimiz portatif platform arabası ve ek personel desteğiyle eşyaları uygun bir yükleme noktasına kadar taşır. Güngören Merkez'deki daha geniş caddelerde ise araç doğrudan bina önüne çekilebilmekte ve süreç daha hızlı ilerlemektedir.
                </p>
                <p style="margin-bottom:2.5rem;line-height:1.9;color:var(--gray-700);">
                    Güngören'den Ankara'ya taşınanların büyük çoğunluğu iş değişikliği veya yaşam maliyetini düşürme hedefiyle hareket etmektedir. Tekstil sektörüne yakın konumu nedeniyle zaman zaman bir işletmenin tüm donanımı da Ankara'ya taşınmaktadır; bu tür kurumsal işlerde taşıma öncesi envanter listesi çıkarılması ve her parça için özel koruyucu ambalaj uygulanması standart prosedürümüzün parçasıdır. Güngören'den Ankara'ya yapılacak her türlü taşıma için ücretsiz keşif randevusu alarak ayrıntılı fiyat teklifi alabilirsiniz.
                </p>

                <!-- SÜREÇ -->
                <h2 style="margin-bottom:1.5rem;">Güngören Nakliyat Sürecimiz</h2>
                <div style="margin-bottom:2.5rem;">
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">1</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Ücretsiz Keşif</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Uzman eksperimiz Güngören adresinize gelir. Dar sokak, kat durumu, asansör kapasitesi ve eşya miktarını yerinde değerlendirir. Keşif tamamen ücretsizdir.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">2</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sabit Fiyat Teklifi</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Tüm kalemleri (ambalaj, söküm, montaj, sigorta) kapsayan yazılı teklif verilir. Dar sokak veya asansörsüz bina durumundaki ek kalemler de teklif içinde açıkça belirtilir.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">3</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Profesyonel Ambalajlama</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Taşıma günü ekibimiz Güngören'e erken saatte gelir. Mobilyalar battaniye ve streç filmle, kırılganlar balonlu naylonla özenle paketlenir.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">4</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sigortalı Nakliye</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Eşyalarınız kapalı kasalı, sigortalı araçlara yüklenerek E-5 güzergahıyla Ankara'ya hareket edilir. ~450 km mesafe ortalama 8–12 saatte tamamlanır.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">5</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Yerleştirme ve Montaj</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Ankara'daki yeni adresinizde eşyalar boşaltılır, sökülmüş mobilyalar monte edilir. İşlem tamamlanana kadar yanınızdayız.</p></div>
                    </div>
                </div>

                <!-- FİYAT -->
                <h2 style="margin-bottom:1rem;">Güngören – Ankara Nakliyat Fiyatları 2026</h2>
                <p style="color:var(--gray-600);margin-bottom:1.25rem;font-size:.95rem;">
                    Aşağıdaki fiyatlar referans niteliğindedir. Kesin fiyat keşif sonrası belirlenir.
                </p>
                <div class="price-table" style="margin-bottom:2.5rem;">
                    <div class="price-row price-row--header"><span>Daire / Hacim</span><span>Yaklaşık m³</span><span>Fiyat Aralığı</span></div>
                    <div class="price-row"><span>1+1 Daire</span><span>15–25 m³</span><span>8.000 – 14.000 ₺</span></div>
                    <div class="price-row"><span>2+1 Daire</span><span>25–40 m³</span><span>12.000 – 20.000 ₺</span></div>
                    <div class="price-row"><span>3+1 Daire</span><span>40–60 m³</span><span>16.000 – 26.000 ₺</span></div>
                    <div class="price-row"><span>4+1 / Villa</span><span>60–100+ m³</span><span>Keşif Sonrası</span></div>
                    <div class="price-row"><span>Ofis / Atölye</span><span>Değişken</span><span>Keşif Sonrası</span></div>
                </div>

                <!-- MAHALLELER -->
                <div style="background:var(--gray-100);border-radius:var(--radius-lg);padding:1.75rem;margin-bottom:2.5rem;">
                    <h3 style="margin-bottom:.75rem;">Güngören Mahalleleri — Hizmet Bölgelerimiz</h3>
                    <p style="margin-bottom:1rem;font-size:.95rem;color:var(--gray-700);">
                        Güngören'ün tüm mahallelerinde ücretsiz keşif yapıyor ve Ankara'ya nakliyat hizmeti sunuyoruz:
                    </p>
                    <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1rem;">
                        @foreach (var m in new[]{"Güngören Merkez","Tozkoparan","Güven","Mehmet Nesih Özmen","Merter","Abdurrahman Nafiz Gürman","Haznedar"})
                        {
                            <span style="background:var(--white);border:1px solid var(--gray-200);border-radius:50px;padding:.3rem .9rem;font-size:.82rem;font-weight:500;">@m</span>
                        }
                    </div>
                    <p style="font-size:.85rem;color:var(--gray-500);margin:0;">Mahalleniz listede olmasa da Güngören sınırları içindeki tüm adreslere hizmet veriyoruz.</p>
                </div>

                <!-- NEDEN BİZ -->
                <h2 style="margin-bottom:1.25rem;">Neden İstanbul Ankara Nakliyat?</h2>
                <div class="row" style="row-gap:1rem;margin-bottom:2.5rem;">
                    @{
                        var nedenler = new[] {
                            new { I="🛡️", T="Nakliyat Sigortası", A="Tüm eşyalarınız taşıma süresince sigorta kapsamındadır. Güngören'deki eski binalardan taşınan değerli eşyalar için ek sigorta da sunulmaktadır." },
