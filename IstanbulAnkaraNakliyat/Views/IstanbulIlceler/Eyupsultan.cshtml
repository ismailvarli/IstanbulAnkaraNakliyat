                        @foreach (var m in new[]{"Alibeyköy","Göktürk","Nişanca","Düğmeciler","Silahtarağa","Rami","Topçular","Çırçır","İslambey"})
                        {
                            <span style="background:var(--white);border:1px solid var(--gray-200);border-radius:50px;padding:.3rem .9rem;font-size:.82rem;font-weight:500;">@m</span>
                        }
                    </div>
                    <p style="font-size:.85rem;color:var(--gray-500);margin:0;">Mahalleniz listede olmasa da Eyüpsultan sınırları içindeki tüm adreslere hizmet veriyoruz.</p>
                </div>

                <!-- NEDEN BİZ -->
                <h2 style="margin-bottom:1.25rem;">Neden İstanbul Ankara Nakliyat?</h2>
                <div class="row" style="row-gap:1rem;margin-bottom:2.5rem;">
                    @{
                        var nedenler = new[] {
                            new { I="🛡️", T="Nakliyat Sigortası", A="Tüm eşyalarınız taşıma süresince sigorta kapsamındadır. Göktürk'teki lüks mobilyalar ve değerli eşyalar için ek sigorta seçeneği de sunulmaktadır." },
