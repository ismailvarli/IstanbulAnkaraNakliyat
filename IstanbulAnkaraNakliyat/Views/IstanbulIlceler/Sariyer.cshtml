<!-- ANA İÇERİK -->
<section style="padding:64px 0;">
    <div class="container">
        <div class="row">

            <!-- Sol: Ana İçerik -->
            <div class="col-lg-8">

                <h2 style="margin-bottom:1rem;">Sarıyer'den Ankara'ya Nakliyat</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    <strong>Sarıyer</strong>, İstanbul Boğazı kıyısındaki köklü yerleşim noktaları ve kuzey orman alanlarıyla İstanbul'un hem en prestijli hem de en yeşil ilçelerinden biridir. Yeniköy, Tarabya, Büyükdere ve İstinye gibi Boğaz kıyısı köyleri, yüzyıllık yalıları ve dar sokaklı tarihi dokusuyla özgün bir karakter taşırken Zekeriyaköy bölgesi İstanbul'un en değerli lüks villa ve gated community projelerine ev sahipliği yapar. Kuzey kesiminde ise Rumelifeneri ve Kilyos gibi mesire alanlarına yakın yerleşimler bulunmaktadır. Bu çeşitlilik, <strong>Sarıyer'den Ankara'ya nakliyat</strong> sürecini son derece özel bir uzmanlık gerektiren bir hizmete dönüştürür. İstanbul Ankara Nakliyat olarak Sarıyer'in her bölgesine özgü lojistik çözümler üretiyoruz.
                </p>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Boğaz köylerindeki tarihi yalı ve apartmanlarda taşımanın en büyük güçlüğü dar sokaklar ve sınırlı park alanıdır. Yeniköy ve Tarabya'nın kıyı şeridinde büyük nakliyat araçlarının manevra alanı oldukça kısıtlıdır; bu nedenle uygun boyutlu araç seçimi ve erken saatte konuşlanma zorunluluk taşır. Eski yalılarda değerli ahşap mobilyalar, antika eşyalar ve sanat yapıtları taşıma sürecinin en hassas unsurlarıdır; özel köpük paketleme, özelleşmiş sandık ambalajı ve ekstra battaniye koruma katmanları bu tür eşyalar için standart uygulamalarımız arasındadır. Boğaz kıyısındaki binalarda rıhtıma yakın konumlanma imkânı zaman zaman yükleme sürecini kolaylaştırsa da trafik yönetimi her adrese göre ayrı planlanır.
                </p>
                <p style="margin-bottom:2rem;line-height:1.9;color:var(--gray-700);">
                    Zekeriyaköy, TEM otoyoluna bağlantısı sayesinde Ankara güzergahında önemli bir çıkış avantajı sunmaktadır. Lüks villa sitelerinde taşıma yaparken site yönetimiyle önceden koordinasyon kurulur; güvenlik görevlisi kontrolündeki araç girişi ve servis kapısı rezervasyonu ekibimiz tarafından yönetilir. Üst gelir segmentine hitap eden bu bölgede antika mobilya, sanat eseri ve değerli koleksiyon parçaları için sigorta kapsamı standart sınırların üzerine çıkarılabilir; bu ek sigorta seçeneği keşif aşamasında müşterilerimize sunulur. <strong>Sarıyer Ankara nakliyat</strong> hizmeti sunarken tüm bu nüansları göz önünde bulundurarak her müşteriye özel çözüm üretiyoruz.
                </p>


                <figure style="margin:1.75rem 0 2rem;">
                    <img src="~/img/galeri/galeri30.jpeg" loading="lazy"
                         style="width:100%;border-radius:var(--radius-lg);object-fit:cover;max-height:380px;"
                         onerror="this.style.display='none'">
                </figure>
                <!-- HİZMET KAPSAMI -->
                <h2 style="margin-bottom:1.25rem;">Sarıyer'de Sunduğumuz Nakliyat Hizmetleri</h2>
                <div class="row" style="row-gap:1.25rem;margin-bottom:2.5rem;">
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏠</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Evden Eve Nakliyat</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Yeniköy, Tarabya, Zekeriyaköy, Büyükdere ve tüm Sarıyer mahallelerinden Ankara'ya kapıdan kapıya taşıma hizmeti.
                            </p>
                            <a href="/evden-eve-nakliyat" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏡</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Lüks Villa ve Yalı Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Zekeriyaköy ve Boğaz kıyısındaki lüks yalı ve villa taşımalarında değerli eşya, antika mobilya ve sanat eserleri için uzman ekip ve özel ambalaj.
                            </p>
                            <a href="/evden-eve-nakliyat" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏢</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Ofis Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Sarıyer'deki iş yerinizi minimum iş kaybıyla Ankara'ya taşıyoruz. Hafta sonu veya gece taşıma seçeneği mevcuttur.
                            </p>
                            <a href="/ofis-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🎁</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Değerli Eşya Ambalajı</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Antika mobilya, sanat eseri ve değerli koleksiyonlar için özel sandık ambalajı, köpük paketleme ve sigortalı taşıma çözümleri.
                            </p>
                            <a href="/ambalaj-hizmeti" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                </div>

                <!-- İLÇEYE ÖZGÜ -->
                <h2 style="margin-bottom:1rem;">Sarıyer Nakliyatında Bilmeniz Gerekenler</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Sarıyer'in Boğaz kıyısındaki köy ve mahallelerinde araç park etme ve yükleme noktası seçimi titiz bir planlama ister. Yeniköy, Tarabya ve Büyükdere'de kıyı şeridindeki dar yollar büyük araçların rahatça hareket edemeyeceği koşullar yaratabilir. Bu durumlarda daha kompakt araçlar kullanılır ya da uygun bir noktaya park edilen büyük araca aktarma yapılır. Belediye park düzenlemelerine uyum ve gerektiğinde izin alınması ekibimiz tarafından yönetilir. Emirgan ve Kireçburnu gibi mahallelerde ise yükseğe çıkan yollar ve dar geçitler önceden keşfedilerek en uygun araç rotası belirlenir.
                </p>
                <p style="margin-bottom:2.5rem;line-height:1.9;color:var(--gray-700);">
                    Zekeriyaköy bölgesinde taşıma planlaması oldukça sistematik biçimde yürütülür. Site yönetimiyle önceden iletişim kurularak araç giriş belgesi ve çalışma izni alınır; servis kapısı zamanlaması güvenlik birimiyle koordine edilir. Bu bölgedeki üst segment müşterilerin zaman zaman uluslararası kalitede ambalaj ve beyaz eldiven taşıma talepleri de karşılanmaktadır. Sarıyer'den Ankara'ya taşınma kararının arkasında çoğunlukla iş değişikliği, aile büyümesi veya Ankara'nın sunduğu daha geniş konut seçenekleri yatmaktadır. İstanbul Ankara Nakliyat olarak Sarıyerlilere eksiksiz ve güvenilir bir taşıma deneyimi sunmaktan memnuniyet duyuyoruz.
                </p>

                <!-- SÜREÇ -->
                <h2 style="margin-bottom:1.5rem;">Sarıyer Nakliyat Sürecimiz</h2>
                <div style="margin-bottom:2.5rem;">
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">1</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Ücretsiz Keşif</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Uzman eksperimiz Sarıyer adresinize gelir. Sokak genişliği, bina tipi, kat ve asansör durumu, değerli eşya listesi yerinde değerlendirilir. Keşif tamamen ücretsizdir.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">2</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sabit Fiyat Teklifi</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Ambalaj, söküm, montaj, sigorta ve site koordinasyonunu kapsayan yazılı teklif verilir. Verilen fiyat değişmez; sürpriz fatura çıkmaz.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">3</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Özel Ambalajlama</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Mobilyalar battaniye ve streç filmle, kırılganlar balonlu naylonla, değerli eşyalar özel köpük ve sandık ambalajıyla korunur.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">4</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sigortalı Nakliye</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Eşyalarınız kapalı kasalı, sigortalı araçlara yüklenerek Ankara'ya hareket edilir. ~450 km mesafe ortalama 8–12 saatte tamamlanır.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">5</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Yerleştirme ve Montaj</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Ankara'daki yeni adresinizde eşyalar boşaltılır, sökülmüş mobilyalar monte edilir. İşlem tamamlanana kadar yanınızdayız.</p></div>
                    </div>
                </div>

                <!-- FİYAT -->
                <h2 style="margin-bottom:1rem;">Sarıyer – Ankara Nakliyat Fiyatları 2026</h2>
                <p style="color:var(--gray-600);margin-bottom:1.25rem;font-size:.95rem;">
                    Aşağıdaki fiyatlar referans niteliğindedir. Kesin fiyat keşif sonrası belirlenir.
                </p>
                <div class="price-table" style="margin-bottom:2.5rem;">
                    <div class="price-row price-row--header"><span>Daire / Hacim</span><span>Yaklaşık m³</span><span>Fiyat Aralığı</span></div>
                    <div class="price-row"><span>1+1 Daire</span><span>15–25 m³</span><span>8.000 – 14.000 ₺</span></div>
                    <div class="price-row"><span>2+1 Daire</span><span>25–40 m³</span><span>12.000 – 20.000 ₺</span></div>
                    <div class="price-row"><span>3+1 Daire</span><span>40–60 m³</span><span>16.000 – 26.000 ₺</span></div>
                    <div class="price-row"><span>4+1 / Villa</span><span>60–100+ m³</span><span>Keşif Sonrası</span></div>
                    <div class="price-row"><span>Yalı / Lüks Konut</span><span>Değişken</span><span>Keşif Sonrası</span></div>
                </div>

                <!-- MAHALLELER -->
                <div style="background:var(--gray-100);border-radius:var(--radius-lg);padding:1.75rem;margin-bottom:2.5rem;">
                    <h3 style="margin-bottom:.75rem;">Sarıyer Mahalleleri — Hizmet Bölgelerimiz</h3>
                    <p style="margin-bottom:1rem;font-size:.95rem;color:var(--gray-700);">
                        Sarıyer'in tüm mahalle ve beldelerinde ücretsiz keşif yapıyor ve Ankara'ya nakliyat hizmeti sunuyoruz:
                    </p>
                    <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1rem;">
                        @foreach (var m in new[]{"Yeniköy","Tarabya","Büyükdere","İstinye","Zekeriyaköy","Rumelifeneri","Kilyos","Emirgan","Kireçburnu","Baltalimanı"})
                        {
                            <span style="background:var(--white);border:1px solid var(--gray-200);border-radius:50px;padding:.3rem .9rem;font-size:.82rem;font-weight:500;">@m</span>
                        }
                    </div>
                    <p style="font-size:.85rem;color:var(--gray-500);margin:0;">Mahalleniz listede olmasa da Sarıyer sınırları içindeki tüm adreslere hizmet veriyoruz.</p>
                </div>

                <!-- NEDEN BİZ -->
                <h2 style="margin-bottom:1.25rem;">Neden İstanbul Ankara Nakliyat?</h2>
                <div class="row" style="row-gap:1rem;margin-bottom:2.5rem;">
                    @{
                        var nedenler = new[] {
                            new { I="🛡️", T="Nakliyat Sigortası", A="Tüm eşyalarınız sigorta kapsamındadır. Sarıyer'deki antika, sanat eseri ve lüks mobilyalar için standart sigortanın üzerinde ek sigorta seçeneği sunulmaktadır." },
                            new { I="🔍", T="Ücretsiz Keşif", A="Eksperimiz Sarıyer adresinize gelir. Boğaz köyü dar sokakları, site erişimi ve değerli eşya tespiti yerinde yapılır; özel ambalaj planı hazırlanır." },
                            new { I="🔧", T="Söküm-Montaj Dahil", A="Karyola, gardırop ve yatak odası takımları sökülür; Ankara'daki yeni adresinizde kurulur. Montaj ücretsizdir." },
