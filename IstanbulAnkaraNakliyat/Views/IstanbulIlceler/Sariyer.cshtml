@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Sarıyer Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/sariyer-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Sarıyer Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Sarıyer, İstanbul",
            "description": "Sarıyer ilçesinden Ankara'ya kapıdan kapıya, sigortalı evden eve ve ofis taşıma hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/sariyer-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Sarıyer'den Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Sarıyer'den Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında başlamaktadır. Zekeriyaköy villaları ve Boğaz yalıları için kesin fiyat ücretsiz keşif sonrası belirlenir." }
                },
                {
                    "@@type": "Question",
                    "name": "Zekeriyaköy villaları için özel nakliyat hizmetiniz var mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Zekeriyaköy'ün lüks villa bölgelerinden Ankara'ya kapsamlı taşıma sunuyoruz. Site güvenlik koordinasyonu, büyük hacimli yükler için uygun araç seçimi ve değerli mobilyalar için özel ambalajlama yapıyoruz." }
                },
                {
                    "@@type": "Question",
                    "name": "Boğaz köylerindeki dar sokaklarda taşıma yapabiliyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Yeniköy, Tarabya ve Büyükdere gibi Boğaz köylerindeki dar sokaklarda taşıma deneyimine sahibiz. Büyük araçların giremeyeceği sokaklarda uygun boyutlu araç kullanılır ya da aktarma sistemiyle yükleme yapılır." }
                },
                {
                    "@@type": "Question",
                    "name": "Sarıyer'den Ankara'ya taşıma kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Sarıyer – Ankara mesafesi yaklaşık 450 km'dir. Zekeriyaköy'den TEM bağlantısıyla görece hızlı çıkış mümkünken Boğaz köylerinden şehir içi geçiş ek süre gerektirebilir. Yükleme ve boşaltmayla birlikte toplam süre 8–12 saat arasında tamamlanır." }
                }
            ]
        }
    ]
}
</script>
}

