                },
                {
                    "@@type": "Question",
                    "name": "Sancaktepe'de aynı gün taşıma imkânı var mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Aynı gün taşıma, müsaitlik durumuna ve eşya miktarına göre değerlendirilebilir. Acil taşıma talepleriniz için bizi arayın veya WhatsApp üzerinden yazın; ekibimiz en hızlı çözümü sizinle paylaşsın. Küçük hacimli taşımalar için genellikle kısa sürede planlama yapılabilir." }
                }
            ]
        }
    ]
}
</script>
}

