@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Şişli Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/sisli-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Şişli Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Şişli, İstanbul",
            "description": "Şişli ilçesinden Ankara'ya kapıdan kapıya, sigortalı evden eve ve kurumsal ofis taşıma hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/sisli-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Nişantaşı'ndaki eski apartmanlardan taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Nişantaşı'nın eski ve dar merdivenlere sahip apartmanlarında uzun yıllara dayanan deneyimimiz var. Asansörün küçük ya da devre dışı olduğu binalarda özel ekipman ve yeterli personel kullanarak büyük mobilyaları güvenle indiriyoruz. Gerektiğinde balkon veya pencere yöntemiyle taşıma da yapıyoruz." }
                },
                {
                    "@@type": "Question",
                    "name": "Mecidiyeköy ofis binalarından kurumsal taşıma fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Mecidiyeköy'deki ofis taşıma fiyatları; ofis büyüklüğüne, arşiv ve ekipman miktarına, kat ve asansör durumuna göre değişir. Küçük ofisler için 10.000–18.000 ₺ aralığı başlangıç noktasıdır; ancak kesin fiyat yerinde keşif sonrası belirlenir. İş kulelerinde hafta sonu veya gece taşıma programı ile ek koordinasyon giderleri söz konusu olabilir." }
                },
                {
                    "@@type": "Question",
                    "name": "Şişli'den Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Şişli'den Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında başlamaktadır. Kesin fiyat bina tipi, kat durumu, eşya miktarı ve ek hizmetlere göre ücretsiz keşif sonrası netleşir." }
                },
                {
                    "@@type": "Question",
                    "name": "Şişli – Ankara taşıması hangi güzergahtan yapılıyor?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Şişli'nin TEM otoyoluna ve FSM (Fatih Sultan Mehmet) köprüsüne yakın konumu İstanbul çıkışını önemli ölçüde kolaylaştırır. Güzergah genellikle TEM – D-100 (E-80) bağlantısıyla Ankara'ya ulaşır. Trafik yoğunluğuna göre sabah erken saatte yola çıkılarak ~450 km'lik mesafe 8–12 saatte tamamlanır." }
                }
            ]
        }
    ]
}
</script>
}

