            "url": "https://www.istanbulankaranakliyat.tr/arnavutkoy-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Arnavutköy'den Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Arnavutköy'den Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında başlamaktadır. Kesin fiyat keşif sonrası belirlenir." }
