@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Pendik Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/pendik-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Pendik Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Pendik, İstanbul",
            "description": "Pendik ilçesinden Ankara'ya kapıdan kapıya, sigortalı evden eve ve kurumsal taşıma hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/pendik-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Pendik'ten Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Pendik'ten Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında değişmektedir. Kesin fiyat kat sayısı, asansör durumu ve eşya miktarına göre ücretsiz keşif sonrası belirlenir." }
                },
                {
                    "@@type": "Question",
                    "name": "Kurtköy'deki sitelere ve lojistik bölgeye hizmet veriyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Kurtköy'deki güvenlikli konut sitelerine ve organize lojistik tesislerine hizmet veriyoruz. Lojistik bölgedeki kurumsal taşımalarda büyük hacimli araç kullanımı ve esnek zamanlama sağlıyoruz. Konut sitelerinde ise site yönetimiyle önceden koordinasyon kurarak araç girişini ayarlıyoruz." }
                },
                {
                    "@@type": "Question",
                    "name": "Sabiha Gökçen yakınındaki depolardan kurumsal taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Sabiha Gökçen Havalimanı çevresindeki depo ve lojistik tesislerden Ankara'ya kurumsal taşıma yapıyoruz. Büyük hacimli ticari eşya ve ofis malzemeleri için geniş tonajlı araçlarımızla hizmet sunuyoruz. Uçuş takvimiyle koordineli taşıma planlaması da yapılabilmektedir." }
                },
                {
                    "@@type": "Question",
                    "name": "Pendik – Ankara güzergahı kaç saat sürer?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Pendik – Ankara mesafesi yaklaşık 450 km'dir. Pendik, TEM otoyoluna yakın konumda olduğundan İstanbul iç trafik yükü görece azdır. Yükleme ve boşaltmayla birlikte toplam süre genellikle 9–13 saat arasında tamamlanır. Sabah erken başlanan operasyonlarda Ankara'ya öğleden sonra varılır." }
                }
            ]
        }
    ]
}
</script>
}

