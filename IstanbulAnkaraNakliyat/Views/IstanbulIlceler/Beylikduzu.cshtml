<!-- ANA İÇERİK -->
<section style="padding:64px 0;">
    <div class="container">
        <div class="row">

            <!-- Sol: Ana İçerik -->
            <div class="col-lg-8">

                <h2 style="margin-bottom:1rem;">Beylikdüzü'nden Ankara'ya Nakliyat</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    <strong>Beylikdüzü</strong>, İstanbul'un Avrupa yakasının batısında yer alan, planlı kentsel gelişimiyle öne çıkan modern bir ilçedir. Gürpınar'ın deniz manzaralı sitelerinden Adnan Kahveci ve Büyükşehir mahallelerinin geniş caddeli konut bloklarına, Marmara mahallesi ile Yakuplu'nun yeni rezidanslarına uzanan bu ilçe, TEM otoyoluna sıfır mesafesiyle İstanbul'un Ankara güzergahı açısından en avantajlı başlangıç noktalarından birini oluşturur. <strong>Beylikdüzü'nden Ankara'ya nakliyat</strong> sürecinde bu güzergah avantajını en verimli şekilde kullanan bir lojistik planlamayla çalışıyoruz.
                </p>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Beylikdüzü'nün inşaat stoku büyük ölçüde 2000'li ve 2010'lu yıllarda tamamlanan modern yapılardan oluşur. Bu binalarda geniş servis asansörleri, araç parkı için uygun alanlar ve kapıdan çıkışa uygun mobilya boyutları genellikle standarttır; dolayısıyla yükleme süreci diğer eski ilçelere kıyasla daha hızlı ve sorunsuz ilerler. Ancak kapalı site ve güvenlikli rezidanslarda araç giriş izni ile servis asansörü rezervasyonu önceden ayarlanması gereken kritik detaylardır. Ekibimiz bu koordinasyonu siz hiç uğraşmak zorunda kalmadan yürütür.
                </p>
                <p style="margin-bottom:2rem;line-height:1.9;color:var(--gray-700);">
                    TEM otoyoluna Beylikdüzü kavşağından direkt çıkış, <strong>Beylikdüzü Ankara nakliyat</strong> sürecinin en büyük avantajıdır. İstanbul içi trafik stresini en aza indirerek sabahın erken saatlerinde yola çıkan ekibimiz, Ankara'ya öğleden sonra ulaşır ve boşaltma işlemi gün ışığında tamamlanır. Tüm eşyalar nakliyat sigortası güvencesi altında kapalı kasalı araçlarda taşınır; kırılganlar balonlu naylon ve köpük paketlemeyle, mobilyalar battaniye ve streç filmle korunur.
                </p>


                <figure style="margin:1.75rem 0 2rem;">
                    <img src="~/img/galeri/galeri12.webp" loading="lazy"
                         style="width:100%;border-radius:var(--radius-lg);object-fit:cover;max-height:380px;"
                         onerror="this.style.display='none'">
                </figure>
                <!-- HİZMET KAPSAMI -->
                <h2 style="margin-bottom:1.25rem;">Beylikdüzü'nde Sunduğumuz Nakliyat Hizmetleri</h2>
                <div class="row" style="row-gap:1.25rem;margin-bottom:2.5rem;">
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏠</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Evden Eve Nakliyat</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Beylikdüzü'ndeki evinizden Ankara'nın istediğiniz semtine tam kapıdan kapıya taşıma. Gürpınar, Adnan Kahveci, Marmara fark etmez — her adrese geliyoruz.
                            </p>
                            <a href="/evden-eve-nakliyat" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏢</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Ofis Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Beylikdüzü'ndeki iş yerinizi minimum iş kaybıyla Ankara'ya taşıyoruz. Hafta sonu veya gece taşıma seçeneğiyle operasyonel kesinti sıfıra iner.
                            </p>
                            <a href="/ofis-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">📦</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Parça Eşya Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Beylikdüzü'nden Ankara'ya tek koltuk, kargo kutusu veya birkaç parça eşya gönderimi. Parsiyel yükle ekonomik ve hızlı çözüm.
                            </p>
                            <a href="/parca-esya-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🎁</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Ambalaj &amp; Paketleme</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Balonlu naylon, streç film, karton kutu ve köpük koruyucularla profesyonel ambalaj. Büyük rezidanslardaki lüks mobilyalar için özel paketleme.
                            </p>
                            <a href="/ambalaj-hizmeti" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                </div>

                <!-- İLÇEYE ÖZGÜ -->
                <h2 style="margin-bottom:1rem;">Beylikdüzü Nakliyatında Bilmeniz Gerekenler</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Beylikdüzü'ndeki kapalı sitelerde araç park koordinasyonu taşıma sürecinin en kritik adımıdır. Gürpınar'ın deniz manzaralı sitelerinde ve Marmara mahallesi rezidanslarında site yönetimiyle önceden iletişim kurarak araç giriş saati ve servis asansörü rezervasyonu ayarlanır. Büyükşehir ve Adnan Kahveci mahallelerindeki müstakil binalarda ise cadde parkı genellikle sorunsuz sağlanabilir; sabah erken saatte başlanan yüklemeler trafik avantajıyla hem hız hem güvenlik açısından en verimli sonucu verir.
                </p>
                <p style="margin-bottom:2.5rem;line-height:1.9;color:var(--gray-700);">
                    Beylikdüzü'nden Ankara'ya taşınmanın en sık nedenleri arasında iş değişikliği, Ankara'da daha geniş konut seçeneği ve yaşam maliyetini optimize etme isteği yer almaktadır. TEM'e yakınlığı sayesinde nakliyat ekibinin yola çıkışı hızlanır; bu avantaj özellikle hafta içi taşımalarda belirgin biçimde hissedilir. İstanbul Ankara Nakliyat olarak Beylikdüzü'nün modern konut stokuna uygun ekipman ve deneyimle ücretsiz keşif, sabit fiyat garantisi ve sigortalı taşıma sunuyoruz.
                </p>

                <!-- SÜREÇ -->
                <h2 style="margin-bottom:1.5rem;">Beylikdüzü Nakliyat Sürecimiz</h2>
                <div style="margin-bottom:2.5rem;">
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">1</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Ücretsiz Keşif</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Uzman eksperimiz Beylikdüzü adresinize gelir. Bina tipi, kat durumu, asansör kapasitesi ve eşya miktarını yerinde değerlendirir. Keşif tamamen ücretsizdir.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">2</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sabit Fiyat Teklifi</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Tüm kalemleri (ambalaj, söküm, montaj, sigorta) kapsayan yazılı teklif verilir. Verilen fiyat değişmez; sürpriz fatura çıkmaz.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">3</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Profesyonel Ambalajlama</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Taşıma günü ekibimiz Beylikdüzü'ne erken saatte gelir. Mobilyalar battaniye ve streç filmle, kırılganlar balonlu naylonla özenle paketlenir.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">4</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sigortalı Nakliye</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Eşyalarınız kapalı kasalı, sigortalı araçlara yüklenerek TEM üzerinden Ankara'ya hareket edilir. ~450 km mesafe ortalama 8–12 saatte tamamlanır.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">5</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Yerleştirme ve Montaj</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Ankara'daki yeni adresinizde eşyalar boşaltılır, sökülmüş mobilyalar monte edilir. İşlem tamamlanana kadar yanınızdayız.</p></div>
                    </div>
                </div>

                <!-- FİYAT -->
                <h2 style="margin-bottom:1rem;">Beylikdüzü – Ankara Nakliyat Fiyatları 2026</h2>
                <p style="color:var(--gray-600);margin-bottom:1.25rem;font-size:.95rem;">
                    Aşağıdaki fiyatlar referans niteliğindedir. Kesin fiyat keşif sonrası belirlenir.
                </p>
                <div class="price-table" style="margin-bottom:2.5rem;">
                    <div class="price-row price-row--header"><span>Daire / Hacim</span><span>Yaklaşık m³</span><span>Fiyat Aralığı</span></div>
                    <div class="price-row"><span>1+1 Daire</span><span>15–25 m³</span><span>8.000 – 14.000 ₺</span></div>
                    <div class="price-row"><span>2+1 Daire</span><span>25–40 m³</span><span>12.000 – 20.000 ₺</span></div>
                    <div class="price-row"><span>3+1 Daire</span><span>40–60 m³</span><span>16.000 – 26.000 ₺</span></div>
                    <div class="price-row"><span>4+1 / Villa</span><span>60–100+ m³</span><span>Keşif Sonrası</span></div>
                    <div class="price-row"><span>Ofis / İşyeri</span><span>Değişken</span><span>Keşif Sonrası</span></div>
                </div>

                <!-- MAHALLELER -->
                <div style="background:var(--gray-100);border-radius:var(--radius-lg);padding:1.75rem;margin-bottom:2.5rem;">
                    <h3 style="margin-bottom:.75rem;">Beylikdüzü Mahalleleri — Hizmet Bölgelerimiz</h3>
                    <p style="margin-bottom:1rem;font-size:.95rem;color:var(--gray-700);">
                        Beylikdüzü'nün tüm mahallelerinde ücretsiz keşif yapıyor ve Ankara'ya nakliyat hizmeti sunuyoruz:
                    </p>
                    <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1rem;">
                        @foreach (var m in new[]{"Gürpınar","Adnan Kahveci","Büyükşehir","Marmara","Yakuplu","Barış","Kavaklı","Dereağzı"})
                        {
                            <span style="background:var(--white);border:1px solid var(--gray-200);border-radius:50px;padding:.3rem .9rem;font-size:.82rem;font-weight:500;">@m</span>
                        }
                    </div>
                    <p style="font-size:.85rem;color:var(--gray-500);margin:0;">Mahalleniz listede olmasa da Beylikdüzü sınırları içindeki tüm adreslere hizmet veriyoruz.</p>
                </div>

                <!-- NEDEN BİZ -->
                <h2 style="margin-bottom:1.25rem;">Neden İstanbul Ankara Nakliyat?</h2>
                <div class="row" style="row-gap:1rem;margin-bottom:2.5rem;">
                    @{
                        var nedenler = new[] {
                            new { I="🛡️", T="Nakliyat Sigortası", A="Tüm eşyalarınız taşıma süresince sigorta kapsamındadır. Beylikdüzü'nün modern rezidanslarından taşınan lüks mobilyalar için ek sigorta da sunulmaktadır." },
                            new { I="🔍", T="Ücretsiz Keşif", A="Eksperimiz Beylikdüzü adresinize gelir, eşyaları yerinde değerlendirir ve sabit fiyat teklifi sunar. Site koordinasyonu dahil tüm detaylar planlanır." },
                            new { I="🔧", T="Söküm-Montaj Dahil", A="Karyola, gardırop ve yatak odası takımları sökülür; Ankara'daki yeni adresinizde kurulur. Montaj ücretsizdir." },
                            new { I="🚛", T="Modern Araç Filosu", A="Kapalı kasalı, perde branda donanımlı araçlarla eşyalarınız yağmur ve dış etkilerden korunur. TEM güzergahına uygun büyüklükte araç seçilir." },
                            new { I="💬", T="7/24 İletişim", A="Taşıma öncesi, sırası ve sonrasında her an ulaşabilirsiniz. WhatsApp üzerinden anlık bilgi alabilirsiniz." },
                            new { I="💰", T="Şeffaf Fiyatlandırma", A="Keşif sonrası verilen fiyat değişmez. Ek merdiven veya asansör ücreti gibi kalemler önceden belirtilir; sürpriz fatura çıkmaz." }
                        };
                    }
                    @foreach (var n in nedenler)
                    {
