@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Beylikdüzü Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/beylikduzu-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Beylikdüzü Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Beylikdüzü, İstanbul",
            "description": "Beylikdüzü ilçesinden Ankara'ya kapıdan kapıya, sigortalı evden eve ve ofis taşıma hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/beylikduzu-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Beylikdüzü'nden Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Beylikdüzü'nden Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında başlamaktadır. Kesin fiyat keşif sonrası belirlenir." }
                },
                {
                    "@@type": "Question",
                    "name": "Beylikdüzü TEM otoyolundan Ankara'ya ulaşım ne kadar sürer?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Beylikdüzü, TEM otoyoluna çok yakın konumdadır. İstanbul içi trafiği atlatıldıktan sonra Ankara'ya ulaşım süresi ortalama 4,5–5,5 saattir. Yükleme ve boşaltmayla birlikte toplam süre 10–14 saat arasında tamamlanır." }
                },
                {
                    "@@type": "Question",
                    "name": "Beylikdüzü sitelerindeki taşıma için araç park izni gerekiyor mu?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Beylikdüzü'ndeki kapalı site ve rezidanslarda araç girişi için site yönetimiyle önceden koordinasyon gerekebilir. Bu süreci biz sizin adınıza yönetiyoruz; taşıma günü herhangi bir engelle karşılaşmazsınız." }
                },
                {
                    "@@type": "Question",
                    "name": "Eşyalar taşıma sırasında sigortalı mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Beylikdüzü – Ankara güzergahında taşınan tüm eşyalar nakliyat sigortası kapsamındadır. Hasar durumunda sigorta şirketimiz devreye girer; tazminat hakkınız yazılı sözleşmeyle güvence altına alınır." }
                }
            ]
        }
    ]
}
</script>
}

