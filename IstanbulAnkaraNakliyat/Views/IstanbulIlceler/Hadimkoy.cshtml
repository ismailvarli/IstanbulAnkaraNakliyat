    <div class="container">
        <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:0;text-align:center;">
            <div style="padding:1.1rem 1.5rem;border-right:1px solid var(--gray-200);">
                <div style="font-size:1.1rem;font-weight:800;">10+ Yıl</div>
