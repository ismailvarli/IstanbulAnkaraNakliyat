<!-- ANA İÇERİK -->
<section style="padding:64px 0;">
    <div class="container">
        <div class="row">

            <!-- Sol: Ana İçerik -->
            <div class="col-lg-8">

                <h2 style="margin-bottom:1rem;">Hadımköy'den Ankara'ya Nakliyat</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    <strong>Hadımköy</strong>, Arnavutköy ilçesine bağlı ve İstanbul'un Avrupa yakasında yer alan köklü bir sanayi merkezidir. İstanbul'un en büyük organize sanayi bölgelerinden birini barındıran Hadımköy, aynı zamanda son yıllarda hızla gelişen konut stokuyla da dikkat çekmektedir. İstanbul Havalimanı'na ve TEM otoyoluna olan yakınlığı, bölgeyi lojistik açıdan son derece stratejik bir konuma taşımaktadır. <strong>Hadımköy'den Ankara'ya nakliyat</strong> sürecinde bu coğrafi avantaj, şehir içi trafik kaybını minimuma indirerek güzergaha çok hızlı çıkılmasını sağlar.
                </p>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Hadımköy'deki konut yapısı oldukça çeşitlidir: OSB çevresi çalışanlarının yoğunlaştığı bağımsız apartmanlar ve villa tipi konutların yanı sıra Taşoluk ve Bolluca mahallelerinde de yerleşim alanları bulunmaktadır. Çoğunlukla geniş yol ağına ve erişim kolaylığına sahip bu bölgede büyük nakliye araçlarının konuşlanması oldukça pratiktir; dar sokak veya sık otopark problemleriyle nadiren karşılaşılır. İstanbul Ankara Nakliyat olarak Hadımköy'ün tüm mahallelerinde ücretsiz keşif yapıyor, eşyalarınızı yerinde değerlendirdikten sonra sabit fiyat teklifi sunuyoruz.
                </p>
                <p style="margin-bottom:2rem;line-height:1.9;color:var(--gray-700);">
                    Hadımköy'den Ankara'ya taşınma taleplerinin önemli bir bölümü OSB'deki fabrika, atölye ve depo işletmecilerinden ya da bu işyerlerinde çalışan ve iş değiştiren beyaz yakalı çalışanlardan gelmektedir. Bunun yanı sıra bölgede konut kiralayan ve Ankara'ya atanan kamu personeli ile aileler de sık başvuran profilimiz arasında yer almaktadır. Her profilde müşteriye özel keşif, sigortalı taşıma ve C Tipi Yetki Belgesi güvencesiyle hizmet sunuyoruz.
                </p>

                <figure style="margin:1.75rem 0 2rem;">
                    <img src="~/img/galeri/galeri12.webp" loading="lazy"
                         style="width:100%;border-radius:var(--radius-lg);object-fit:cover;max-height:380px;"
                         onerror="this.style.display='none'">
                </figure>

                <!-- HİZMET KAPSAMI -->
                <h2 style="margin-bottom:1.25rem;">Hadımköy'de Sunduğumuz Nakliyat Hizmetleri</h2>
                <div class="row" style="row-gap:1.25rem;margin-bottom:2.5rem;">
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏠</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Evden Eve Nakliyat</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Hadımköy, Taşoluk ve Bolluca'daki evinizden Ankara'nın istediğiniz semtine tam kapıdan kapıya, sigortalı taşıma.
                            </p>
                            <a href="/evden-eve-nakliyat" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏭</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Ofis &amp; İşyeri Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Hadımköy OSB'deki ofis, depo veya atölyenizi Ankara'ya minimum kesinti ile taşıyoruz. Hafta sonu ve gece taşıma seçeneği mevcuttur.
                            </p>
                            <a href="/ofis-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">📦</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Parça Eşya Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Hadımköy'den Ankara'ya tek koltuk, kargo kutusu veya birkaç parça eşya gönderimi. Parsiyel yükle ekonomik ve hızlı çözüm.
                            </p>
                            <a href="/parca-esya-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🎁</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Ambalaj &amp; Paketleme</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Balonlu naylon, streç film, karton kutu ve köpük koruyucularla profesyonel ambalaj. Kırılgan elektronik ve değerli eşyalar için özel paketleme.
                            </p>
                            <a href="/ambalaj-hizmeti" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                </div>

                <!-- İLÇEYE ÖZGÜ -->
                <h2 style="margin-bottom:1rem;">Hadımköy Nakliyatında Bilmeniz Gerekenler</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Hadımköy OSB içindeki işyeri taşımalarında fabrika veya depo yönetiminden araç giriş izni alınması gerekebilir; bu koordinasyonu sizin adınıza sağlıyoruz. Taşoluk ve Bolluca gibi konut ağırlıklı mahallelerde ise geniş yol yapısı sayesinde büyük nakliye araçlarının konuşlanması pratiktir. OSB bölgesinde gece saatlerinde daha az yoğunluk olduğundan, büyük ölçekli ticari taşımalar için erken sabah veya gece seçeneğini öneriyoruz.
                </p>
                <p style="margin-bottom:2.5rem;line-height:1.9;color:var(--gray-700);">
                    TEM otoyoluna olan yakınlık, Hadımköy'ü Ankara güzergahında İstanbul'un avantajlı çıkış noktalarından biri yapmaktadır. İstanbul içi köprü geçişi ya da boğaz tüneli maliyeti olmaksızın TEM'e bağlanarak Ankara'ya 450 km mesafeyi ortalama 8–12 saatte tamamlıyoruz. Havalimanı yakınlığı ise gün içinde yükleme planlaması açısından esneklik sağlamaktadır.
                </p>

                <!-- SÜREÇ -->
                <h2 style="margin-bottom:1.5rem;">Hadımköy Nakliyat Sürecimiz</h2>
                <div style="margin-bottom:2.5rem;">
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">1</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Ücretsiz Keşif</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Uzman eksperimiz Hadımköy adresinize gelir. Bina tipi, kat durumu, asansör kapasitesi ve eşya miktarını yerinde değerlendirir. Keşif tamamen ücretsizdir.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">2</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sabit Fiyat Teklifi</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Tüm kalemleri (ambalaj, söküm, montaj, sigorta) kapsayan yazılı teklif verilir. Verilen fiyat değişmez; sürpriz fatura çıkmaz.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">3</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Profesyonel Ambalajlama</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Taşıma günü ekibimiz erken saatte Hadımköy'e gelir. Mobilyalar battaniye ve streç filmle, kırılganlar balonlu naylonla paketlenir.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">4</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sigortalı Nakliye</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Eşyalarınız kapalı kasalı, sigortalı araçlara yüklenerek TEM üzerinden Ankara'ya hareket edilir. ~450 km mesafe ortalama 8–12 saatte tamamlanır.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">5</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Yerleştirme ve Montaj</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Ankara'daki yeni adresinizde eşyalar boşaltılır, sökülmüş mobilyalar monte edilir. İşlem tamamlanana kadar yanınızdayız.</p></div>
                    </div>
                </div>

                <!-- FİYAT -->
                <h2 style="margin-bottom:1rem;">Hadımköy – Ankara Nakliyat Fiyatları 2026</h2>
                <p style="color:var(--gray-600);margin-bottom:1.25rem;font-size:.95rem;">
                    Aşağıdaki fiyatlar referans niteliğindedir. Kesin fiyat keşif sonrası belirlenir.
                </p>
                <div class="price-table" style="margin-bottom:2.5rem;">
                    <div class="price-row price-row--header"><span>Daire / Hacim</span><span>Yaklaşık m³</span><span>Fiyat Aralığı</span></div>
                    <div class="price-row"><span>1+1 Daire</span><span>15–25 m³</span><span>8.000 – 14.000 ₺</span></div>
                    <div class="price-row"><span>2+1 Daire</span><span>25–40 m³</span><span>12.000 – 20.000 ₺</span></div>
                    <div class="price-row"><span>3+1 Daire</span><span>40–60 m³</span><span>16.000 – 26.000 ₺</span></div>
                    <div class="price-row"><span>4+1 / Villa</span><span>60–100+ m³</span><span>Keşif Sonrası</span></div>
                    <div class="price-row"><span>Ofis / İşyeri</span><span>Değişken</span><span>Keşif Sonrası</span></div>
                </div>

                <!-- MAHALLELER -->
                <div style="background:var(--gray-100);border-radius:var(--radius-lg);padding:1.75rem;margin-bottom:2.5rem;">
                    <h3 style="margin-bottom:.75rem;">Hadımköy ve Çevresi — Hizmet Bölgelerimiz</h3>
                    <p style="margin-bottom:1rem;font-size:.95rem;color:var(--gray-700);">
                        Hadımköy bölgesinin tüm mahallelerinde ücretsiz keşif yapıyor ve Ankara'ya nakliyat hizmeti sunuyoruz:
                    </p>
                    <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1rem;">
                        @foreach (var m in new[]{"Hadımköy Merkez","Hadımköy OSB","Taşoluk","Bolluca","Haraçcı","Arnavutköy Merkez","Yassıören","Durusu"})
                        {
                            <span style="background:var(--white);border:1px solid var(--gray-200);border-radius:50px;padding:.3rem .9rem;font-size:.82rem;font-weight:500;">@m</span>
                        }
                    </div>
                    <p style="font-size:.85rem;color:var(--gray-500);margin:0;">Mahalleniz listede olmasa da Hadımköy ve Arnavutköy sınırları içindeki tüm adreslere hizmet veriyoruz.</p>
                </div>

                <!-- NEDEN BİZ -->
                <h2 style="margin-bottom:1.25rem;">Neden İstanbul Ankara Nakliyat?</h2>
                <div class="row" style="row-gap:1rem;margin-bottom:2.5rem;">
                    @{
                        var nedenler = new[] {
                            new { I="🛡️", T="Nakliyat Sigortası", A="Tüm eşyalarınız taşıma süresince sigorta kapsamındadır. OSB bölgesindeki ticari ekipman ve değerli eşyalar için ek sigorta da sunulmaktadır." },
                            new { I="🔍", T="Ücretsiz Keşif", A="Eksperimiz Hadımköy adresinize gelir, eşyaları yerinde değerlendirir ve sabit fiyat teklifi sunar. OSB'deki işyerleri için de aynı hizmeti sunuyoruz." },
                            new { I="🔧", T="Söküm-Montaj Dahil", A="Karyola, gardırop ve yatak odası takımları sökülür; Ankara'daki yeni adresinizde kurulur. Montaj ücretsizdir." },
                            new { I="🚛", T="TEM Bağlantılı Güzergah", A="Hadımköy'ün TEM'e yakın konumu, köprü veya tünel trafiği olmaksızın hızlı güzergah çıkışı sağlar. Bu hem süreyi hem maliyeti optimize eder." },
                            new { I="💬", T="7/24 İletişim", A="Taşıma öncesi, sırası ve sonrasında her an ulaşabilirsiniz. WhatsApp üzerinden anlık bilgi alabilirsiniz." },
                            new { I="💰", T="Şeffaf Fiyatlandırma", A="Keşif sonrası verilen fiyat değişmez. OSB giriş izni veya ek personel gibi kalemler önceden belirtilir; sürpriz fatura çıkmaz." }
                        };
                    }
                    @foreach (var n in nedenler)
                    {
                        <div class="col-md-6">
                            <div style="display:flex;gap:1rem;align-items:flex-start;padding:1.1rem;border:1px solid var(--gray-200);border-radius:var(--radius);">
                                <span style="font-size:1.5rem;flex-shrink:0;line-height:1;">@n.I</span>
                                <div>
                                    <h4 style="font-size:.9rem;margin-bottom:.3rem;">@n.T</h4>
                                    <p style="font-size:.83rem;color:var(--gray-600);margin:0;line-height:1.6;">@n.A</p>
                                </div>
                            </div>
