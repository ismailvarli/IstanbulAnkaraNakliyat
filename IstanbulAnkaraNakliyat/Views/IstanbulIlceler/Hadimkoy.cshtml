            </div>
            <div style="padding:1.1rem 1.5rem;border-right:1px solid var(--gray-200);">
                <div style="font-size:1.1rem;font-weight:800;">~450 km</div>
                <div style="font-size:.75rem;color:var(--gray-600);margin-top:.1rem;">İstanbul–Ankara Mesafe</div>
            </div>
            <div style="padding:1.1rem 1.5rem;border-right:1px solid var(--gray-200);">
                <div style="font-size:1.1rem;font-weight:800;">8–12 saat</div>
                <div style="font-size:.75rem;color:var(--gray-600);margin-top:.1rem;">Ortalama Teslimat</div>
            </div>
