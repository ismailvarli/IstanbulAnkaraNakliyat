@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Hadımköy Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/hadimkoy-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Hadımköy Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Hadımköy, Arnavutköy, İstanbul",
            "description": "Hadımköy'den Ankara'ya kapıdan kapıya, sigortalı evden eve ve ofis taşıma hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/hadimkoy-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Hadımköy'den Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Hadımköy'den Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında başlamaktadır. Kesin fiyat keşif sonrası belirlenir." }
                },
                {
                    "@@type": "Question",
                    "name": "Hadımköy OSB'den Ankara'ya ofis veya fabrika taşıması yapılıyor mu?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Hadımköy OSB'deki işyerleri, depolar ve küçük fabrikalara özel ticari nakliyat hizmeti sunuyoruz. Ekipman, ofis mobilyası ve ticari malların taşınması için önceden keşif yapılır ve sabit fiyat teklifi verilir." }
                },
                {
                    "@@type": "Question",
                    "name": "Hadımköy – Ankara güzergahı kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Hadımköy, TEM otoyoluna ve İstanbul Havalimanı çevresine yakın konumuyla İstanbul içi trafiği minimum düzeyde tutan bir bölgedir. Yükleme ve boşaltmayla birlikte Hadımköy – Ankara güzergahı toplam 8–12 saat arasında tamamlanmaktadır." }
                },
                {
                    "@@type": "Question",
                    "name": "Hadımköy'de hafta sonu taşıma imkânı var mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet, haftanın 7 günü hizmet sunuyoruz. OSB bölgesindeki taşımalar için işletme yönetimiyle araç giriş koordinasyonunu biz sağlıyoruz." }
                }
            ]
        }
    ]
}
</script>
}

