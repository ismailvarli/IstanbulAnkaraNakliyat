                            new { I="🛡️", T="Nakliyat Sigortası", A="Tüm eşyalarınız taşıma süresince sigorta kapsamındadır. Yazlıktaki nem görmüş veya uzun süre depolanan eşyalar için ek koruma önerilmektedir." },
                            new { I="🔍", T="Ücretsiz Keşif", A="Eksperimiz Şile adresinize gelir. Yazlık konut koşullarını ve erişim yolunu değerlendirerek sabit fiyat teklifi sunar." },
                            new { I="🔧", T="Söküm-Montaj Dahil", A="Karyola, gardırop ve yatak odası takımları sökülür; Ankara'daki yeni adresinizde kurulur. Montaj ücretsizdir." },
                            new { I="🚛", T="Uygun Araç Seçimi", A="Şile'nin bazı bölgelerindeki dar yollar için uygun araç boyutu keşif sonrası belirlenir. Ağva gibi dar yollu bölgeler için aktarma çözümü hazırlanır." },
                            new { I="💬", T="7/24 İletişim", A="Taşıma öncesi, sırası ve sonrasında her an ulaşabilirsiniz. Şile'nin uzak konumu nedeniyle taşıma günü anlık bilgi paylaşımı yapılmaktadır." },
                            new { I="💰", T="Şeffaf Fiyatlandırma", A="Keşif sonrası verilen fiyat değişmez. Şile'nin uzaklık faktörü fiyata nasıl yansıdığı önceden açıkça belirtilir." }
                        };
                    }
                    @foreach (var n in nedenler)
