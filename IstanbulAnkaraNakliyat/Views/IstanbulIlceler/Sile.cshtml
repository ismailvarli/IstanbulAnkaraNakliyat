@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Şile Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/sile-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Şile Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Şile, İstanbul",
            "description": "Şile ilçesinden Ankara'ya kapıdan kapıya, sigortalı evden eve taşıma ve yazlık kapama hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/sile-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Şile'den Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Şile'den Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında başlamaktadır. Şile'nin İstanbul merkezine uzaklığı (~70 km) göz önünde bulundurularak güzergah süresi planlamaya eklenir. Kesin fiyat ücretsiz keşif sonrası netleşir." }
                },
                {
                    "@@type": "Question",
                    "name": "Ağva bölgesine büyük nakliyat araçları girebiliyor mu?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Ağva'nın bazı dar köy yollarına ve nehir kenarındaki yazlık bölgelerine büyük TIR tipi araçlar giremeyebilir. Bu durumlarda eşyalar önce küçük bir araçla ana yola taşınır, ardından büyük nakliyat aracına aktarılır. Keşif aşamasında adres koordinatları incelenerek uygun araç boyutu belirlenir." }
                },
                {
                    "@@type": "Question",
                    "name": "Şile yazlıklarından eşya taşıma ne zaman yapılabilir?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Şile yazlıklarından Ankara'ya eşya taşıma yıl boyu yapılabilmektedir. Yaz sezonu sonunda (Eylül–Ekim) yazlığı kapatıp ana ikamete eşya taşıması en yoğun dönemdir. Bu dönemde önceden randevu alınması önerilir. Kış aylarında daha sakin bir süreç yaşandığından planlamak daha kolaydır." }
                },
                {
                    "@@type": "Question",
                    "name": "Şile – Ankara taşıması toplam kaç saat sürer?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Şile, İstanbul'un kuzeydoğusunda İstanbul merkeze yaklaşık 70 km uzaklıkta konumlanmaktadır. Şile'den İstanbul TEM bağlantısına geçiş yaklaşık 1–1,5 saat sürmekte, ardından Ankara yolu ~450 km'lik mesafeyi oluşturmaktadır. Yükleme ve boşaltmayla birlikte toplam taşıma süresi 12–16 saat olarak planlanmaktadır." }
                }
            ]
        }
    ]
}
</script>
}

