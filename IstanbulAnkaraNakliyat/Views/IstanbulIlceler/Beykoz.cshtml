                { "@@type": "ListItem", "position": 3, "name": "Beykoz Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/beykoz-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Beykoz Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Beykoz, İstanbul",
            "description": "Beykoz ilçesinden Ankara'ya kapıdan kapıya, sigortalı lüks ev taşıma hizmeti. Yalı, villa ve orman içi konutlardan özel güzergah planlamasıyla taşıma.",
            "url": "https://www.istanbulankaranakliyat.tr/beykoz-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Beykoz Riva veya Polonezköy'deki villalardan taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Beykoz'un orman içindeki Riva ve Polonezköy gibi uzak mahallelerindeki villa ve çiftlik evlerinden Ankara'ya nakliyat hizmeti veriyoruz. Bu bölgelere ulaşım için güzergah önceden planlanır; dar ve ormanlık yollarda geçebilecek uygun boyutta araç seçilir." }
                },
                {
                    "@@type": "Question",
                    "name": "Beykoz'a büyük araçlarla ulaşım mümkün mü?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Beykoz'un bazı bölgelerine — özellikle Riva, Polonezköy ve boğaz kıyısının çeşitli noktalarına — TIR veya büyük kamyon giremez. Bu nedenle eşyaların önce ara araçla ana yola taşınması gerekebilir. Ekibimiz, güzergahı önceden keşfederek en uygun araç kombinasyonunu belirler." }
                },
                {
                    "@@type": "Question",
                    "name": "Beykoz'dan Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Beykoz'dan Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında başlamaktadır. Yalı ve villalar için erişim güçlüğü ek maliyet doğurabileceğinden keşif sonrası sabit fiyat verilir." }
                },
                {
                    "@@type": "Question",
                    "name": "Beykoz yalı ve villalardaki antika/değerli eşyalar için özel ambalaj yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Beykoz'daki tarihi yalılar ve lüks villalarda sıkça karşılaştığımız antika mobilyalar, değerli tablolar, Türk halıları ve piyano gibi hassas eşyalar için özel köpük kalıp ambalaj, ahşap sandık ve sanat eseri sarmalama malzemeleri kullanıyoruz. Tüm bu eşyalar ek sigorta kapsamına dahil edilir." }
                }
            ]
        }
    ]
}
</script>
}

