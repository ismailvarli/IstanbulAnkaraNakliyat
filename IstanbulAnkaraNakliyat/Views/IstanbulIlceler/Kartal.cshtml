@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Kartal Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/kartal-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Kartal Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Kartal, İstanbul",
            "description": "Kartal ilçesinden Ankara'ya kapıdan kapıya, sigortalı evden eve ve kurumsal taşıma hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/kartal-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Kartal'dan Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Kartal'dan Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında değişmektedir. Kesin fiyat kat sayısı, asansör durumu ve eşya miktarına göre ücretsiz keşif sonrası belirlenir." }
                },
                {
                    "@@type": "Question",
                    "name": "Soğanlık sanayi bölgesinden kurumsal taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Soğanlık'taki sanayi sitesinden ofis, depo ve fabrika taşımaları yapıyoruz. Büyük tonajlı araçlarımız ve geniş kapasiteli ekibimizle kurumsal yükleri Ankara'ya güvenle taşıyoruz. Hafta sonu veya gece operasyonu ile iş sürekliliği korunur." }
                },
                {
                    "@@type": "Question",
                    "name": "Kartal'daki kentsel dönüşüm projelerinden taşıma deneyiminiz var mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Kartal'daki kentsel dönüşüm kapsamında yenilenen binalardaki taşımalarda deneyimliyiz. Hem yeni teslim edilen asansörlü rezidanslardan hem de yıkım öncesi eski binalardan taşıma yapabiliyoruz. Yıkım takvimini göz önünde bulundurarak acil taşıma planlaması da yapılabilmektedir." }
                },
                {
                    "@@type": "Question",
                    "name": "Kartal – Ankara arasında parça eşya taşıma mümkün mü?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Kartal'dan Ankara'ya parsiyel (parça eşya) taşıma yapıyoruz. Tek koltuk, beyaz eşya, birkaç koli veya küçük hacimli taşınma için parsiyel yük hizmetimizden yararlanabilirsiniz. Fiyat eşya hacmine ve ağırlığına göre belirlenir; aynı güzergahtaki diğer yüklerle birleştirilerek ekonomik çözüm sunulur." }
                }
            ]
        }
    ]
}
</script>
}

