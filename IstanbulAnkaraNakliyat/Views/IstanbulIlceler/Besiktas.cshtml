                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Beşiktaş Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/besiktas-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Beşiktaş Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Beşiktaş, İstanbul",
            "description": "Beşiktaş ilçesinden Ankara'ya kapıdan kapıya, sigortalı lüks ev ve kurumsal ofis taşıma hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/besiktas-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Bebek ve Ortaköy'deki dar Boğaz kıyısı sokaklarına araçla ulaşabiliyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Bebek ve Ortaköy'ün kıyı sokaklarında araç manevra alanı kısıtlıdır; bu nedenle taşımaları sabahın erken saatlerinde, trafik yoğunluğu oluşmadan başlatıyoruz. Gerektiğinde daha küçük boyutlu araçları ön taşıma için kullanarak eşyaları ana araca aktarıyoruz. Bölgedeki park yeri kısıtları ve olası belediye izinleri tarafımızca önceden ayarlanır." }
                },
                {
                    "@@type": "Question",
                    "name": "Levent ofis kulesinden kurumsal taşıma nasıl yapılıyor?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Levent iş kulelerinde taşıma büyük ölçüde hafta sonlarına programlanır; çünkü bina yönetimleri iş günleri boyunca yükleme rampasına ve servis asansörüne erişimi kısıtlar. Hafta sonu sabah erken saatte bina güvenliğiyle koordineli olarak araçlar yerleştirilir, arşiv, sunucu ve ofis mobilyaları özel ambalajla taşınır. Tüm bina koordinasyonunu biz yönetiriz." }
                },
                {
                    "@@type": "Question",
                    "name": "Beşiktaş'tan Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Beşiktaş'tan Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında başlamaktadır. Bebek ve Ortaköy gibi özel erişim koordinasyonu gereken bölgelerde ek planlama maliyeti söz konusu olabilir. Kesin fiyat ücretsiz keşif sonrası netleşir." }
                },
                {
                    "@@type": "Question",
                    "name": "Beşiktaş lüks evlerden antika ve değerli eşya taşıyabiliyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Bebek ve Ortaköy'deki lüks konutlardan antika mobilya, tablolar, heykeller, piyano ve koleksiyon eşyalarının taşınması için özel ambalaj malzemeleri (ahşap kasalar, köpük koruyucular, klimatize araç seçeneği) kullanıyoruz. Değerli eşyalar için ek nakliyat sigortası da sunulmaktadır." }
                }
            ]
        }
    ]
}
</script>
}

