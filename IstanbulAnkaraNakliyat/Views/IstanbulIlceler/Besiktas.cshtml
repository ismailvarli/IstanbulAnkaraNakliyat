                            new { I="🔍", T="Ücretsiz Keşif", A="Eksperimiz Beşiktaş adresinize gelir, erişim koşullarını ve değerli eşyaları yerinde değerlendirerek sabit fiyat sunar." },
                            new { I="🔧", T="Söküm-Montaj Dahil", A="Karyola, gardırop ve mobilya takımları sökülür; Ankara'daki yeni adresinizde kurulur. Montaj ücretsizdir." },
                            new { I="🚛", T="Modern Araç Filosu", A="Kapalı kasalı perde branda araçlarla eşyalarınız korunur. Dar sokaklara özel küçük araç seçeneği de mevcuttur." },
