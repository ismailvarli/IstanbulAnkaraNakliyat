@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Fatih Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/fatih-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Fatih Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Fatih, İstanbul",
            "description": "Fatih ilçesindeki tarihi yarımadadan Ankara'ya dar sokak deneyimli ekiple, antika eşya hassasiyetiyle kapıdan kapıya nakliyat hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/fatih-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Fatih'teki dar tarihi sokaklara büyük araçlarla girebiliyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Fatih'in Balat, Ayvansaray ve Fener gibi bölgelerindeki çok dar sokaklara büyük nakliyat kamyonları girememektedir. Bu durumlarda eşyalar küçük aktarma araçları ya da el taşımasıyla sokak başına taşınır, ardından büyük araca aktarılır. Keşif aşamasında adresinizin sokak genişliği değerlendirilir ve uygun çözüm planlanır." }
                },
                {
                    "@@type": "Question",
                    "name": "Fatih'ten Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Fatih'ten Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında başlamaktadır. Dar sokaklarda aktarma gerekiyorsa bu durum fiyata yansır; keşif aşamasında tüm kalemler yazılı olarak belirtilir." }
                },
                {
                    "@@type": "Question",
                    "name": "Balat ve Fener'deki restore edilmiş eski binalarda taşıma nasıl yapılıyor?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Balat ve Fener'deki restore binalarda genellikle dar ve dik merdivenler bulunmaktadır. Büyük mobilyalar bu sokaklarda ya pencere/balkon üzerinden vinçle ya da parçalara ayrılarak taşınmaktadır. Ekibimiz restore yapılarda bina bütünlüğüne zarar vermeden taşıma konusunda deneyimlidir; gereken tüm ekipman önceden hazırlanır." }
                },
                {
                    "@@type": "Question",
                    "name": "Fatih'teki antika ve değerli eşyalar için özel ambalaj hizmeti veriyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Fatih'teki antika mobilya, eski tablo ve kırılgan değerli eşyalar için özel ambalaj hizmeti sunuyoruz. Köpük dolgulu kutular, ahşap kasalar, koruyucu battaniye ve çok katlı balonlu naylon kullanılarak eşyalarınız 450 km'lik yolculuk süresince güvende tutulmaktadır." }
                },
                {
                    "@@type": "Question",
                    "name": "Fatih – Ankara taşıması kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Fatih – Ankara mesafesi yaklaşık 450 km'dir. Dar sokaklarda yükleme süresini göz önünde bulundurulduğunda yükleme, nakliye ve boşaltmayla birlikte toplam süre 10–14 saat arasında tamamlanmaktadır. Fatih'in tarihi yarımada konumu nedeniyle araç park koordinasyonu için sabah erken saatlerde hareket tercih edilir." }
                }
            ]
        }
    ]
}
</script>
}

