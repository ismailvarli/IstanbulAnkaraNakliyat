<!-- ANA İÇERİK -->
<section style="padding:64px 0;">
    <div class="container">
        <div class="row">

            <!-- Sol: Ana İçerik -->
            <div class="col-lg-8">

                <h2 style="margin-bottom:1rem;">Başakşehir'den Ankara'ya Nakliyat</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    <strong>Başakşehir</strong>, İstanbul'un Avrupa yakasında son yıllarda en çok dikkat çeken, planlı kentsel dönüşümün ve modern yaşam anlayışının simgesi haline gelen bir ilçedir. Kayaşehir ve Bahçeşehir mega konut projeleriyle, Altınşehir ve Şahintepe'deki düzenli site yapılarıyla Başakşehir; geniş bulvarları, yeşil koridorları, modern park alanları ve Şehir Hastanesine yakınlığıyla öne çıkar. Orta-üst gelir grubundan ailelerin tercih ettiği bu ilçede yaşam kalitesi yüksek, konut stoku büyük ölçüde yeni ve bakımlıdır. <strong>Başakşehir'den Ankara'ya nakliyat</strong> sürecinde bu yapısal avantajlar taşımayı ciddi ölçüde kolaylaştırmaktadır; modern binalar, büyük asansörler ve geniş otopark alanları profesyonel taşıma ekiplerinin çalışmasını hızlandırır.
                </p>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Başakşehir'in taşıma sürecindeki en belirgin avantajı, planlı yapılaşmanın getirdiği erişim kolaylığıdır. Kayaşehir ve Bahçeşehir'deki büyük sitelerde araç giriş yolları geniş, yükleme-boşaltma noktaları belirlenmiş ve servis asansörleri büyük mobilyaları kaldıracak kapasitededir. Altınşehir ile İspartakule'de kalitenin yüksek olduğu rezidans projelerinde site yönetimiyle önceden koordinasyon kurarak araç girişini ayarlıyoruz. Güvercintepe ve Şahintepe gibi daha küçük ölçekli mahallelerde bile cadde genişlikleri büyük nakliye araçlarının konuşlanmasına elvermektedir. TEM otoyoluna direkt bağlantı, İstanbul içi trafik kaybını en aza indirerek Ankara güzergahına çabuk çıkışı sağlar; bu da hem taşıma süresini hem de yakıt maliyetini optimize eder.
                </p>
                <p style="margin-bottom:2rem;line-height:1.9;color:var(--gray-700);">
                    <strong>Başakşehir Ankara nakliyat</strong> talebinin önemli bir bölümü sağlık sektörü çalışanlarından kaynaklanmaktadır; Şehir Hastanesi'nde görev yapan uzman hekimler ve sağlık personeli zaman zaman Ankara'ya naklen atandığında ya da daha uygun koşullar arayışında olduklarında ilk tercihleri arasında uzman ve güvenilir bir nakliyat firması yer almaktadır. Bunun yanı sıra devlet kurumlarındaki memurlar ve aileler de Başakşehir'den Ankara'ya sıkça taşınmaktadır. İstanbul Ankara Nakliyat olarak her profilde müşteriye özel ücretsiz keşif, sabit fiyat teklifi ve nakliyat sigortası güvencesiyle hizmet sunuyoruz. Eşyalarınız kapalı kasalı araçlarda balonlu naylon, streç film ve battaniye korumasıyla Ankara'daki yeni adresinize teslim edilir.
                </p>


                <figure style="margin:1.75rem 0 2rem;">
                    <img src="~/img/galeri/galeri8.webp" loading="lazy"
                         style="width:100%;border-radius:var(--radius-lg);object-fit:cover;max-height:380px;"
                         onerror="this.style.display='none'">
                </figure>
                <!-- HİZMET KAPSAMI -->
                <h2 style="margin-bottom:1.25rem;">Başakşehir'de Sunduğumuz Nakliyat Hizmetleri</h2>
                <div class="row" style="row-gap:1.25rem;margin-bottom:2.5rem;">
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏠</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Evden Eve Nakliyat</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Başakşehir'deki evinizden Ankara'nın istediğiniz semtine tam kapıdan kapıya taşıma. Kayaşehir, Bahçeşehir, İspartakule fark etmez — her adrese geliyoruz.
                            </p>
                            <a href="/evden-eve-nakliyat" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏢</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Ofis Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Başakşehir'deki iş yerinizi minimum iş kaybıyla Ankara'ya taşıyoruz. Hafta sonu veya gece taşıma seçeneğiyle operasyonel kesinti sıfıra iner.
                            </p>
                            <a href="/ofis-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">📦</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Parça Eşya Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Başakşehir'den Ankara'ya tek koltuk, kargo kutusu veya birkaç parça eşya gönderimi. Parsiyel yükle ekonomik ve hızlı çözüm.
                            </p>
                            <a href="/parca-esya-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🎁</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Ambalaj &amp; Paketleme</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Balonlu naylon, streç film, karton kutu ve köpük koruyucularla profesyonel ambalaj. Kırılgan elektronik ve değerli eşyalar için özel paketleme.
                            </p>
                            <a href="/ambalaj-hizmeti" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                </div>

                <!-- İLÇEYE ÖZGÜ -->
                <h2 style="margin-bottom:1rem;">Başakşehir Nakliyatında Bilmeniz Gerekenler</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Başakşehir'deki büyük ölçekli sitelerde taşıma günü için site yönetiminden önceden onay alınması gerekmektedir. Kayaşehir ve Bahçeşehir'deki sitelerde bu süreci biz yönetiyoruz; araç plakası ve taşıma saatini yönetime önceden bildirerek gerekli izni temin ediyoruz. Özellikle hafta sonu veya tatil dönemlerinde önceden bildirim yapılması çok önemlidir. İkitelli ve Ziya Gökalp mahallelerinde ise genellikle site dışı yapılar hâkimdir; bu bölgelerde araç park noktası belirleme konusunda da sizi yönlendiriyoruz.
                </p>
                <p style="margin-bottom:2.5rem;line-height:1.9;color:var(--gray-700);">
                    Başakşehir'den Ankara'ya taşınmanın arkasındaki en yaygın nedenler arasında iş değişikliği, kamu kurumu atamaları ve yaşam maliyeti hesapları öne çıkmaktadır. Başakşehir'deki yüksek kira bedellerine karşın Ankara'nın özellikle Çankaya, Keçiören ve Etimesgut gibi ilçelerinde benzer ya da daha geniş konutları çok daha uygun fiyatlara kiralamak mümkündür. İstanbul Ankara Nakliyat olarak bu taşınma kararını desteklemek için ücretsiz keşif, şeffaf fiyatlama ve sigortacılık hizmetleriyle profesyonel destek sunuyoruz.
                </p>

                <!-- SÜREÇ -->
                <h2 style="margin-bottom:1.5rem;">Başakşehir Nakliyat Sürecimiz</h2>
                <div style="margin-bottom:2.5rem;">
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">1</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Ücretsiz Keşif</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Uzman eksperimiz Başakşehir adresinize gelir. Bina tipi, kat durumu, asansör kapasitesi ve eşya miktarını yerinde değerlendirir. Keşif tamamen ücretsizdir.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">2</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sabit Fiyat Teklifi</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Tüm kalemleri (ambalaj, söküm, montaj, sigorta) kapsayan yazılı teklif verilir. Verilen fiyat değişmez; sürpriz fatura çıkmaz.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">3</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Profesyonel Ambalajlama</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Taşıma günü ekibimiz Başakşehir'e erken saatte gelir. Mobilyalar battaniye ve streç filmle, kırılganlar balonlu naylonla özenle paketlenir.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">4</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sigortalı Nakliye</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Eşyalarınız kapalı kasalı, sigortalı araçlara yüklenerek Ankara'ya hareket edilir. TEM'den çıkışla ~450 km mesafe ortalama 8–12 saatte tamamlanır.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">5</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Yerleştirme ve Montaj</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Ankara'daki yeni adresinizde eşyalar boşaltılır, sökülmüş mobilyalar monte edilir. İşlem tamamlanana kadar yanınızdayız.</p></div>
                    </div>
                </div>

                <!-- FİYAT -->
                <h2 style="margin-bottom:1rem;">Başakşehir – Ankara Nakliyat Fiyatları 2026</h2>
                <p style="color:var(--gray-600);margin-bottom:1.25rem;font-size:.95rem;">
                    Aşağıdaki fiyatlar referans niteliğindedir. Kesin fiyat keşif sonrası belirlenir.
                </p>
                <div class="price-table" style="margin-bottom:2.5rem;">
                    <div class="price-row price-row--header"><span>Daire / Hacim</span><span>Yaklaşık m³</span><span>Fiyat Aralığı</span></div>
                    <div class="price-row"><span>1+1 Daire</span><span>15–25 m³</span><span>8.000 – 14.000 ₺</span></div>
                    <div class="price-row"><span>2+1 Daire</span><span>25–40 m³</span><span>12.000 – 20.000 ₺</span></div>
                    <div class="price-row"><span>3+1 Daire</span><span>40–60 m³</span><span>16.000 – 26.000 ₺</span></div>
                    <div class="price-row"><span>4+1 / Villa</span><span>60–100+ m³</span><span>Keşif Sonrası</span></div>
                    <div class="price-row"><span>Ofis / İşyeri</span><span>Değişken</span><span>Keşif Sonrası</span></div>
                </div>

                <!-- MAHALLELER -->
                <div style="background:var(--gray-100);border-radius:var(--radius-lg);padding:1.75rem;margin-bottom:2.5rem;">
                    <h3 style="margin-bottom:.75rem;">Başakşehir Mahalleleri — Hizmet Bölgelerimiz</h3>
                    <p style="margin-bottom:1rem;font-size:.95rem;color:var(--gray-700);">
                        Başakşehir'in tüm mahallelerinde ücretsiz keşif yapıyor ve Ankara'ya nakliyat hizmeti sunuyoruz:
                    </p>
                    <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1rem;">
                        @foreach (var m in new[]{"Kayaşehir","Bahçeşehir","Altınşehir","Şahintepe","Güvercintepe","Başakşehir Merkez","Ziya Gökalp","İkitelli","İspartakule","Atatürk"})
                        {
                            <span style="background:var(--white);border:1px solid var(--gray-200);border-radius:50px;padding:.3rem .9rem;font-size:.82rem;font-weight:500;">@m</span>
                        }
                    </div>
                    <p style="font-size:.85rem;color:var(--gray-500);margin:0;">Mahalleniz listede olmasa da Başakşehir sınırları içindeki tüm adreslere hizmet veriyoruz.</p>
                </div>

                <!-- NEDEN BİZ -->
                <h2 style="margin-bottom:1.25rem;">Neden İstanbul Ankara Nakliyat?</h2>
                <div class="row" style="row-gap:1rem;margin-bottom:2.5rem;">
                    @{
                        var nedenler = new[] {
                            new { I="🛡️", T="Nakliyat Sigortası", A="Tüm eşyalarınız taşıma süresince sigorta kapsamındadır. Başakşehir'in modern sitelerindeki değerli eşyalar için ek sigorta da sunulmaktadır." },
                            new { I="🔍", T="Ücretsiz Keşif", A="Eksperimiz Başakşehir adresinize gelir, eşyaları yerinde değerlendirir ve sabit fiyat teklifi sunar. Site girişi ve asansör kapasitesi önceden planlanır." },
