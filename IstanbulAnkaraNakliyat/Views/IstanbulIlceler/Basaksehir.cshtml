@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "İstanbul Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-ankara-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Başakşehir Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/basaksehir-ankara-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Başakşehir Ankara Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Başakşehir, İstanbul",
            "description": "Başakşehir ilçesinden Ankara'ya kapıdan kapıya, sigortalı evden eve ve ofis taşıma hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/basaksehir-ankara-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Başakşehir'den Ankara'ya nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Başakşehir'den Ankara'ya nakliyat; 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–26.000 ₺ arasında başlamaktadır. Kesin fiyat kat sayısı, asansör durumu ve eşya miktarına göre ücretsiz keşif sonrası netleşir." }
                },
                {
                    "@@type": "Question",
                    "name": "Kayaşehir ve Bahçeşehir sitelerinden taşıma kolay mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Kayaşehir ve Bahçeşehir'deki modern konut projelerinde site girişleri geniş ve düzenli, asansörler büyük mobilya taşımaya uygundur. Site yönetimiyle araç girişini önceden koordine ediyoruz." }
                },
                {
                    "@@type": "Question",
                    "name": "Başakşehir – Ankara güzergahı kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Başakşehir, TEM otoyoluna direkt bağlantısı sayesinde İstanbul içi trafiği en aza indirerek Ankara güzergahına çıkar. Yükleme ve boşaltmayla birlikte toplam süre genellikle 8–12 saat arasında tamamlanır." }
                },
                {
                    "@@type": "Question",
                    "name": "Başakşehir'de hafta sonu taşıma imkânı var mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet, hafta sonu dahil haftanın 7 günü taşıma hizmeti sunuyoruz. Başakşehir'deki büyük sitelerde hafta sonu taşıma izni için site yönetimiyle iletişimi biz sağlarız." }
                }
            ]
        }
    ]
}
</script>
}

