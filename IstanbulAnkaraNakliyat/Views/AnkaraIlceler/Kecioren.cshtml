@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "Ankara İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/ankara-istanbul-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Keçiören İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/kecioren-istanbul-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Keçiören İstanbul Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Keçiören, Ankara",
            "description": "Keçiören ilçesinden İstanbul'a kapıdan kapıya, sigortalı evden eve ve parsiyel taşıma hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/kecioren-istanbul-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Keçiören dar sokaklardan nakliyat yapabiliyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Keçiören'in kuzey mahallelerindeki (Bağlum, Kalaba, Güçlükaya) dar ve eğimli sokaklarda taşıma konusunda deneyimliyiz. Büyük araçların giremediği sokaklarda daha küçük nakliye aracı veya aktarma yöntemiyle operasyon yürütülür." }
                },
                {
                    "@@type": "Question",
                    "name": "Keçiören'den İstanbul'a nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Keçiören'den İstanbul'a nakliyat; 1+1 daire için 7.500–13.500 ₺, 2+1 daire için 11.500–19.000 ₺, 3+1 daire için 15.500–25.000 ₺ arasında başlamaktadır. Kat sayısı, asansör durumu ve eşya miktarına göre kesin fiyat ücretsiz keşif sonrası netleşir." }
                },
                {
                    "@@type": "Question",
                    "name": "Keçiören – İstanbul arasında taşıma kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Keçiören – İstanbul mesafesi yaklaşık 450 km'dir. Yükleme, nakliye ve boşaltmayla birlikte toplam süre genellikle 8–12 saat arasında tamamlanır. Ankara çevre yoluna hızlı bağlantı avantajından yararlanarak TEM otoyoluna erken saatte çıkılır." }
                },
                {
                    "@@type": "Question",
                    "name": "Keçiören'den İstanbul'a parsiyel yük taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Az eşyayla taşınıyorsanız ya da belirli parçaları İstanbul'a göndermeniz gerekiyorsa parsiyel yük hizmeti sunuyoruz. Bu seçenekte eşyalarınız aynı güzergahtaki diğer yüklerle birleştirilir; maliyet ciddi ölçüde düşer. Keçiören'den İstanbul'a parsiyel gönderi için önce iletişime geçin." }
                }
            ]
        }
    ]
}
</script>
}

