<!-- ANA İÇERİK -->
<section style="padding:64px 0;">
    <div class="container">
        <div class="row">

            <!-- Sol: Ana İçerik -->
            <div class="col-lg-8">

                <h2 style="margin-bottom:1rem;">Keçiören'den İstanbul'a Nakliyat</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    <strong>Keçiören</strong>, nüfus bakımından Ankara'nın en büyük ilçesidir. Etlik'in geniş toplu konut alanları, Bağlum ve Kalaba'nın kuzey mahalleleri, Kuşcağız ve Aktepe'nin köklü semtleri ile Yıldıztepe ve Bağlarbaşı'nın yoğun konut dokusu ilçeye özgün bir çeşitlilik katmaktadır. Güçlü sosyal donatılar, yoğun hastane ve okul ağı ile ulaşım altyapısı açısından Ankara'nın en gelişmiş ilçelerinden biri olan Keçiören, İstanbul'a her yıl binlerce kişiyi uğurlayan bir geçiş noktasıdır. <strong>Keçiören'den İstanbul'a nakliyat</strong> sürecinde yıllar içinde birikmiş mahalle bazındaki saha deneyimimizle her adrese özgün çözümler üretiyoruz.
                </p>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Keçiören'de taşıma sürecinin en önemli teknik noktası mahalle topografyasıdır. Bağlum, Kalaba ve Güçlükaya gibi kuzey mahallelerinde eğimli arazi ve dar sokaklar, büyük kamyonların manevra alanını kısıtlar; bu tür bölgelerde daha küçük araçla ön yükleme yapılarak ana araca aktarma yöntemi uygulanır. Etlik'in TOKİ ve toplu konut projelerinde ise binalar modern ve geniş erişimli olduğundan yükleme süreci oldukça verimli ilerler. Ankara çevre yoluna hızlı bağlantı sağlayan Keçiören, TEM otoyoluna erken çıkış imkânı sunarak İstanbul'a ulaşım süresini optimize eder.
                </p>
                <p style="margin-bottom:2rem;line-height:1.9;color:var(--gray-700);">
                    <strong>Keçiören – İstanbul</strong> güzergahında iş ve kariyer hedefli taşınmalar en büyük dilimi oluşturmaktadır. Ekonomik segment konutların ağırlıklı olduğu bu ilçeden İstanbul'a taşınanlar arasında parsiyel yük hizmeti özellikle tercih edilmektedir; az sayıda eşyayla taşınıyorsanız ya da belirli parçaları göndermeniz gerekiyorsa aynı güzergahtaki diğer yüklerle birleştirilen parsiyel seçenek ciddi maliyet avantajı sağlar. Tüm eşyalar nakliyat sigortası güvencesi altında taşınır; kırılganlar balonlu naylon ve köpük paketle, mobilyalar battaniye ve streç filmle korunur. Ücretsiz keşif randevusu için hemen arayabilirsiniz.
                </p>


                <figure style="margin:1.75rem 0 2rem;">
                    <img src="~/img/galeri/galeri15.webp" loading="lazy"
                         style="width:100%;border-radius:var(--radius-lg);object-fit:cover;max-height:380px;"
                         onerror="this.style.display='none'">
                </figure>
                <!-- HİZMET KAPSAMI -->
                <h2 style="margin-bottom:1.25rem;">Keçiören'de Sunduğumuz Nakliyat Hizmetleri</h2>
                <div class="row" style="row-gap:1.25rem;margin-bottom:2.5rem;">
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏠</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Evden Eve Nakliyat</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Keçiören'deki evinizden İstanbul'un istediğiniz semtine kapıdan kapıya tam taşıma. Etlik, Bağlum, Aktepe fark etmez — her adrese geliyoruz.
                            </p>
                            <a href="/evden-eve-nakliyat" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">📦</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Parça Eşya / Parsiyel Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Keçiören'den İstanbul'a tek koltuk veya birkaç parça eşya gönderimi. Parsiyel yükle ekonomik çözüm; tam araç kiralama gerekmez.
                            </p>
                            <a href="/parca-esya-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🏢</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Ofis Taşıma</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Keçiören'deki iş yerinizi minimum iş kaybıyla İstanbul'a taşıyoruz. Hafta sonu ve gece taşıma seçeneğiyle operasyonel kesinti sıfıra iner.
                            </p>
                            <a href="/ofis-tasima" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="service-card" style="height:100%;padding:1.5rem;">
                            <div class="service-icon" aria-hidden="true" style="width:40px;height:40px;font-size:1.2rem;">🎁</div>
                            <h3 style="font-size:1rem;margin-bottom:.6rem;">Ambalaj &amp; Paketleme</h3>
                            <p style="font-size:.9rem;color:var(--gray-600);line-height:1.7;">
                                Balonlu naylon, streç film, karton kutu ve köpük koruyucularla profesyonel ambalaj. Dar merdivenlerde indirilecek eşyalar için özel paketleme.
                            </p>
                            <a href="/ambalaj-hizmeti" style="font-size:.85rem;font-weight:600;margin-top:.75rem;display:inline-block;">Detaylı Bilgi →</a>
                        </div>
                    </div>
                </div>

                <!-- İLÇEYE ÖZGÜ -->
                <h2 style="margin-bottom:1rem;">Keçiören Nakliyatında Bilmeniz Gerekenler</h2>
                <p style="margin-bottom:1.25rem;line-height:1.9;color:var(--gray-700);">
                    Keçiören'de taşıma aracı park yeri ve yükleme noktası planlaması, ilçenin heterojen coğrafyası nedeniyle titizlik gerektirir. Etlik'teki geniş caddeli toplu konut bloklarında araç park ve yükleme oldukça pratikken, Bağlum ve Kalaba'nın kuzey kesimlerinde eğimli ve dar sokaklara uyum sağlayan küçük yardımcı araçlarla ön taşıma yapılır. Bu aktarma süreci ek süre gerektirse de eşyaların güvenliğini kesinlikle ön planda tutar; ekibimiz bu tür operasyonlarda deneyimlidir. Yıldıztepe ve Bağlarbaşı'nın yoğun konut dokusunda sabah erken saatte başlanan yüklemeler trafik avantajıyla hem zaman kazandırır hem de komşulara rahatsızlık vermez.
                </p>
                <p style="margin-bottom:2.5rem;line-height:1.9;color:var(--gray-700);">
                    Keçiören'den İstanbul'a taşınmanın temel motivasyonu büyük ölçüde iş ve kariyer fırsatlarıdır. İstanbul'un sunduğu çeşitli istihdam olanakları ve daha yüksek ücret beklentisiyle taşınanların yanı sıra eğitim, aile birleşimi ve yaşam tarzı değişikliği de sık karşılaşılan gerekçeler arasındadır. Az eşyayla taşınanlar için parsiyel yük çözümümüz, hem bütçe hem de zaman açısından en verimli seçeneği sunar. Tek seferlik ücretsiz keşif randevusu alarak taşıma maliyetinizi önceden netleştirin.
                </p>

                <!-- SÜREÇ -->
                <h2 style="margin-bottom:1.5rem;">Keçiören Nakliyat Sürecimiz</h2>
                <div style="margin-bottom:2.5rem;">
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">1</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Ücretsiz Keşif</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Uzman eksperimiz Keçiören adresinize gelir. Mahalle yapısı, bina tipi, kat durumu ve eşya miktarını yerinde değerlendirir. Keşif tamamen ücretsizdir.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">2</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sabit Fiyat Teklifi</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Tüm kalemleri (ambalaj, söküm, montaj, sigorta) kapsayan yazılı teklif verilir. Verilen fiyat değişmez; sürpriz fatura çıkmaz.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">3</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Profesyonel Ambalajlama</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Taşıma günü ekibimiz Keçiören'e erken saatte gelir. Mobilyalar battaniye ve streç filmle, kırılganlar balonlu naylonla özenle paketlenir.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;margin-bottom:1.5rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">4</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Sigortalı Nakliye</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">Eşyalarınız kapalı kasalı, sigortalı araçlara yüklenerek İstanbul'a hareket edilir. ~450 km mesafe ortalama 8–12 saatte tamamlanır.</p></div>
                    </div>
                    <div style="display:flex;gap:1.25rem;align-items:flex-start;">
                        <div style="flex-shrink:0;width:40px;height:40px;background:var(--black);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.95rem;">5</div>
                        <div><h3 style="font-size:1rem;margin-bottom:.4rem;">Yerleştirme ve Montaj</h3><p style="font-size:.92rem;color:var(--gray-600);line-height:1.75;margin:0;">İstanbul'daki yeni adresinizde eşyalar boşaltılır, sökülmüş mobilyalar monte edilir. İşlem tamamlanana kadar yanınızdayız.</p></div>
                    </div>
                </div>

                <!-- FİYAT -->
                <h2 style="margin-bottom:1rem;">Keçiören – İstanbul Nakliyat Fiyatları 2026</h2>
                <p style="color:var(--gray-600);margin-bottom:1.25rem;font-size:.95rem;">
                    Aşağıdaki fiyatlar referans niteliğindedir. Kesin fiyat keşif sonrası belirlenir.
                </p>
                <div class="price-table" style="margin-bottom:2.5rem;">
                    <div class="price-row price-row--header"><span>Daire / Hacim</span><span>Yaklaşık m³</span><span>Fiyat Aralığı</span></div>
                    <div class="price-row"><span>1+1 Daire</span><span>15–25 m³</span><span>7.500 – 13.500 ₺</span></div>
                    <div class="price-row"><span>2+1 Daire</span><span>25–40 m³</span><span>11.500 – 19.000 ₺</span></div>
                    <div class="price-row"><span>3+1 Daire</span><span>40–60 m³</span><span>15.500 – 25.000 ₺</span></div>
                    <div class="price-row"><span>4+1 / Villa</span><span>60–100+ m³</span><span>Keşif Sonrası</span></div>
                    <div class="price-row"><span>Parsiyel Yük</span><span>Değişken</span><span>Keşif Sonrası</span></div>
                </div>

                <!-- MAHALLELER -->
                <div style="background:var(--gray-100);border-radius:var(--radius-lg);padding:1.75rem;margin-bottom:2.5rem;">
                    <h3 style="margin-bottom:.75rem;">Keçiören Mahalleleri — Hizmet Bölgelerimiz</h3>
                    <p style="margin-bottom:1rem;font-size:.95rem;color:var(--gray-700);">
                        Keçiören'in tüm mahallelerinde ücretsiz keşif yapıyor ve İstanbul'a nakliyat hizmeti sunuyoruz:
                    </p>
                    <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1rem;">
                        @foreach (var m in new[]{"Etlik","Bağlum","Kalaba","Kuşcağız","Aktepe","Yıldıztepe","Bağlarbaşı","Güçlükaya","Ovacık"})
                        {
                            <span style="background:var(--white);border:1px solid var(--gray-200);border-radius:50px;padding:.3rem .9rem;font-size:.82rem;font-weight:500;">@m</span>
                        }
                    </div>
                    <p style="font-size:.85rem;color:var(--gray-500);margin:0;">Mahalleniz listede olmasa da Keçiören sınırları içindeki tüm adreslere hizmet veriyoruz.</p>
                </div>

                <!-- NEDEN BİZ -->
                <h2 style="margin-bottom:1.25rem;">Neden İstanbul Ankara Nakliyat?</h2>
                <div class="row" style="row-gap:1rem;margin-bottom:2.5rem;">
                    @{
                        var nedenler = new[] {
                            new { I="🛡️", T="Nakliyat Sigortası", A="Keçiören'den İstanbul'a taşınan tüm eşyalarınız sigorta kapsamındadır. Değerli eşyalar için ek sigorta seçeneği de sunulmaktadır." },
                            new { I="🔍", T="Ücretsiz Keşif", A="Eksperimiz Keçiören adresinize gelir, mahalle ve bina koşullarını yerinde değerlendirir, sabit fiyat teklifi sunar." },
