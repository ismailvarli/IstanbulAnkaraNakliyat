@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "Ankara İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/ankara-istanbul-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Ayaş İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/ayas-istanbul-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Ayaş İstanbul Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Ayaş, Ankara",
            "description": "Ayaş ilçesinden İstanbul'a kapıdan kapıya, üzüm bağı ve bağ evi taşımalarında uzman nakliyat hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/ayas-istanbul-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Ayaş'tan İstanbul'a nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "1+1 daire için 8.000–14.000 ₺, 2+1 için 12.000–20.000 ₺, 3+1 için 16.000–26.000 ₺. Bağ evi ve kırsal bölgeler için keşif sonrası fiyat belirlenir." }
                },
                {
                    "@@type": "Question",
                    "name": "Ayaş'taki bağ evinden İstanbul'a taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Ayaş'taki bağ evleri ve üzüm bağı mülklerinden İstanbul'a taşıma hizmeti verilmektedir. Kırsal yollar için uygun araç seçimi yapılır." }
                },
                {
                    "@@type": "Question",
                    "name": "Ayaş'tan İstanbul'a taşıma kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Ayaş'tan İstanbul'a yükleme, nakliye ve boşaltma dahil 9–12 saatte tamamlanır." }
                },
                {
                    "@@type": "Question",
                    "name": "Parsiyel yük hizmetiniz var mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Bağ evi ve az eşyayla İstanbul'a taşınmak isteyenler için parsiyel yük hizmetimiz mevcuttur." }
                }
            ]
        }
    ]
}
</script>
}

