@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "Ankara İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/ankara-istanbul-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Kızılcahamam İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/kizilcahamam-istanbul-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Kızılcahamam İstanbul Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Kızılcahamam, Ankara",
            "description": "Kızılcahamam ilçesinden İstanbul'a kapıdan kapıya, kaplıca ve yazlık konut taşımalarında uzman nakliyat hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/kizilcahamam-istanbul-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Kızılcahamam'dan İstanbul'a nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "1+1 daire için 8.000–14.000 ₺, 2+1 için 12.000–20.000 ₺, 3+1 için 16.000–26.000 ₺. Yazlık konutlar ve kırsal bölgeler için keşif sonrası fiyat belirlenir." }
                },
                {
                    "@@type": "Question",
                    "name": "Kızılcahamam'daki yazlık konuttan İstanbul'a taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Kızılcahamam'daki yazlık konutlar ve termal bölgedeki tüm konutlardan İstanbul'a taşıma hizmeti verilmektedir." }
                },
                {
                    "@@type": "Question",
                    "name": "Kızılcahamam'dan İstanbul'a taşıma kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Kızılcahamam'dan İstanbul'a yükleme, nakliye ve boşaltma dahil 10–13 saatte tamamlanır." }
                },
                {
                    "@@type": "Question",
                    "name": "Parsiyel yük hizmetiniz var mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Az eşyayla İstanbul'a taşınmak isteyenler için parsiyel yük hizmetimiz mevcuttur. Yazlık eşya taşımalarında sıkça tercih edilir." }
                }
            ]
        }
    ]
}
</script>
}

