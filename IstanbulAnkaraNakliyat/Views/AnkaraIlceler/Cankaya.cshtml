@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "Ankara İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/ankara-istanbul-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Çankaya İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/cankaya-istanbul-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Çankaya İstanbul Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Çankaya, Ankara",
            "description": "Çankaya ilçesinden İstanbul'a kapıdan kapıya, sigortalı evden eve ve ofis taşıma hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/cankaya-istanbul-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Çankaya'dan İstanbul'a nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Çankaya'dan İstanbul'a nakliyat; 1+1 daire için 7.500–13.500 ₺, 2+1 daire için 11.500–19.000 ₺, 3+1 daire için 15.500–25.000 ₺ arasında başlamaktadır. Kesin fiyat kat sayısı, asansör durumu ve eşya miktarına göre ücretsiz keşif sonrası netleşir." }
                },
                {
                    "@@type": "Question",
                    "name": "Kavaklidere'deki eski konutlardan taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Kavaklidere'nin asansörsüz ve dar merdiveni olan eski apartmanlarında taşıma konusunda deneyimliyiz. Dar boşluklarda yeterli personel ve özel ekipman kullanarak büyük mobilyaları güvenle indiriyoruz. Gerektiğinde balkon veya pencere yoluyla taşıma da yapılmaktadır." }
                },
                {
                    "@@type": "Question",
                    "name": "Çankaya – İstanbul arasında taşıma kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Çankaya – İstanbul mesafesi yaklaşık 450 km'dir. Yükleme, nakliye ve boşaltmayla birlikte toplam süre genellikle 8–12 saat arasında tamamlanır. Ankara çıkışı için Eskişehir yolu veya Konya yolu güzergahına göre planlama yapılır." }
                },
                {
                    "@@type": "Question",
                    "name": "Oran ve Balgat'ın güvenlikli sitelerinden taşıma için önceden koordinasyon gerekiyor mu?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Oran ve Balgat'taki kapalı ve güvenlikli sitelerde araç ve personel girişi için site yönetimiyle önceden iletişim kurulması gerekir. Bu koordinasyonu biz üstleniyoruz; servis asansörü rezervasyonu ve güvenlik prosedürleri taşıma günü öncesinde ayarlanır." }
                },
                {
                    "@@type": "Question",
                    "name": "Çankaya ofislerinden İstanbul'a kurumsal taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Çukurambar ve Balgat'taki rezidans ofisler ile Kızılay'daki ticari binalarda kurumsal taşıma gerçekleştiriyoruz. Hafta sonu veya gece taşıma seçeneğiyle iş operasyonlarınızın aksaması önlenir. Sunucu odaları, arşiv dolapları ve ofis mobilyaları için özel ekipman kullanılır." }
                }
            ]
        }
    ]
}
</script>
}

