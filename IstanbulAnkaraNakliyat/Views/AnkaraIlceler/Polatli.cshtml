@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "Ankara İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/ankara-istanbul-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Polatlı İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/polatli-istanbul-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Polatlı İstanbul Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Polatlı, Ankara",
            "description": "Polatlı ilçesinden İstanbul'a kapıdan kapıya, sigortalı evden eve nakliyat hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/polatli-istanbul-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Polatlı'dan İstanbul'a nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "1+1 daire için 8.000–14.000 ₺, 2+1 için 12.000–20.000 ₺, 3+1 için 16.000–26.000 ₺. Kırsal bölge ve köy mahallelerinde ek erişim ücreti olabilir." }
                },
                {
                    "@@type": "Question",
                    "name": "Polatlı'dan İstanbul'a taşıma kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Polatlı, İstanbul karayoluna yakın olduğundan yükleme, nakliye ve boşaltma dahil 9–12 saatte tamamlanır." }
                },
                {
                    "@@type": "Question",
                    "name": "Polatlı köylerinden taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Polatlı'ya bağlı kırsal mahalle ve köylerden de taşıma hizmeti verilmektedir. Dar yollar için uygun araç seçimi yapılır." }
                },
                {
                    "@@type": "Question",
                    "name": "Parsiyel yük hizmetiniz var mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Az eşya taşımak isteyenler için parsiyel yük hizmetimiz mevcuttur. Ekonomik fiyatlarla İstanbul'a taşıma imkânı sağlanır." }
                }
            ]
        }
    ]
}
</script>
}

