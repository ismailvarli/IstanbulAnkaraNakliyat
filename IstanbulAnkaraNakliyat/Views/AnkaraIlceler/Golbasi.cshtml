@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "Ankara İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/ankara-istanbul-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Gölbaşı İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/golbasi-istanbul-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Gölbaşı İstanbul Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Gölbaşı, Ankara",
            "description": "Gölbaşı ilçesinden İstanbul'a kapıdan kapıya, sigortalı evden eve ve villa taşıma hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/golbasi-istanbul-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Gölbaşı'ndan İstanbul'a nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "1+1 daire için 8.000–14.000 ₺, 2+1 için 12.000–20.000 ₺, 3+1 için 16.000–26.000 ₺. Villa ve büyük konutlar için ücretsiz keşif sonrası fiyat belirlenir." }
                },
                {
                    "@@type": "Question",
                    "name": "İncek ve Bağlıca sitelerinden taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. İncek, Bağlıca ve Gölbaşı'ndaki tüm sitelerden ve villa bölgelerinden taşıma hizmeti sunmaktayız." }
                },
                {
                    "@@type": "Question",
                    "name": "Gölbaşı'ndan İstanbul'a taşıma kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Gölbaşı merkez ve Ankara güney çıkışından İstanbul'a yükleme, nakliye ve boşaltma dahil 10–13 saatte tamamlanır." }
                },
                {
                    "@@type": "Question",
                    "name": "Villadan İstanbul'a taşıma için özel hizmet var mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Villa taşımalarında tüm mobilya söküm-montaj, özel ambalajlama ve sigorta hizmetleri dahil kapsamlı paket sunulmaktadır." }
                }
            ]
        }
    ]
}
</script>
}

<nav aria-label="breadcrumb" style="background:var(--gray-100);padding:10px 0;">
    <div class="container">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/">Ana Sayfa</a></li>
            <li class="breadcrumb-item"><a href="/ankara-istanbul-nakliyat">Ankara İstanbul Nakliyat</a></li>
            <li class="breadcrumb-item active">Gölbaşı İstanbul Nakliyat</li>
        </ol>
    </div>
</nav>

<div class="page-header" style="background:var(--black);color:#fff;padding:60px 0 40px;">
    <div class="container">
        <h1 style="font-size:2.2rem;font-weight:700;margin-bottom:16px;">Gölbaşı İstanbul Nakliyat</h1>
        <p style="font-size:1.1rem;opacity:.85;max-width:640px;">Mogan ve Eymir gölleri kıyısındaki yeşil ilçeden İstanbul'a, villa deneyimli profesyonel taşıma hizmeti.</p>
        <div style="margin-top:28px;display:flex;gap:16px;flex-wrap:wrap;">
            <a href="tel:05325436837" style="background:#fff;color:var(--black);padding:12px 28px;border-radius:6px;font-weight:700;text-decoration:none;">📞 0532 543 68 37</a>
            <a href="https://wa.me/905325436837" target="_blank" style="background:#25D366;color:#fff;padding:12px 28px;border-radius:6px;font-weight:700;text-decoration:none;">WhatsApp</a>
        </div>
    </div>
</div>

<div style="background:var(--gray-100);padding:20px 0;border-bottom:1px solid #e0e0e0;">
    <div class="container">
        <div class="row text-center g-3">
            <div class="col-6 col-md-2-4">
                <div style="font-size:1.5rem;font-weight:700;color:var(--black);">~450 km</div>
                <div style="font-size:.82rem;color:#555;">Ankara–İstanbul Mesafe</div>
            </div>
            <div class="col-6 col-md-2-4">
                <div style="font-size:1.5rem;font-weight:700;color:var(--black);">10–13 Saat</div>
                <div style="font-size:.82rem;color:#555;">Ortalama Taşıma Süresi</div>
            </div>
            <div class="col-6 col-md-2-4">
                <div style="font-size:1.5rem;font-weight:700;color:var(--black);">Sigortalı</div>
                <div style="font-size:.82rem;color:#555;">Tüm Eşyalar Güvende</div>
            </div>
            <div class="col-6 col-md-2-4">
                <div style="font-size:1.5rem;font-weight:700;color:var(--black);">Kapıdan</div>
                <div style="font-size:.82rem;color:#555;">Kapıya Hizmet</div>
            </div>
            <div class="col-6 col-md-2-4">
                <div style="font-size:1.5rem;font-weight:700;color:var(--black);">7/24</div>
                <div style="font-size:.82rem;color:#555;">Müşteri Desteği</div>

                <div style="border:1px solid #e0e0e0;border-radius:10px;padding:24px;">
                    <h4 style="font-size:1rem;font-weight:700;margin-bottom:12px;">Maliyet Hesapla</h4>
                    <p style="font-size:.88rem;color:var(--gray-600);margin-bottom:.75rem;">Taşıma maliyetinizi anında hesaplayın.</p>
                    <a href="/nakliyat-maliyet-hesaplayici" style="display:block;background:var(--black);color:#fff;text-align:center;padding:10px;border-radius:6px;font-weight:600;text-decoration:none;font-size:.88rem;">🧮 Hesaplayıcıyı Aç →</a>
                </div>

                <div style="border:1px solid #e0e0e0;border-radius:10px;padding:24px;">
                    <h4 style="font-size:1rem;font-weight:700;margin-bottom:12px;">Müşteri Yorumları</h4>
                    <p style="font-size:.88rem;color:var(--gray-600);margin-bottom:.75rem;">Gerçek müşterilerimizin deneyimlerini okuyun.</p>
                    <a href="/yorumlar" style="display:block;background:var(--black);color:#fff;text-align:center;padding:10px;border-radius:6px;font-weight:600;text-decoration:none;font-size:.88rem;">⭐ Yorumları Gör →</a>
                </div>

            </div>
