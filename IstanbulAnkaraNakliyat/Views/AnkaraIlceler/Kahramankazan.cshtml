@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "Ankara İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/ankara-istanbul-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Kahramankazan İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/kahramankazan-istanbul-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Kahramankazan İstanbul Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Kahramankazan, Ankara",
            "description": "Kahramankazan ilçesinden İstanbul'a kapıdan kapıya, OSB sanayi ve konut bölgelerine özel kurumsal ve bireysel nakliyat hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/kahramankazan-istanbul-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Kahramankazan'dan İstanbul'a nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "1+1 daire için 8.000–14.000 ₺, 2+1 için 12.000–20.000 ₺, 3+1 için 16.000–26.000 ₺. Kurumsal ve OSB taşımaları için özel fiyat belirlenir." }
                },
                {
                    "@@type": "Question",
                    "name": "Kahramankazan OSB'den İstanbul'a kurumsal taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Kahramankazan Organize Sanayi Bölgesi'ndeki fabrika ve iş yerlerinden İstanbul'a kurumsal taşıma hizmeti sunmaktayız." }
                },
                {
                    "@@type": "Question",
                    "name": "Kahramankazan'dan İstanbul'a taşıma kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Kahramankazan TEM bağlantısına yakın olduğundan yükleme, nakliye ve boşaltma dahil 9–12 saatte tamamlanır." }
                },
                {
                    "@@type": "Question",
                    "name": "Kahramankazan yeni konut sitelerinden taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Kahramankazan'ın yeni gelişen konut sitelerinden İstanbul'a kapıdan kapıya ev taşıma hizmeti verilmektedir." }
                }
            ]
        }
    ]
}
</script>
}

<nav aria-label="breadcrumb" style="background:var(--gray-100);padding:10px 0;">
    <div class="container">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/">Ana Sayfa</a></li>
            <li class="breadcrumb-item"><a href="/ankara-istanbul-nakliyat">Ankara İstanbul Nakliyat</a></li>
            <li class="breadcrumb-item active">Kahramankazan İstanbul Nakliyat</li>
        </ol>
    </div>
</nav>

<div class="page-header" style="background:var(--black);color:#fff;padding:60px 0 40px;">
    <div class="container">
        <h1 style="font-size:2.2rem;font-weight:700;margin-bottom:16px;">Kahramankazan İstanbul Nakliyat</h1>
        <p style="font-size:1.1rem;opacity:.85;max-width:640px;">OSB sanayi ve modern konut bölgelerinin bir arada bulunduğu Kahramankazan'dan İstanbul'a, kurumsal ve bireysel nakliyat hizmeti.</p>
        <div style="margin-top:28px;display:flex;gap:16px;flex-wrap:wrap;">
            <a href="tel:05325436837" style="background:#fff;color:var(--black);padding:12px 28px;border-radius:6px;font-weight:700;text-decoration:none;">📞 0532 543 68 37</a>
            <a href="https://wa.me/905325436837" target="_blank" style="background:#25D366;color:#fff;padding:12px 28px;border-radius:6px;font-weight:700;text-decoration:none;">WhatsApp</a>
        </div>
    </div>
</div>

<div style="background:var(--gray-100);padding:20px 0;border-bottom:1px solid #e0e0e0;">
    <div class="container">
        <div class="row text-center g-3">
            <div class="col-6 col-md-2-4">
                <div style="font-size:1.5rem;font-weight:700;color:var(--black);">~430 km</div>
                <div style="font-size:.82rem;color:#555;">Ankara–İstanbul Mesafe</div>
            </div>
            <div class="col-6 col-md-2-4">
                <div style="font-size:1.5rem;font-weight:700;color:var(--black);">9–12 Saat</div>
                <div style="font-size:.82rem;color:#555;">Ortalama Taşıma Süresi</div>
            </div>
            <div class="col-6 col-md-2-4">
                <div style="font-size:1.5rem;font-weight:700;color:var(--black);">Sigortalı</div>
                <div style="font-size:.82rem;color:#555;">Tüm Eşyalar Güvende</div>
            </div>
            <div class="col-6 col-md-2-4">
                <div style="font-size:1.5rem;font-weight:700;color:var(--black);">Kapıdan</div>
                <div style="font-size:.82rem;color:#555;">Kapıya Hizmet</div>
            </div>
            <div class="col-6 col-md-2-4">
                <div style="font-size:1.5rem;font-weight:700;color:var(--black);">7/24</div>
                <div style="font-size:.82rem;color:#555;">Müşteri Desteği</div>
            </div>
        </div>
    </div>
</div>

<div class="container" style="padding:60px 15px;">
    <div class="row g-5">
        <div class="col-lg-8">

            <h2 style="font-size:1.6rem;font-weight:700;margin-bottom:20px;">Kahramankazan'dan İstanbul'a Nakliyat</h2>
            <p>Kahramankazan, Ankara'nın kuzeybatısında yer alan ve Organize Sanayi Bölgesi (OSB) ile modern konut sitelerinin iç içe geliştiği dinamik bir ilçedir. TEM Otoyolu'na yakın konumu, İstanbul güzergahına hızlı çıkış imkânı sağlamaktadır. OSB'deki fabrika ve iş yerlerinden kurumsal taşıma ile ilçenin konut bölgelerinden bireysel ev taşıma hizmeti sunmaktayız.</p>
            <p>Kahramankazan'ın modern site yapısı, geniş araç erişimine uygun altyapısıyla yükleme süreçlerini kolaylaştırmaktadır. Sanayi bölgesindeki ofis ve üretim tesislerinden İstanbul'a taşıma için özel planlama ve büyük tonajlı araçlar kullanılmaktadır. Tüm taşımalarda nakliyat sigortası standarttır.</p>


            <figure style="margin:1.75rem 0 2rem;">
                <img src="~/img/galeri/galeri13.jpeg" loading="lazy"
                     style="width:100%;border-radius:var(--radius-lg);object-fit:cover;max-height:380px;"
                     onerror="this.style.display='none'">
            </figure>
            <h3 style="font-size:1.25rem;font-weight:700;margin:36px 0 16px;">Hizmetlerimiz</h3>
            <div class="row g-3">
                @foreach (var s in new[] {
                    new { I="🏭", T="OSB / Sanayi Taşıma", A="Kahramankazan OSB'deki fabrika ve iş yerlerinden İstanbul'a kurumsal taşıma." },
                    new { I="🏢", T="Ofis Taşıma", A="Kurumsal ofis ve işyerlerinden İstanbul'a planlı ve hızlı taşıma hizmeti." },
                    new { I="🏠", T="Evden Eve Nakliyat", A="Kahramankazan konut sitelerinden İstanbul'a kapıdan kapıya taşıma." },
                    new { I="🔧", T="Söküm-Montaj", A="Tüm mobilya ve beyaz eşyalarda söküm ve montaj hizmeti dahildir." },
                    new { I="📦", T="Parsiyel Yük", A="Az eşya taşımalarında ekonomik parsiyel yük seçeneği sunulmaktadır." },
                    new { I="🛡️", T="Sigortalı Taşıma", A="Nakliyat sigortasıyla tüm eşyalarınız güvence altındadır." }
                })
                {
                    <div class="col-md-6">
                        <div class="service-card" style="border:1px solid #e0e0e0;border-radius:8px;padding:20px;height:100%;">
                            <div class="service-icon" style="font-size:2rem;margin-bottom:10px;">@s.I</div>
                            <h4 style="font-size:1rem;font-weight:700;margin-bottom:8px;">@s.T</h4>
                            <p style="font-size:.9rem;color:#555;margin:0;">@s.A</p>
                        </div>
                    </div>
                }
            </div>

            <h3 style="font-size:1.25rem;font-weight:700;margin:36px 0 16px;">Taşıma Süreci</h3>
            <div style="counter-reset:steps;">
                @foreach (var step in new[] {
                    "Ücretsiz keşif için randevu alınır; konut veya OSB adresi değerlendirilir.",
                    "Taşıma günü ve fiyat netleştirilir, sözleşme imzalanır.",
                    "Profesyonel ekip eşyaları paketler ve araca yükler.",
                    "İstanbul'a hareket edilir, güzergah boyunca takip sağlanır.",
                    "İstanbul'daki yeni adresinizde eşyalar boşaltılır ve yerleştirilir."
                })
                {
                    <div style="display:flex;gap:16px;margin-bottom:16px;align-items:flex-start;">
                        <div style="background:var(--black);color:#fff;border-radius:50%;width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0;">@(Array.IndexOf(new[]{"Ücretsiz keşif için randevu alınır; konut veya OSB adresi değerlendirilir.","Taşıma günü ve fiyat netleştirilir, sözleşme imzalanır.","Profesyonel ekip eşyaları paketler ve araca yükler.","İstanbul'a hareket edilir, güzergah boyunca takip sağlanır.","İstanbul'daki yeni adresinizde eşyalar boşaltılır ve yerleştirilir."},step)+1)</div>
                        <p style="margin:0;padding-top:4px;">@step</p>
                    </div>
                }
            </div>

            <h3 style="font-size:1.25rem;font-weight:700;margin:36px 0 16px;">Fiyat Tablosu</h3>
            <div class="price-table" style="border:1px solid #e0e0e0;border-radius:8px;overflow:hidden;">
                <div class="price-row price-row--header" style="display:grid;grid-template-columns:1fr 1fr 1fr;background:var(--black);color:#fff;padding:12px 16px;font-weight:700;">
                    <span>Konut Tipi</span><span>Hacim</span><span>Fiyat Aralığı</span>
                </div>
                @foreach (var r in new[] {
                    new { T="1+1 Daire", H="15–25 m³", F="8.000–14.000 ₺" },
                    new { T="2+1 Daire", H="25–40 m³", F="12.000–20.000 ₺" },
                    new { T="3+1 Daire", H="40–60 m³", F="16.000–26.000 ₺" },
                    new { T="4+1 / Villa", H="60–100+ m³", F="Keşif Sonrası" },
                    new { T="Ofis / İşyeri", H="Değişken", F="Keşif Sonrası" }
                })
                {
                    <div class="price-row" style="display:grid;grid-template-columns:1fr 1fr 1fr;padding:12px 16px;border-top:1px solid #e0e0e0;">
                        <span>@r.T</span><span>@r.H</span><span style="font-weight:600;">@r.F</span>
                    </div>
                }
            </div>
            <p style="font-size:.85rem;color:#777;margin-top:8px;">* Fiyatlar yaklaşık olup keşif sonrası kesinleşir. KDV dahildir.</p>

            <h3 style="font-size:1.25rem;font-weight:700;margin:36px 0 16px;">Hizmet Verilen Mahalleler</h3>
            <div style="display:flex;flex-wrap:wrap;gap:8px;">
                @foreach (var m in new[] { "Kazan Merkez", "OSB Bölgesi", "Fatih", "Cumhuriyet", "İnönü", "Yenidoğan", "Karacaören", "Çiğdem", "Yeşilköy", "Bağlıca", "Saray", "İstiklal" })
                {
                    <span style="background:var(--gray-100);padding:6px 14px;border-radius:20px;font-size:.88rem;">@m</span>
                }
            </div>

            <h3 style="font-size:1.25rem;font-weight:700;margin:36px 0 16px;">Bilmeniz Gerekenler</h3>
            <p>Kahramankazan OSB'deki kurumsal taşımalar için önceden detaylı planlama yapılması, iş sürekliliğinin korunması açısından önemlidir. TEM bağlantısına yakın ilçe konumu, İstanbul'a ulaşım süresini kısaltmaktadır. Konut sitelerindeki taşımalarda güvenlik protokolü için araç giriş izni önceden alınabilmektedir. Tüm bireysel ve kurumsal taşımalarda nakliyat sigortası dahildir.</p>

            <h3 style="font-size:1.25rem;font-weight:700;margin:36px 0 16px;">Neden Bizi Seçmelisiniz?</h3>
            <div class="row g-3">
                @{ var nedenler = new[] {
                    new { I="🛡️", T="Nakliyat Sigortası", A="Tüm eşyalarınız taşıma süresince sigorta kapsamındadır. Olası hasarlara karşı tam güvence sağlanır." },
                    new { I="🔍", T="Ücretsiz Keşif", A="Eksperimiz adresinize gelir, eşya listesini çıkarır ve size net fiyat sunar. Sürpriz ücret yoktur." },
                    new { I="🔧", T="Söküm-Montaj Dahil", A="Mobilyalarınızın sökülmesi ve yeni adresinizde montajı hizmet kapsamındadır." },
                    new { I="🚛", T="Modern Araç Filosu", A="Kapalı kasa, klimasız ve askılı sistemli araçlarımız eşyalarınızı koruyarak taşır." },
                    new { I="💬", T="7/24 İletişim", A="Taşıma sürecinin her aşamasında müşteri temsilcimize ulaşabilirsiniz." },
                    new { I="💰", T="Şeffaf Fiyatlandırma", A="Keşif sonrası verilen fiyat sabittir. Ekstra ücret talep edilmez." }
                }; }
                @foreach (var n in nedenler)
                {
                    <div class="col-md-6">
                        <div style="border:1px solid #e0e0e0;border-radius:8px;padding:20px;height:100%;display:flex;gap:14px;">
                            <div style="font-size:1.8rem;flex-shrink:0;">@n.I</div>
                            <div>
                                <div style="font-weight:700;margin-bottom:6px;">@n.T</div>
                                <div style="font-size:.9rem;color:#555;">@n.A</div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <h3 style="font-size:1.25rem;font-weight:700;margin:36px 0 16px;">Sık Sorulan Sorular</h3>
            <div class="faq-list">
                @foreach (var faq in new[] {
                    new { Q="Kahramankazan'dan İstanbul'a nakliyat fiyatı ne kadar?", A="1+1 daire için 8.000–14.000 ₺, 2+1 için 12.000–20.000 ₺, 3+1 için 16.000–26.000 ₺. Kurumsal ve OSB taşımaları için özel fiyat belirlenir." },
                    new { Q="Kahramankazan OSB'den İstanbul'a kurumsal taşıma yapıyor musunuz?", A="Evet. Kahramankazan Organize Sanayi Bölgesi'ndeki fabrika ve iş yerlerinden İstanbul'a kurumsal taşıma hizmeti sunmaktayız." },
                    new { Q="Kahramankazan'dan İstanbul'a taşıma kaç saatte tamamlanır?", A="Kahramankazan TEM bağlantısına yakın olduğundan yükleme, nakliye ve boşaltma dahil 9–12 saatte tamamlanır." },
                    new { Q="Kahramankazan yeni konut sitelerinden taşıma yapıyor musunuz?", A="Evet. Kahramankazan'ın yeni gelişen konut sitelerinden İstanbul'a kapıdan kapıya ev taşıma hizmeti verilmektedir." }
                })
                {
                    <div class="faq-item" style="border:1px solid #e0e0e0;border-radius:8px;margin-bottom:12px;overflow:hidden;">
                        <div class="faq-question" style="padding:16px 20px;font-weight:600;cursor:pointer;background:var(--gray-100);">@faq.Q</div>
                        <div class="faq-answer" style="padding:16px 20px;border-top:1px solid #e0e0e0;">@faq.A</div>
                    </div>
                }
            </div>

        </div>

        <div class="col-lg-4">
            <div style="position:sticky;top:24px;display:flex;flex-direction:column;gap:24px;">

                <div style="background:var(--black);color:#fff;border-radius:10px;padding:28px;">
                    <h3 style="font-size:1.1rem;font-weight:700;margin-bottom:16px;">Hemen Teklif Alın</h3>
                    <p style="font-size:.9rem;opacity:.85;margin-bottom:20px;">Kahramankazan'dan İstanbul'a taşınma planınız için ücretsiz keşif ve fiyat teklifi alın.</p>
                    <a href="tel:05325436837" style="display:block;background:#fff;color:var(--black);text-align:center;padding:13px;border-radius:6px;font-weight:700;text-decoration:none;margin-bottom:10px;">📞 0532 543 68 37</a>
                    <a href="https://wa.me/905325436837" target="_blank" style="display:block;background:#25D366;color:#fff;text-align:center;padding:13px;border-radius:6px;font-weight:700;text-decoration:none;">WhatsApp ile Yaz</a>
                </div>

                <div style="border:1px solid #e0e0e0;border-radius:10px;padding:24px;">
                    <h4 style="font-size:1rem;font-weight:700;margin-bottom:14px;">Yakın İlçeler</h4>
                    <div style="display:flex;flex-direction:column;gap:8px;">
                        @foreach (var il in new[] { "Sincan", "Etimesgut", "Yenimahalle", "Çubuk", "Pursaklar" })
                        {
                            <a href="/@il.ToLower().Replace(" ","-").Replace("ç","c").Replace("ş","s").Replace("ğ","g").Replace("ü","u").Replace("ö","o").Replace("ı","i")-istanbul-nakliyat" style="padding:10px 14px;background:var(--gray-100);border-radius:6px;text-decoration:none;color:var(--black);font-size:.9rem;">@il İstanbul Nakliyat →</a>
                        }
                    </div>
                </div>

                <div style="border:1px solid #e0e0e0;border-radius:10px;padding:24px;">
                    <h4 style="font-size:1rem;font-weight:700;margin-bottom:12px;">Hızlı Bilgi</h4>
                    <ul style="list-style:none;padding:0;margin:0;font-size:.9rem;display:flex;flex-direction:column;gap:8px;">
                        <li>📍 <strong>Nereden:</strong> Kahramankazan, Ankara</li>
                        <li>📍 <strong>Nereye:</strong> İstanbul (Tüm İlçeler)</li>
                        <li>🛣️ <strong>Mesafe:</strong> ~430 km</li>
                        <li>⏱️ <strong>Süre:</strong> 9–12 saat</li>
                        <li>✅ <strong>Sigorta:</strong> Dahil</li>
                        <li>🔧 <strong>Söküm-Montaj:</strong> Dahil</li>
                    </ul>
                </div>

            </div>
        </div>
    </div>
</div>
