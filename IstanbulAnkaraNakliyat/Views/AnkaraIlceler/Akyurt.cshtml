@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "Ankara İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/ankara-istanbul-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Akyurt İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/akyurt-istanbul-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Akyurt İstanbul Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Akyurt, Ankara",
            "description": "Akyurt ilçesinden İstanbul'a kapıdan kapıya, sigortalı evden eve nakliyat hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/akyurt-istanbul-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Akyurt'tan İstanbul'a nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "1+1 daire için 8.000–14.000 ₺, 2+1 için 12.000–20.000 ₺, 3+1 için 16.000–26.000 ₺. Parsiyel yük seçeneğiyle az eşyada tasarruf sağlanabilir." }
                },
                {
                    "@@type": "Question",
                    "name": "Akyurt köy mahallelerinden taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Akyurt'a bağlı köy ve mahallelerin tamamından taşıma hizmeti verilmektedir. Dar yollar için uygun araç seçimi yapılır." }
                },
                {
                    "@@type": "Question",
                    "name": "Akyurt'tan İstanbul'a taşıma kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Akyurt'tan İstanbul'a yükleme, nakliye ve boşaltma dahil 10–13 saatte tamamlanır." }
                },
                {
                    "@@type": "Question",
                    "name": "Parsiyel yük hizmetiniz var mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Akyurt gibi sakin küçük ilçelerde az eşya taşımak isteyenler için parsiyel yük hizmetimiz mevcuttur." }
                }
            ]
        }
    ]
}
</script>
}

