@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "Ankara İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/ankara-istanbul-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Çamlıdere İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/camlidere-istanbul-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Çamlıdere İstanbul Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Çamlıdere, Ankara",
            "description": "Çamlıdere ilçesinden İstanbul'a kapıdan kapıya, baraj gölü kıyısı ve orman ilçesi deneyimiyle ikinci konut nakliyat hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/camlidere-istanbul-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Çamlıdere'den İstanbul'a nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "1+1 daire için 8.000–14.000 ₺, 2+1 için 12.000–20.000 ₺, 3+1 için 16.000–26.000 ₺. İkinci konut ve kırsal mülkler için keşif sonrası fiyat belirlenir." }
                },
                {
                    "@@type": "Question",
                    "name": "Çamlıdere baraj gölü kıyısındaki konuttan taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Çamlıdere Barajı kıyısındaki konutlardan ve orman içi mülklerden İstanbul'a taşıma hizmeti verilmektedir." }
                },
                {
                    "@@type": "Question",
                    "name": "Çamlıdere'den İstanbul'a taşıma kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Çamlıdere'den İstanbul'a yükleme, nakliye ve boşaltma dahil 10–13 saatte tamamlanır." }
                },
                {
                    "@@type": "Question",
                    "name": "Parsiyel yük hizmetiniz var mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. İkinci konut eşyası gibi az yüklerde parsiyel yük hizmetimiz mevcuttur. Ekonomik ve pratik taşıma sağlanır." }
                }
            ]
        }
    ]
}
</script>
}

