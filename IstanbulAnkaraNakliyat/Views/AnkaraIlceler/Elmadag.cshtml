@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "Ankara İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/ankara-istanbul-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Elmadağ İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/elmadag-istanbul-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Elmadağ İstanbul Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Elmadağ, Ankara",
            "description": "Elmadağ ilçesinden İstanbul'a kapıdan kapıya, sigortalı evden eve nakliyat hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/elmadag-istanbul-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Elmadağ'dan İstanbul'a nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "1+1 daire için 8.000–14.000 ₺, 2+1 için 12.000–20.000 ₺, 3+1 için 16.000–26.000 ₺. Ormanlık ve kırsal yollardaki mahalleler için ek erişim ücreti belirtilir." }
                },
                {
                    "@@type": "Question",
                    "name": "Elmadağ'ın ormanlık bölgelerinden taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Ormanlık ve kırsal yollar dahil tüm Elmadağ mahallelerinden taşıma hizmeti verilmektedir. Dar yollar için uygun araç seçimi yapılır." }
                },
                {
                    "@@type": "Question",
                    "name": "Elmadağ'dan İstanbul'a taşıma kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Elmadağ'dan İstanbul'a yükleme, nakliye ve boşaltma dahil 10–13 saatte tamamlanır." }
                },
                {
                    "@@type": "Question",
                    "name": "Parsiyel yük hizmetiniz var mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Az eşyayla İstanbul'a taşınmak isteyenler için parsiyel yük hizmetimiz mevcuttur. Ekonomik ve güvenli taşıma sağlanır." }
                }
            ]
        }
    ]
}
</script>
}

