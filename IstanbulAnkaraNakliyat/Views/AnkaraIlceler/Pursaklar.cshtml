}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "Ankara İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/ankara-istanbul-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Pursaklar İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/pursaklar-istanbul-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Pursaklar İstanbul Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Pursaklar, Ankara",
            "description": "Pursaklar ilçesinden İstanbul'a kapıdan kapıya, sigortalı evden eve nakliyat hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/pursaklar-istanbul-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Pursaklar'dan İstanbul'a nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "1+1 daire için 8.000–14.000 ₺, 2+1 için 12.000–20.000 ₺, 3+1 için 16.000–26.000 ₺. Az eşya için parsiyel yük seçeneğiyle tasarruf sağlanabilir." }
                },
                {
                    "@@type": "Question",
                    "name": "Pursaklar'dan İstanbul'a parsiyel nakliyat yapılıyor mu?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Pursaklar gibi küçük sakin ilçelerde parsiyel yük hizmetimiz mevcuttur. Az eşyayla başka yüklerle birleştirilerek ekonomik taşıma yapılır." }
                },
                {
                    "@@type": "Question",
                    "name": "Pursaklar'dan İstanbul'a taşıma kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Pursaklar'dan İstanbul'a yükleme, nakliye ve boşaltma dahil 10–13 saatte tamamlanır." }
                },
                {
                    "@@type": "Question",
                    "name": "Taşıma öncesi keşif gerekli midir?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Keşif ücretsiz olup net fiyat belirlenmesini sağlar. Küçük hacimli taşımalarda telefon görüşmesiyle de fiyat verilebilir." }
                }
            ]
        }
    ]
}
</script>
}

