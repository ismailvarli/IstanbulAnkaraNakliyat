@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "Ankara İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/ankara-istanbul-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Beypazarı İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/beypazari-istanbul-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Beypazarı İstanbul Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Beypazarı, Ankara",
            "description": "Beypazarı ilçesinden İstanbul'a kapıdan kapıya, Osmanlı konakları ve antika eşyalara özel nakliyat hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/beypazari-istanbul-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Beypazarı'ndan İstanbul'a nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "1+1 daire için 8.000–14.000 ₺, 2+1 için 12.000–20.000 ₺, 3+1 için 16.000–26.000 ₺. Osmanlı konakları ve antika eşya taşımaları için özel fiyat belirlenir." }
                },
                {
                    "@@type": "Question",
                    "name": "Beypazarı'ndaki Osmanlı konağından eşya taşıyabiliyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Tarihi Osmanlı konakları ve eski yapılardan taşıma konusunda deneyimliyiz. Dar kapı ve alçak tavan için özel yöntemler kullanılmaktadır." }
                },
                {
                    "@@type": "Question",
                    "name": "Antika ve değerli eşyalar güvenle taşınıyor mu?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Antika mobilya ve değerli eşyalar için özel köpük ambalaj, ahşap sandık ve kontrollü yükleme uygulanır. Ek sigorta seçeneği de mevcuttur." }
                },
                {
                    "@@type": "Question",
                    "name": "Beypazarı'ndan İstanbul'a taşıma kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Beypazarı'ndan İstanbul'a yükleme, nakliye ve boşaltma dahil 9–12 saatte tamamlanır." }
                }
            ]
        }
    ]
}
</script>
}

