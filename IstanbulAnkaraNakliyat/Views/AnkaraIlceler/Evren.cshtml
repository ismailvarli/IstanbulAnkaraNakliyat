@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@graph": [
        {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
                { "@@type": "ListItem", "position": 2, "name": "Ankara İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/ankara-istanbul-nakliyat" },
                { "@@type": "ListItem", "position": 3, "name": "Evren İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/evren-istanbul-nakliyat" }
            ]
        },
        {
            "@@type": "Service",
            "name": "Evren İstanbul Nakliyat Hizmeti",
            "provider": { "@@id": "https://www.istanbulankaranakliyat.tr/#organization" },
            "areaServed": "Evren, Ankara",
            "description": "Evren ilçesinden İstanbul'a kapıdan kapıya, sigortalı evden eve nakliyat hizmeti.",
            "url": "https://www.istanbulankaranakliyat.tr/evren-istanbul-nakliyat"
        },
        {
            "@@type": "FAQPage",
            "mainEntity": [
                {
                    "@@type": "Question",
                    "name": "Evren'den İstanbul'a nakliyat fiyatı ne kadar?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "1+1 daire için 8.000–14.000 ₺, 2+1 için 12.000–20.000 ₺, 3+1 için 16.000–27.000 ₺. Az eşyada parsiyel yük seçeneği mevcuttur." }
                },
                {
                    "@@type": "Question",
                    "name": "Evren'den İstanbul'a taşıma kaç saatte tamamlanır?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evren'den İstanbul'a yükleme, nakliye ve boşaltma dahil ortalama 10–14 saatte tamamlanır." }
                },
                {
                    "@@type": "Question",
                    "name": "Evren köy ve bağ evlerinden taşıma yapıyor musunuz?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Evren'e bağlı köy ve bağ evlerinden taşıma yapılmaktadır. Dar yollar için uygun araç planlaması yapılır." }
                },
                {
                    "@@type": "Question",
                    "name": "Parsiyel yük hizmetiniz var mı?",
                    "acceptedAnswer": { "@@type": "Answer", "text": "Evet. Evren gibi küçük yerleşim birimlerinden az eşyayla İstanbul'a taşınmak isteyenler için parsiyel yük hizmetimiz mevcuttur." }
                }
            ]
        }
    ]
}
</script>
}

