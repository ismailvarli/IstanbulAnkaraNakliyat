        document.getElementById('galeri-lb-counter').textContent = (idx + 1) + ' / ' + galItems.length;
        document.getElementById('galeri-lightbox').style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function galeriKapat() {
        document.getElementById('galeri-lightbox').style.display = 'none';
        document.body.style.overflow = '';
    }

    function galeriPrev() { galeriAc((galCurrent - 1 + galItems.length) % galItems.length); }
    function galeriNext() { galeriAc((galCurrent + 1) % galItems.length); }

    document.addEventListener('keydown', function(e) {
        if (document.getElementById('galeri-lightbox').style.display !== 'flex') return;
        if (e.key === 'Escape')     galeriKapat();
        if (e.key === 'ArrowLeft')  galeriPrev();
        if (e.key === 'ArrowRight') galeriNext();
