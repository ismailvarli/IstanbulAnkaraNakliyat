<div id="galeri-lightbox" onclick="galeriKapat()">
    <span class="g-lb-kapat">&times;</span>
    <img id="galeri-lb-img" src="" alt="" onclick="event.stopPropagation()" />
    <button class="g-lb-prev" onclick="event.stopPropagation(); galeriPrev()" aria-label="Önceki">&#8249;</button>
    <button class="g-lb-next" onclick="event.stopPropagation(); galeriNext()" aria-label="Sonraki">&#8250;</button>
    <div class="g-lb-counter" id="galeri-lb-counter"></div>
</div>

@section Scripts {
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "BreadcrumbList",
        "itemListElement": [
            { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
            { "@@type": "ListItem", "position": 2, "name": "Taşıma Galerisi", "item": "https://www.istanbulankaranakliyat.tr/galeri" }
        ]
    }
    </script>
    <script>
    var galItems = [
        { src: '/img/galeri/galeri1.jpeg',  alt: 'İstanbul Ankara Ev Taşıma' },
        { src: '/img/galeri/galeri2.jpeg',  alt: 'Profesyonel Ambalajlama' },
        { src: '/img/galeri/galeri3.jpeg',  alt: 'Nakliyat Aracına Yükleme' },
        { src: '/img/galeri/galeri4.jpeg',  alt: 'Mobilya Koruma' },
        { src: '/img/galeri/galeri5.jpeg',  alt: 'Sigortalı Nakliyat' },
        { src: '/img/galeri/galeri6.jpeg',  alt: 'Ofis Taşıma' },
        { src: '/img/galeri/galeri7.jpeg',  alt: 'Parça Eşya Taşıma' },
        { src: '/img/galeri/galeri8.jpeg',  alt: 'Güvenli Ev Taşıma' },
        { src: '/img/galeri/galeri9.jpeg',  alt: 'Kırılgan Eşya Ambalajı' },
        { src: '/img/galeri/galeri10.jpeg', alt: 'Nakliyat Aracı' },
        { src: '/img/galeri/galeri11.jpeg', alt: 'Kapıdan Kapıya Taşıma' },
        { src: '/img/galeri/galeri12.jpeg', alt: 'Profesyonel Ekip' },
        { src: '/img/galeri/galeri14.jpeg', alt: 'Eşya Paketleme' },
        { src: '/img/galeri/galeri15.jpeg', alt: 'İstanbul Ankara Taşımacılık' },
        { src: '/img/galeri/galeri16.jpeg', alt: 'Ekip Çalışması' },
        { src: '/img/galeri/galeri17.jpeg', alt: 'Mobilya Streç Koruma' },
        { src: '/img/galeri/galeri18.jpeg', alt: 'Kutu Paketleme' },
        { src: '/img/galeri/galeri19.jpeg', alt: 'Ankara\'ya Taşınma' },
        { src: '/img/galeri/galeri20.jpeg', alt: 'Asansörlü Nakliyat' },
        { src: '/img/galeri/galeri21.jpeg', alt: 'Güvenli Taşıma' },
        { src: '/img/galeri/galeri22.jpeg', alt: 'İstanbul Nakliyat' },
        { src: '/img/galeri/galeri23.jpeg', alt: 'Ev Eşyası Taşıma' },
        { src: '/img/galeri/galeri24.jpeg', alt: 'Profesyonel Taşımacılık' },
        { src: '/img/galeri/galeri25.jpeg', alt: 'Sigortalı Taşıma' },
        { src: '/img/galeri/galeri27.jpeg', alt: 'Eşya Depolama' },
        { src: '/img/galeri/galeri28.jpeg', alt: 'Ambalaj Malzemeleri' },
        { src: '/img/galeri/galeri29.jpeg', alt: 'Taşınma Günü Hazırlık' },
        { src: '/img/galeri/galeri30.jpeg', alt: 'Araç Yükleme' },
        { src: '/img/galeri/galeri31.jpeg', alt: 'Ev Taşıma İstanbul' },
        { src: '/img/galeri/galeri32.jpeg', alt: 'Ankara Nakliyat' },
        { src: '/img/galeri/galeri33.jpeg', alt: 'Kapıdan Kapıya Nakliyat' }
    ];
    var galCurrent = 0;

    function galeriAc(idx) {
        galCurrent = idx;
        document.getElementById('galeri-lb-img').src = galItems[idx].src;
        document.getElementById('galeri-lb-img').alt = galItems[idx].alt;
        document.getElementById('galeri-lb-counter').textContent = (idx + 1) + ' / ' + galItems.length;
        document.getElementById('galeri-lightbox').style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function galeriKapat() {
        document.getElementById('galeri-lightbox').style.display = 'none';
        document.body.style.overflow = '';
    }

    function galeriPrev() { galeriAc((galCurrent - 1 + galItems.length) % galItems.length); }
    function galeriNext() { galeriAc((galCurrent + 1) % galItems.length); }

    document.addEventListener('keydown', function(e) {
        if (document.getElementById('galeri-lightbox').style.display !== 'flex') return;
        if (e.key === 'Escape')     galeriKapat();
        if (e.key === 'ArrowLeft')  galeriPrev();
        if (e.key === 'ArrowRight') galeriNext();
    });
    </script>
}

<style>
.galeri-baslik {
    padding: 52px 0 36px;
    border-bottom: 1px solid var(--gray-200);
    margin-bottom: 40px;
}
.galeri-baslik small {
    display: block;
    font-size: .78rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--gray-400);
    margin-bottom: .6rem;
}
.galeri-baslik h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: .75rem;
}
.galeri-baslik p {
    color: var(--gray-600);
    font-size: 1.05rem;
    max-width: 520px;
}

.galeri-grid-wrap {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    padding-bottom: 64px;
}

.g-item {
    position: relative;
    height: 240px;
    overflow: hidden;
    border-radius: var(--radius);
    cursor: pointer;
    border-bottom: 3px solid var(--black);
    box-shadow: 0 2px 8px rgba(0,0,0,.08);
    transition: transform .3s ease, box-shadow .3s ease;
}
.g-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 24px rgba(0,0,0,.15);
}
.g-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .4s ease;
}
.g-item:hover img { transform: scale(1.06); }

.g-item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0);
    transition: background .3s ease;
}
.g-item:hover::after { background: rgba(0,0,0,.2); }

#galeri-lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0,0,0,.92);
    justify-content: center;
    align-items: center;
}
#galeri-lb-img {
    max-width: 88%;
    max-height: 88vh;
    object-fit: contain;
    border-radius: var(--radius);
    box-shadow: 0 20px 60px rgba(0,0,0,.5);
}
.g-lb-kapat {
    position: fixed;
    top: 18px; right: 26px;
    color: #fff;
    font-size: 42px;
    cursor: pointer;
    line-height: 1;
    opacity: .8;
}
.g-lb-kapat:hover { opacity: 1; }
.g-lb-prev, .g-lb-next {
    position: fixed;
    top: 50%; transform: translateY(-50%);
    background: rgba(255,255,255,.12);
    border: none; color: #fff;
    font-size: 2.5rem;
    width: 48px; height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s;
}
.g-lb-prev:hover, .g-lb-next:hover { background: rgba(255,255,255,.25); }
.g-lb-prev { left: 16px; }
.g-lb-next { right: 16px; }
.g-lb-counter {
    position: fixed;
    bottom: 20px; left: 50%; transform: translateX(-50%);
    color: rgba(255,255,255,.55);
    font-size: .8rem; font-weight: 600; letter-spacing: .08em;
}

@@media (max-width: 1100px) { .galeri-grid-wrap { grid-template-columns: repeat(3, 1fr); } }
@@media (max-width: 768px) {
    .galeri-grid-wrap { grid-template-columns: repeat(2, 1fr); gap: 8px; }
    .g-item { height: 190px; }
    .g-lb-prev { left: 6px; }
    .g-lb-next { right: 6px; }
}
</style>
