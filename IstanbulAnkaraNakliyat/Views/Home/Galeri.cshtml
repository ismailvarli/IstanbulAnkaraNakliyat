<style>
.galeri-baslik {
    padding: 52px 0 36px;
    border-bottom: 1px solid var(--gray-200);
    margin-bottom: 40px;
}
.galeri-baslik small {
    display: block;
    font-size: .78rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--gray-400);
    margin-bottom: .6rem;
}
.galeri-baslik h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: .75rem;
}
.galeri-baslik p {
    color: var(--gray-600);
    font-size: 1.05rem;
    max-width: 520px;
}

.galeri-grid-wrap {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    padding-bottom: 64px;
}

.g-item {
    position: relative;
    height: 240px;
    overflow: hidden;
    border-radius: var(--radius);
    cursor: pointer;
    border-bottom: 3px solid var(--black);
    box-shadow: 0 2px 8px rgba(0,0,0,.08);
    transition: transform .3s ease, box-shadow .3s ease;
}
.g-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 24px rgba(0,0,0,.15);
}
.g-item img {
    width: 100%;
    height: 100%;
