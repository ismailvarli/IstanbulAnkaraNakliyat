@{
    var slug = ViewData["IlceSlug"] as string ?? "";
    var ilce = ViewData["IlceAdi"]  as string ?? "";

    var servisler = new[]
    {
        ("evden-eve",    "🏠", "Evden Eve Nakliyat",     "Kapıdan kapıya, söküm-montaj ve sigorta dahil tam hizmet"),
        ("kamyonet",     "🚐", "Kamyonet Nakliyat",      "Stüdyo, 1+1 ve öğrenci eşyası için ekonomik seçenek"),
        ("kamyon",       "🚛", "Kamyon Nakliyat",        "2+1, 3+1 ve büyük daireler için tam araç taşıma"),
        ("sehirlerarasi","📋", "Şehirlerarası Nakliyat", "C Tipi Yetki Belgeli, sigortalı yasal güvence"),
        ("ofis",         "🏢", "Ofis Nakliyat",          "IT ekipmanı ve arşiv dahil kurumsal taşıma"),
        ("parsiyel",     "📦", "Parsiyel Nakliyat",      "Az eşya için paylaşımlı araç ile ekonomik fiyat"),
        ("ambar",        "🏭", "Ambar Nakliyat",         "Esnek tarihli depolama ve taşıma kombine hizmeti"),
        ("fuar",         "🎪", "Fuar Nakliyat",          "Stand ve sergi malzemeleri için zamanında teslimat"),
    };
}

<section style="padding:48px 0 56px;background:var(--gray-100);border-top:1px solid var(--gray-200);">
    <div class="container">
        <h2 style="margin-bottom:.5rem;">@ilce İstanbul Nakliyat Hizmetleri</h2>
        <p style="color:var(--gray-600);margin-bottom:2rem;font-size:.95rem;">
            @ilce'den İstanbul'a özel tüm nakliyat seçenekleri — ihtiyacınıza göre seçin.
        </p>
        <div class="row" style="row-gap:1rem;">
            @foreach (var s in servisler)
            {
                <div class="col-md-6 col-lg-3">
                    <a href="/@slug-istanbul-@s.Item1-nakliyat"
                       style="display:flex;flex-direction:column;gap:.5rem;padding:1.25rem;background:#fff;border:1px solid var(--gray-200);border-radius:var(--radius-lg);text-decoration:none;color:inherit;height:100%;transition:box-shadow .18s,transform .18s;"
                       onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,.08)';this.style.transform='translateY(-3px)'"
                       onmouseout="this.style.boxShadow='none';this.style.transform='none'">
                        <span style="font-size:1.6rem;line-height:1;">@s.Item2</span>
                        <strong style="font-size:.92rem;">@s.Item3</strong>
                        <span style="font-size:.82rem;color:var(--gray-600);line-height:1.55;flex:1;">@s.Item4</span>
                        <span style="font-size:.82rem;font-weight:700;color:var(--black);margin-top:.25rem;">Detaylı Bilgi →</span>
                    </a>
                </div>
            }
        </div>
    </div>
</section>
