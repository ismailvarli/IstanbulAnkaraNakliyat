        </nav>

        <!-- Mobil Menü -->
        <div class="mobile-menu" id="mobileMenu" aria-hidden="true">
            <ul role="list">
                <li><a href="/">Ana Sayfa</a></li>
                <li><a href="/hakkimizda">Hakkımızda</a></li>
                <li><a href="/istanbul-ankara-nakliyat">İstanbul → Ankara</a></li>
                <li><a href="/ankara-istanbul-nakliyat">Ankara → İstanbul</a></li>
                <li class="mobile-dropdown">
