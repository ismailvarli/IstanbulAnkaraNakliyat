<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1a1a1a" />
    <link rel="icon" type="image/png" href="~/img/logo.png" />
    <link rel="apple-touch-icon" href="~/img/logo.png" />

    <title>@ViewData["Title"]</title>
    <meta name="description" content="@ViewData["Description"]" />
    @if (ViewData["Noindex"] != null)
    {
        <meta name="robots" content="noindex, nofollow" />
    }

    @{
        var path      = Context.Request.Path.Value?.TrimEnd('/');
        var canonical = ViewData["Canonical"]?.ToString()
                        ?? $"https://www.istanbulankaranakliyat.tr{(string.IsNullOrEmpty(path) ? "" : path)}";
    }
    <link rel="canonical" href="@canonical" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:locale"      content="tr_TR" />
    <meta property="og:site_name"   content="İstanbul Ankara Nakliyat" />
    <meta property="og:title"       content="@ViewData["Title"]" />
    <meta property="og:description" content="@ViewData["Description"]" />
    <meta property="og:url"         content="@canonical" />
    <meta property="og:image"       content="https://www.istanbulankaranakliyat.tr/img/og-image.jpg" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content="@ViewData["Title"]" />
    <meta name="twitter:description" content="@ViewData["Description"]" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Bundle: bootstrap-grid + site.css -->
    <link rel="stylesheet" href="~/css/bundle.css" asp-append-version="true" />

    <!-- LocalBusiness JSON-LD -->
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "LocalBusiness",
        "@@id": "https://www.istanbulankaranakliyat.tr/#organization",
        "name": "İstanbul Ankara Nakliyat",
        "url": "https://www.istanbulankaranakliyat.tr",
        "telephone": "+905325436837",
        "email": "istanbulankaranakliyat.tr@gmail.com",
        "address": {
            "@@type": "PostalAddress",
            "addressLocality": "İstanbul",
            "addressCountry": "TR"
        },
        "areaServed": ["İstanbul", "Ankara"],
        "priceRange": "₺₺",
        "image": "https://www.istanbulankaranakliyat.tr/img/og-image.jpg"
    }
    </script>

    <!-- WebSite JSON-LD -->
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "WebSite",
        "@@id": "https://www.istanbulankaranakliyat.tr/#website",
        "url": "https://www.istanbulankaranakliyat.tr",
        "name": "İstanbul Ankara Nakliyat",
        "inLanguage": "tr-TR"
    }
    </script>

    @if (ViewData["Schema"] != null)
    {
        @Html.Raw(ViewData["Schema"])
    }
</head>
<body>

