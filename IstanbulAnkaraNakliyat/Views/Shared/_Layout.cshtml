                    </button>
                    <ul class="mobile-dropdown-menu">
                        <li><a href="/hizmetler">Tüm Hizmetler</a></li>
                        <li><a href="/evden-eve-nakliyat">Evden Eve Nakliyat</a></li>
                        <li><a href="/ofis-tasima">Ofis Taşıma</a></li>
                        <li><a href="/parca-esya-tasima">Parça Eşya Taşıma</a></li>
                        <li><a href="/esya-depolama">Eşya Depolama</a></li>
                        <li><a href="/ambalaj-hizmeti">Ambalaj Hizmeti</a></li>
                        <li><a href="/ceyiz-tasima">Çeyiz Taşıma</a></li>
                    </ul>
                </li>
                <li><a href="/nakliyat-ucreti">Fiyatlar</a></li>
                <li><a href="/galeri">Galeri</a></li>
                <li><a href="/blog">Blog</a></li>
                <li><a href="/iletisim">İletişim</a></li>
                <li><a href="tel:+905325436837" class="mobile-cta">📞 0532 543 68 37</a></li>
            </ul>
        </div>
    </header>

    <!-- ══ MAIN ════════════════════════════════════════════════ -->
    <main id="main-content">
        @RenderBody()
    </main>

    <!-- ══ MÜŞTERİ YORUM FORMU ════════════════════════════════ -->
    <section class="review-form-section" id="yorum-formu" aria-labelledby="review-form-heading">
        <div class="container">
            <div class="text-center" style="margin-bottom:2.5rem;">
                <h2 id="review-form-heading" class="section-title">Deneyiminizi Paylaşın</h2>
                <p class="section-subtitle">Taşıma sürecinizi nasıl buldunuz? Yorumunuz diğer müşterilere yol gösterir.</p>
            </div>

            <div class="review-form-wrap">

            @if (Context.Request.Query["yorum"] == "tesekkur")
            {
                <div class="review-thanks">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                    <h3>Teşekkür Ederiz!</h3>
                    <p>Yorumunuz alındı. İnceleme sonrası "Müşterilerimiz Ne Diyor?" bölümünde yayınlanacaktır.</p>
                </div>
            }
            else
            {
                @if (Context.Request.Query["yorum"] == "hata")
                {
                    <div class="review-error">Lütfen adınızı ve en az 10 karakter yorum giriniz.</div>
                }
                <form method="post" action="/yorum/gonder" class="review-form">
                    @Html.AntiForgeryToken()
                    <div class="review-stars-pick" id="starPicker" role="group" aria-label="Puan seçin">
                        <button type="button" class="star-btn" data-val="1" aria-label="1 yıldız">★</button>
                        <button type="button" class="star-btn" data-val="2" aria-label="2 yıldız">★</button>
                        <button type="button" class="star-btn" data-val="3" aria-label="3 yıldız">★</button>
                        <button type="button" class="star-btn" data-val="4" aria-label="4 yıldız">★</button>
                        <button type="button" class="star-btn active" data-val="5" aria-label="5 yıldız">★</button>
                    </div>
                    <input type="hidden" name="puan" id="puanInput" value="5" />
                    <div class="review-form-row">
                        <input type="text" name="ad" placeholder="Adınız Soyadınız" required maxlength="60" autocomplete="name" />
                    </div>
                    <div class="review-form-row">
                        <textarea name="yorum" placeholder="Taşıma deneyiminizi paylaşın... (min. 10 karakter)" required minlength="10" maxlength="500" rows="4"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Yorumu Gönder</button>
                </form>
            }

            </div>
        </div>
    </section>

