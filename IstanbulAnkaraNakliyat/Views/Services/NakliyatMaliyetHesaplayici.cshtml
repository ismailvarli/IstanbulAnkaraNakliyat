}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "BreadcrumbList",
    "itemListElement": [
        { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
        { "@@type": "ListItem", "position": 2, "name": "Nakliyat Ücretleri", "item": "https://www.istanbulankaranakliyat.tr/nakliyat-ucreti" },
        { "@@type": "ListItem", "position": 3, "name": "Maliyet Hesaplayıcı", "item": "https://www.istanbulankaranakliyat.tr/nakliyat-maliyet-hesaplayici" }
    ]
}
</script>
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "FAQPage",
    "mainEntity": [
        {
            "@@type": "Question",
            "name": "İstanbul Ankara nakliyat maliyeti ne kadar?",
            "acceptedAnswer": { "@@type": "Answer", "text": "2026 yılı itibarıyla 1+1 daire için 8.000–14.000 ₺, 2+1 daire için 12.000–20.000 ₺, 3+1 daire için 16.000–28.000 ₺ arasında değişmektedir. Kesin fiyat için ücretsiz keşif yapılmaktadır." }
        },
        {
            "@@type": "Question",
            "name": "Asansörsüz kat fiyatı nasıl etkiler?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Her asansörsüz kat, merdiven taşıma iş gücü nedeniyle toplam nakliyat maliyetini yaklaşık 500–1.500 ₺ artırabilir. 4. kat ve üzeri asansörsüz binalarda harici asansör (mobil vinç) gerekebilir." }
        },
        {
            "@@type": "Question",
            "name": "Parsiyel yük nakliyat fiyatı nasıl hesaplanır?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Parsiyel yükte yalnızca kapladığınız hacim (m³) için ücret ödersiniz. Genellikle 300–800 ₺/m³ arasında değişir. Az eşyada çok daha ekonomik olabilir." }
        }
    ]
}
</script>

<script>
(function () {
    // Taban fiyatlar (₺) - 2026
    var base = {
        "1+1": { min: 8000,  max: 14000 },
        "2+1": { min: 12000, max: 20000 },
        "3+1": { min: 16000, max: 28000 },
        "4+1": { min: 22000, max: 38000 },
        "villa": { min: 30000, max: 55000 }
    };

    function calculate() {
        var daire     = document.getElementById("daire").value;
        var kat       = parseInt(document.getElementById("kat").value) || 1;
        var asansor   = document.getElementById("asansor").value === "evet";
        var sokim     = document.getElementById("sokim").checked;
        var ambalaj   = document.getElementById("ambalaj").checked;
        var parcaEsya = document.getElementById("parcaEsya").checked;

        if (!daire) {
            document.getElementById("sonuc").style.display = "none";
            return;
        }

        var b = base[daire];
        var minF = b.min, maxF = b.max;

        // Kat faktörü (asansörsüz)
        if (!asansor && kat > 1) {
            var katEk = (kat - 1) * 800;
            minF += katEk;
            maxF += katEk + 400;
        }

        // Söküm-montaj
        if (sokim) {
            minF += 1500;
            maxF += 2500;
        }

        // Profesyonel ambalaj
        if (ambalaj) {
            minF += 1000;
            maxF += 1800;
        }

        // Parça eşya indirimi
        if (parcaEsya) {
            minF = Math.round(minF * 0.55);
            maxF = Math.round(maxF * 0.60);
        }

        document.getElementById("sonucMin").textContent = minF.toLocaleString("tr-TR") + " ₺";
        document.getElementById("sonucMax").textContent = maxF.toLocaleString("tr-TR") + " ₺";

        var aciklamalar = [];
        if (!asansor && kat > 1) aciklamalar.push("Asansörsüz " + kat + ". kat ek maliyeti hesaba katıldı.");
        if (sokim) aciklamalar.push("Söküm-montaj hizmeti dahil.");
        if (ambalaj) aciklamalar.push("Profesyonel ambalaj hizmeti dahil.");
        if (parcaEsya) aciklamalar.push("Parsiyel yük fiyatı gösterilmektedir (tam araç değil).");
        document.getElementById("sonucAciklama").innerHTML = aciklamalar.map(function(a){ return "• " + a; }).join("<br>");

        document.getElementById("sonuc").style.display = "block";
    }

    window.addEventListener("DOMContentLoaded", function () {
        ["daire","kat","asansor"].forEach(function(id){
            document.getElementById(id).addEventListener("change", calculate);
        });
        ["sokim","ambalaj","parcaEsya"].forEach(function(id){
            document.getElementById(id).addEventListener("change", calculate);
        });
    });
})();
</script>
}

