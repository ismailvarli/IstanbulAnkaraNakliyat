                        <a href="tel:+905325436837" style="display:block;background:#fff;color:var(--black);text-align:center;padding:12px;border-radius:6px;font-weight:700;text-decoration:none;margin-bottom:.75rem;">📞 0532 543 68 37</a>
                        <a href="https://wa.me/905325436837" target="_blank" style="display:block;background:#25D366;color:#fff;text-align:center;padding:12px;border-radius:6px;font-weight:700;text-decoration:none;">WhatsApp ile Yaz</a>
                    </div>

                    <div style="border:1px solid #e0e0e0;border-radius:10px;padding:1.5rem;">
                        <h4 style="font-size:1rem;font-weight:700;margin-bottom:1rem;">Maliyet Hesapla</h4>
                        <p style="font-size:.88rem;color:var(--gray-600);margin-bottom:.75rem;">Taşıma maliyetinizi anında hesaplayın.</p>
                        <a href="/nakliyat-maliyet-hesaplayici" style="display:block;background:var(--black);color:#fff;text-align:center;padding:11px;border-radius:6px;font-weight:600;text-decoration:none;font-size:.9rem;">🧮 Hesaplayıcıyı Aç →</a>
                    </div>

                    <div style="border:1px solid #e0e0e0;border-radius:10px;padding:1.5rem;">
                        <h4 style="font-size:1rem;font-weight:700;margin-bottom:.75rem;">Popüler Hizmetler</h4>
                        <div style="display:flex;flex-direction:column;gap:.5rem;font-size:.88rem;">
                            <a href="/evden-eve-nakliyat" style="color:var(--black);text-decoration:none;padding:6px 0;border-bottom:1px solid #f0f0f0;">Evden Eve Nakliyat →</a>
                            <a href="/parca-esya-tasima" style="color:var(--black);text-decoration:none;padding:6px 0;border-bottom:1px solid #f0f0f0;">Parça Eşya Taşıma →</a>
                            <a href="/ofis-tasima" style="color:var(--black);text-decoration:none;padding:6px 0;border-bottom:1px solid #f0f0f0;">Ofis Taşıma →</a>
