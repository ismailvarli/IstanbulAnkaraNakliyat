@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "BreadcrumbList",
    "itemListElement": [
        { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
        { "@@type": "ListItem", "position": 2, "name": "Ankara Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/ankara-nakliyat" },
        { "@@type": "ListItem", "position": 3, "name": "Ankara Mahalle Rehberi", "item": "https://www.istanbulankaranakliyat.tr/ankara-mahalle-rehberi" }
    ]
}
</script>
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "FAQPage",
    "mainEntity": [
        {
            "@@type": "Question",
            "name": "Ankara'nın en uygun fiyatlı ilçesi hangisi?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Mamak, Sincan ve Keçiören'in kuzey mahalleleri (Bağlum, Güçlükaya) Ankara'nın en uygun kiralık ve satılık fiyatlarını sunar. Etimesgut/Eryaman da TOKİ konutları ile uygun seçenekler barındırır." }
        },
        {
            "@@type": "Question",
            "name": "İstanbul'dan Ankara'ya taşınırken hangi ilçeyi seçmeliyim?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Seçim yaşam tarzınıza bağlıdır. Şehir merkezi ve kültüre yakın olmak isteyenler için Çankaya, bütçe dostu modern konut arayanlar için Etimesgut/Eryaman, yeşil alan ve doğa sevenler için Gölbaşı iyi seçeneklerdir." }
        },
        {
            "@@type": "Question",
            "name": "Ankara'da çalışıyorum, hangi ilçe işyerine yakın ve ulaşımı kolay?",
            "acceptedAnswer": { "@@type": "Answer", "text": "TBMM ve bakanlıklara yakın çalışanlar için Çankaya ve Yenimahalle, Ostim/İvedik sanayi bölgesi için Yenimahalle, Kızılay için Çankaya, Altındağ veya Etimesgut metro hattı iyi seçeneklerdir." }
        },
        {
            "@@type": "Question",
            "name": "Gölbaşı'nda yaşamak nasıl?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Gölbaşı, Mogan ve Eymir göllerinin çevresinde konumlanan, görece sessiz ve yeşil bir ilçedir. Ulaşım için özel araç gerekmektedir. Orta-üst gelir grubunun tercih ettiği villa ve site projelerine ev sahipliği yapar." }
        }
    ]
}
</script>
}

