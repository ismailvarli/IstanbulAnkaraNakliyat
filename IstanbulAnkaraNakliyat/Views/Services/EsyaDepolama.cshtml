    ViewData["Description"] = "İstanbul ve Ankara'da eşya depolama hizmeti. 7/24 kameralı, sigortalı, kapalı depo. Aylık kiralama, iklim kontrollü alan. Bilgi: 0532 543 68 37";
}
@section Scripts {
<script type="application/ld+json">
{"@@context":"https://schema.org","@@type":"BreadcrumbList","itemListElement":[
    {"@@type":"ListItem","position":1,"name":"Ana Sayfa","item":"https://www.istanbulankaranakliyat.tr/"},
    {"@@type":"ListItem","position":2,"name":"Eşya Depolama","item":"https://www.istanbulankaranakliyat.tr/esya-depolama"}
]}
