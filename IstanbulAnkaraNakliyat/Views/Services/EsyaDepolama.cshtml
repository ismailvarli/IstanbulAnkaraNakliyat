<script type="application/ld+json">
{"@@context":"https://schema.org","@@type":"FAQPage","mainEntity":[
    {"@@type":"Question","name":"Eşya depolama fiyatı ne kadar?","acceptedAnswer":{"@@type":"Answer","text":"Fiyat eşyanın hacmine (m³) ve depolama süresine göre değişir. Mini paket (1–3 m³) için aylık 500 ₺'den, büyük ev eşyaları (8–20 m³) için aylık 1.800–3.500 ₺'den başlayan paketler mevcuttur."}},
    {"@@type":"Question","name":"Eşyalarım depoda güvende mi?","acceptedAnswer":{"@@type":"Answer","text":"Evet. Depomuz 7/24 güvenlik kameralarıyla izlenmekte, yetkisiz girişlere karşı alarm sistemi ve sigorta kapsamına sahiptir."}},
    {"@@type":"Question","name":"Ne kadar süre depolama yapabilirsiniz?","acceptedAnswer":{"@@type":"Answer","text":"Minimum 1 hafta, azami süre sınırsızdır. Aylık kiralama yapılır; dilediğiniz zaman süre uzatabilir veya eşyalarınızı teslim alabilirsiniz."}},
    {"@@type":"Question","name":"Depoya kendiniz eşya bırakabilir misiniz?","acceptedAnswer":{"@@type":"Answer","text":"Evet. Depo adresimize randevu alarak eşyanızı kendiniz getirebilirsiniz. Evden teslim alma ve yeni adrese teslim hizmeti de mevcuttur."}},
    {"@@type":"Question","name":"Klimalı depo seçeneği var mı?","acceptedAnswer":{"@@type":"Answer","text":"Evet. Elektronik eşyalar, tablolar veya hassas koleksiyonlar için iklim kontrollü (klimalı) depo alanı talep edebilirsiniz."}}
]}
</script>
}

