@{
    Layout = "_Layout";
}

@section Scripts {
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "BreadcrumbList",
    "itemListElement": [
        { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.istanbulankaranakliyat.tr/" },
        { "@@type": "ListItem", "position": 2, "name": "İstanbul Nakliyat", "item": "https://www.istanbulankaranakliyat.tr/istanbul-nakliyat" },
        { "@@type": "ListItem", "position": 3, "name": "İstanbul Mahalle Rehberi", "item": "https://www.istanbulankaranakliyat.tr/istanbul-mahalle-rehberi" }
    ]
}
</script>
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "FAQPage",
    "mainEntity": [
        {
            "@@type": "Question",
            "name": "Ankara'dan İstanbul'a taşınırken hangi ilçeyi seçmeliyim?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Seçim önceliklerinize bağlıdır. Kültürel yaşam ve merkezi konum için Kadıköy veya Beşiktaş, uygun fiyat ve modern konut için Beylikdüzü veya Esenyurt, deniz manzarası için Maltepe veya Sarıyer değerlendirilebilir." }
        },
        {
            "@@type": "Question",
            "name": "İstanbul'un en uygun fiyatlı ilçesi hangisi?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Esenyurt, Sultangazi ve Arnavutköy İstanbul'un en uygun kiralık fiyatlarını sunar. Beylikdüzü ise yeni binalar ve uygun fiyat dengesiyle genç aileler için popüler bir seçenektir." }
        },
        {
            "@@type": "Question",
            "name": "İstanbul'da toplu taşıma en güçlü ilçe hangisi?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Kadıköy, Beşiktaş ve Şişli metro, metrobüs, vapur ve otobüs hatlarıyla İstanbul'un en güçlü toplu taşıma ağına sahip ilçeleridir. Ataşehir ise M4 metro hattıyla iyi bağlantı sunar." }
        },
        {
            "@@type": "Question",
            "name": "Beylikdüzü'nde yaşamak nasıl?",
            "acceptedAnswer": { "@@type": "Answer", "text": "Beylikdüzü, yeni ve büyük site projeleri, uygun kira fiyatları ve geniş alışveriş imkânlarıyla genç aileler için cazip bir ilçedir. Merkeze uzaklık ve metrobüs yoğunluğu dezavantajları arasındadır; ancak sahil şeridine yakınlığı artı yönüdür." }
        }
    ]
}
</script>
}

