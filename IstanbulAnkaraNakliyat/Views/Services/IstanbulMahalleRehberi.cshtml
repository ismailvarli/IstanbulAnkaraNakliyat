                                <th style="padding:10px 14px;text-align:center;">Metro</th>
                                <th style="padding:10px 14px;text-align:center;">Yakaya</th>
                                <th style="padding:10px 14px;text-align:center;">Hedef Kitle</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr style="border-bottom:1px solid #e0e0e0;"><td style="padding:10px 14px;font-weight:600;">Kadıköy</td><td style="padding:10px 14px;text-align:center;">15.000–35.000+</td><td style="padding:10px 14px;text-align:center;">✅</td><td style="padding:10px 14px;text-align:center;">Anadolu</td><td style="padding:10px 14px;text-align:center;">Genç profesyoneller</td></tr>
                            <tr style="border-bottom:1px solid #e0e0e0;background:#fafafa;"><td style="padding:10px 14px;font-weight:600;">Beşiktaş</td><td style="padding:10px 14px;text-align:center;">18.000–50.000+</td><td style="padding:10px 14px;text-align:center;">✅</td><td style="padding:10px 14px;text-align:center;">Avrupa</td><td style="padding:10px 14px;text-align:center;">Üst gelir</td></tr>
                            <tr style="border-bottom:1px solid #e0e0e0;"><td style="padding:10px 14px;font-weight:600;">Ataşehir</td><td style="padding:10px 14px;text-align:center;">14.000–30.000+</td><td style="padding:10px 14px;text-align:center;">✅</td><td style="padding:10px 14px;text-align:center;">Anadolu</td><td style="padding:10px 14px;text-align:center;">Finans sektörü</td></tr>
                            <tr style="border-bottom:1px solid #e0e0e0;background:#fafafa;"><td style="padding:10px 14px;font-weight:600;">Beylikdüzü</td><td style="padding:10px 14px;text-align:center;">8.000–18.000</td><td style="padding:10px 14px;text-align:center;">❌</td><td style="padding:10px 14px;text-align:center;">Avrupa</td><td style="padding:10px 14px;text-align:center;">Genç aileler</td></tr>
                            <tr style="border-bottom:1px solid #e0e0e0;"><td style="padding:10px 14px;font-weight:600;">Üsküdar</td><td style="padding:10px 14px;text-align:center;">10.000–25.000</td><td style="padding:10px 14px;text-align:center;">✅</td><td style="padding:10px 14px;text-align:center;">Anadolu</td><td style="padding:10px 14px;text-align:center;">Aileler</td></tr>
                            <tr style="border-bottom:1px solid #e0e0e0;background:#fafafa;"><td style="padding:10px 14px;font-weight:600;">Maltepe</td><td style="padding:10px 14px;text-align:center;">10.000–22.000</td><td style="padding:10px 14px;text-align:center;">❌</td><td style="padding:10px 14px;text-align:center;">Anadolu</td><td style="padding:10px 14px;text-align:center;">Aileler, deniz severleri</td></tr>
