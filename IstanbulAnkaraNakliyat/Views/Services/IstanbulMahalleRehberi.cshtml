                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div style="background:#f0fff4;border-radius:8px;padding:1rem;">
                                        <div style="font-size:.8rem;font-weight:700;color:#2d6a4f;margin-bottom:.5rem;">✅ Avantajlar</div>
                                        <div style="font-size:.88rem;color:var(--gray-700);">@ilce.Artı</div>
                                    </div>
                                </div>
