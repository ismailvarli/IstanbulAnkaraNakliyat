                }

                @foreach (var ilce in ilceler)
                {
                    <div style="border:1px solid #e0e0e0;border-radius:12px;overflow:hidden;margin-bottom:2rem;">
                        <div style="background:@ilce.Renk;color:#fff;padding:1.25rem 1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;">
                            <div>
                                <h2 style="font-size:1.2rem;font-weight:800;margin:0;color:#fff;">@ilce.Ad</h2>
                                <span style="font-size:.8rem;opacity:.85;">@ilce.Ozellik</span>
                            </div>
                            <div style="background:rgba(255,255,255,.15);padding:.4rem 1rem;border-radius:20px;font-size:.82rem;font-weight:600;">
                                @ilce.KiraMin – @ilce.KiraMax ₺/ay
                            </div>
                        </div>
                        <div style="padding:1.5rem;">
                            <p style="line-height:1.8;color:var(--gray-700);margin-bottom:1.25rem;font-size:.95rem;">@ilce.Aciklama</p>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div style="background:#f8f9fa;border-radius:8px;padding:1rem;">
                                        <div style="font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#888;margin-bottom:.5rem;">Ulaşım</div>
                                        <div style="font-size:.88rem;color:var(--gray-700);">@ilce.Ulasim</div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div style="background:#f8f9fa;border-radius:8px;padding:1rem;">
                                        <div style="font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#888;margin-bottom:.5rem;">Kim İçin Uygun?</div>
